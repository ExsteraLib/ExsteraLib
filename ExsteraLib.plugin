class FPSMonitor:

    def __init__(self):
        self._running = False
        self._fps = 0.0
        self._thread: Optional[threading.Thread] = None

    def start(self, on_fps: Callable[[float], None], interval_ms: int = 1000):
        self._running = True

        def _bg():
            try:
                from android.view import Choreographer
                import queue

                frame_queue: queue.Queue = queue.Queue()

                class FrameCallback:
                    def doFrame(self, frame_time_nanos):
                        if self_ref._running:
                            frame_queue.put(frame_time_nanos)
                            Choreographer.getInstance().postFrameCallback(self)

                cb = FrameCallback()
                self_ref = self
                Choreographer.getInstance().postFrameCallback(cb)

                interval_s = interval_ms / 1000.0
                while self._running:
                    deadline = time.time() + interval_s
                    count = 0
                    while time.time() < deadline:
                        try:
                            frame_queue.get(timeout=0.01)
                            count += 1
                        except Exception:
                            pass
                    self._fps = count / interval_s
                    on_fps(self._fps)
            except Exception:
                interval_s = interval_ms / 1000.0
                while self._running:
                    t0 = time.time()
                    time.sleep(interval_s)
                    elapsed = time.time() - t0
                    self._fps = 1.0 / elapsed if elapsed > 0 else 0.0
                    on_fps(self._fps)

        self._thread = threading.Thread(target=_bg, daemon=True)
        self._thread.start()

    def stop(self):
        self._running = False

    def current_fps(self) -> float:
        return self._fps

class MemoryMonitor:

    def get_used_mb(self) -> float:
        rt = self._runtime()
        return (rt.totalMemory() - rt.freeMemory()) / 1048576.0

    def get_total_mb(self) -> float:
        return self._runtime().maxMemory() / 1048576.0

    def get_free_mb(self) -> float:
        return self._runtime().freeMemory() / 1048576.0

    def log_usage(self, tag: str = ''):
        _log(f'{tag} Memory: used={self.get_used_mb():.1f}MB free={self.get_free_mb():.1f}MB')

    @staticmethod
    def _runtime():
        from java.lang import Runtime
        return Runtime.getRuntime()

class CPUMonitor:

    _last_total: int = 0
    _last_idle: int = 0
    _lock = threading.Lock()

    def get_load_percent(self) -> float:
        try:
            with open('/proc/stat', 'r') as f:
                line = f.readline()
            parts = line.split()
            values = [int(x) for x in parts[1:]]
            total = sum(values)
            idle = values[3] + (values[4] if len(values) > 4 else 0)
            with self._lock:
                delta_total = total - CPUMonitor._last_total
                delta_idle = idle - CPUMonitor._last_idle
                CPUMonitor._last_total = total
                CPUMonitor._last_idle = idle
            if delta_total == 0:
                return 0.0
            return (1.0 - delta_idle / delta_total) * 100.0
        except Exception as e:
            _log(f'CPUMonitor.get_load_percent: {e}')
            return 0.0

class PerformanceProfiler:

    def __init__(self):
        self._timings: Dict[str, List[float]] = {}
        self._starts: Dict[str, float] = {}
        self._lock = threading.Lock()

    def start(self, label: str):
        with self._lock:
            self._starts[label] = time.time()

    def end(self, label: str) -> float:
        with self._lock:
            t0 = self._starts.pop(label, time.time())
            elapsed = (time.time() - t0) * 1000.0
            self._timings.setdefault(label, []).append(elapsed)
        return elapsed

    def report(self) -> Dict[str, float]:
        with self._lock:
            return {k: sum(v) / len(v) for k, v in self._timings.items() if v}

    def clear(self):
        with self._lock:
            self._timings.clear()
            self._starts.clear()

class CrashReporter:

    _last_crash: Optional[str] = None
    _old_hook = None

    def install(self, plugin_id: str):
        self._old_hook = sys.excepthook

        reporter_ref = self

        def _hook(exc_type, exc_value, exc_tb):
            reporter_ref.report(exc_value, context=plugin_id)
            if reporter_ref._old_hook:
                reporter_ref._old_hook(exc_type, exc_value, exc_tb)

        sys.excepthook = _hook

    def report(self, exc: Exception, context: str = ''):
        tb_str = traceback.format_exc()
        header = f'[CrashReporter] context={context} exc={exc!r}'
        formatted = f'{header}\n{tb_str}'
        _log(formatted)
        self._last_crash = formatted

    def get_last_crash(self) -> Optional[str]:
        return self._last_crash

class DevToolsAPI:

    def __init__(self):
        self.fps = FPSMonitor()
        self.memory = MemoryMonitor()
        self.cpu = CPUMonitor()
        self.profiler = PerformanceProfiler()
        self.crash = CrashReporter()
        self._verbose = False

    def enable_verbose_logging(self, enabled: bool):
        self._verbose = enabled

    def log(self, tag: str, message: str, level: str = 'I'):
        _log(f'[{tag}][{level}] {message}')

    def debug(self, tag: str, msg: str):
        if self._verbose:
            self.log(tag, msg, 'D')

    def info(self, tag: str, msg: str):
        self.log(tag, msg, 'I')

    def warn(self, tag: str, msg: str):
        self.log(tag, msg, 'W')

    def error(self, tag: str, msg: str, exc=None):
        suffix = ('\n' + traceback.format_exc()) if exc else ''
        self.log(tag, msg + suffix, 'E')

    def dump_module_info(self) -> str:
        modules = ModuleRegistry.all()
        if not modules:
            return 'No modules registered.'
        col_name = max((len(m.get('name', '')) for m in modules), default=4)
        col_ver = max((len(str(m.get('version', ''))) for m in modules), default=7)
        header = f"{'Module':<{col_name}}  {'Version':<{col_ver}}  Description"
        sep = '-' * (col_name + col_ver + 30)
        rows = [header, sep]
        for m in modules:
            name = m.get('name', '')
            ver = str(m.get('version', ''))
            desc = m.get('description', '')
            rows.append(f'{name:<{col_name}}  {ver:<{col_ver}}  {desc}')
        return '\n'.join(rows)

    def is_debug_build(self) -> bool:
        try:
            checker = getattr(ApplicationLoader, 'isDebugBuild', None)
            if callable(checker):
                return bool(checker())
            return False
        except Exception:
            return False

    def check_health(self, target_plugin_id: str) -> List[str]:
        
        errors = []
        try:
            manifest = PluginRegistry.get_manifest(target_plugin_id) if hasattr(PluginRegistry, 'get_manifest') else None
            
            if not manifest:
                errors.append(f"⚠️ Манифест плагина {target_plugin_id} не найден. Убедитесь, что вы наследуетесь от ExsteraPlugin2.")
            
            leak_count = sum(1 for lst in _events._listeners.values() for p, fn in lst if p == target_plugin_id)
            if leak_count > 0:
                errors.append(f"❌ Утечка памяти: Найдено {leak_count} не очищенных слушателей событий. Используйте off_plugin(id) при выгрузке.")
            
            crash = self.crash.get_last_crash()
            if crash and target_plugin_id in crash:
                errors.append(f"❌ Недавно зафиксирован краш в этом плагине:\n{crash}")
            
            if not errors:
                errors.append(f"✅ Плагин {target_plugin_id} выглядит отлично! Замечаний нет.")
        except Exception as e:
            errors.append(f"⚠️ Ошибка выполнения HealthCheck: {e}")
        return errors

_register_module('DevTools', SDK_VERSION, 'DevTools: Logger/FPS/Memory/CPU/Profiler/CrashReporter')

