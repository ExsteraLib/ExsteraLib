class ClipboardUtils:
    def copy(self, text: str):
        def _do():
            from android.content import ClipboardManager, ClipData
            ctx = ApplicationLoader.applicationContext
            mgr = ctx.getSystemService(ctx.CLIPBOARD_SERVICE)
            mgr.setPrimaryClip(ClipData.newPlainText('', text))
        run_on_ui_thread(_do)

    def paste(self) -> Optional[str]:
        from android.content import ClipboardManager
        ctx = ApplicationLoader.applicationContext
        mgr = ctx.getSystemService(ctx.CLIPBOARD_SERVICE)
        if mgr.hasPrimaryClip():
            clip = mgr.getPrimaryClip()
            if clip is not None and clip.getItemCount() > 0:
                return str(clip.getItemAt(0).getText())
        return None

class JsonUtils:
    def dumps(self, obj: Any, indent=None, ensure_ascii=False) -> str:
        return json.dumps(obj, indent=indent, ensure_ascii=ensure_ascii)

    def loads(self, s: str) -> Any:
        return json.loads(s)

    def merge(self, base: dict, override: dict) -> dict:
        result = dict(base)
        for k, v in override.items():
            if k in result and isinstance(result[k], dict) and isinstance(v, dict):
                result[k] = self.merge(result[k], v)
            else:
                result[k] = v
        return result

    def get_nested(self, obj: dict, *keys, default=None) -> Any:
        cur = obj
        for k in keys:
            if not isinstance(cur, dict) or k not in cur:
                return default
            cur = cur[k]
        return cur

class StringUtils:
    def truncate(self, text: str, max_len: int, suffix='...') -> str:
        if len(text) <= max_len:
            return text
        return text[:max_len - len(suffix)] + suffix

    def plural(self, n: int, one: str, few: str, many: str) -> str:
        abs_n = abs(n)
        mod10 = abs_n % 10
        mod100 = abs_n % 100
        if mod10 == 1 and mod100 != 11:
            return one
        if 2 <= mod10 <= 4 and not (12 <= mod100 <= 14):
            return few
        return many

    def is_url(self, text: str) -> bool:
        return bool(re.match(r'https?://', text.strip()))

    def extract_urls(self, text: str) -> List[str]:
        return re.findall(r'https?://[^\s<>"\']+', text)

    def strip_html(self, html: str) -> str:
        return re.sub(r'<[^>]+>', '', html)

    def strip_markdown(self, md: str) -> str:
        s = re.sub(r'\*{1,3}(.+?)\*{1,3}', r'\1', md)
        s = re.sub(r'_{1,3}(.+?)_{1,3}', r'\1', s)
        s = re.sub(r'`{1,3}(.+?)`{1,3}', r'\1', s)
        s = re.sub(r'~~(.+?)~~', r'\1', s)
        s = re.sub(r'\[([^\]]+)\]\([^)]+\)', r'\1', s)
        return s

    def count_words(self, text: str) -> int:
        return len(text.split())

    def levenshtein(self, s1: str, s2: str) -> int:
        m, n = len(s1), len(s2)
        dp = list(range(n + 1))
        for i in range(1, m + 1):
            prev = dp[0]
            dp[0] = i
            for j in range(1, n + 1):
                temp = dp[j]
                if s1[i - 1] == s2[j - 1]:
                    dp[j] = prev
                else:
                    dp[j] = 1 + min(prev, dp[j], dp[j - 1])
                prev = temp
        return dp[n]

class TimeUtils:
    def now_ts(self) -> int:
        return int(_time.time())

    def format_duration(self, seconds: int) -> str:
        h = seconds // 3600
        m = (seconds % 3600) // 60
        s = seconds % 60
        if h > 0:
            return '%d:%02d:%02d' % (h, m, s)
        return '%d:%02d' % (m, s)

    def format_relative(self, ts: int) -> str:
        diff = int(_time.time()) - ts
        if diff < 60:
            n = diff
            return 'только что' if n < 5 else '%d %s назад' % (n, StringUtils().plural(n, 'секунду', 'секунды', 'секунд'))
        if diff < 3600:
            n = diff // 60
            return '%d %s назад' % (n, StringUtils().plural(n, 'минуту', 'минуты', 'минут'))
        if diff < 86400:
            n = diff // 3600
            return '%d %s назад' % (n, StringUtils().plural(n, 'час', 'часа', 'часов'))
        n = diff // 86400
        return '%d %s назад' % (n, StringUtils().plural(n, 'день', 'дня', 'дней'))

    def format_date(self, ts: int, fmt='%d.%m.%Y') -> str:
        import datetime
        return datetime.datetime.fromtimestamp(ts).strftime(fmt)

class ColorUtils:
    def int_to_hex(self, color: int) -> str:
        return '#%06X' % (color & 0xFFFFFF)

    def hex_to_int(self, hex_str: str) -> int:
        h = hex_str.lstrip('#')
        if len(h) == 6:
            return int(h, 16)
        if len(h) == 8:
            return int(h, 16)
        raise ValueError('Invalid hex color: ' + hex_str)

    def blend(self, c1: int, c2: int, ratio: float) -> int:
        r1, g1, b1 = (c1 >> 16) & 0xFF, (c1 >> 8) & 0xFF, c1 & 0xFF
        r2, g2, b2 = (c2 >> 16) & 0xFF, (c2 >> 8) & 0xFF, c2 & 0xFF
        r = int(r1 + (r2 - r1) * ratio)
        g = int(g1 + (g2 - g1) * ratio)
        b = int(b1 + (b2 - b1) * ratio)
        return (r << 16) | (g << 8) | b

    def lighten(self, color: int, amount: float) -> int:
        delta = int(amount * 255)
        r = min(255, ((color >> 16) & 0xFF) + delta)
        g = min(255, ((color >> 8) & 0xFF) + delta)
        b = min(255, (color & 0xFF) + delta)
        return (r << 16) | (g << 8) | b

    def darken(self, color: int, amount: float) -> int:
        delta = int(amount * 255)
        r = max(0, ((color >> 16) & 0xFF) - delta)
        g = max(0, ((color >> 8) & 0xFF) - delta)
        b = max(0, (color & 0xFF) - delta)
        return (r << 16) | (g << 8) | b

    def get_luminance(self, color: int) -> float:
        r = (color >> 16) & 0xFF
        g = (color >> 8) & 0xFF
        b = color & 0xFF
        return (0.299 * r + 0.587 * g + 0.114 * b) / 255.0

    def is_dark_color(self, color: int) -> bool:
        return self.get_luminance(color) < 0.5

class DeviceUtils:
    def get_model(self) -> str:
        import android.os
        return android.os.Build.MODEL

    def get_android_version(self) -> str:
        import android.os
        return android.os.Build.VERSION.RELEASE

    def get_app_version(self) -> str:
        ctx = ApplicationLoader.applicationContext
        return ctx.getPackageManager().getPackageInfo(ctx.getPackageName(), 0).versionName

    def is_tablet(self) -> bool:
        from android.content.res import Configuration
        ctx = ApplicationLoader.applicationContext
        layout = ctx.getResources().getConfiguration().screenLayout
        size = layout & Configuration.SCREENLAYOUT_SIZE_MASK
        return size >= Configuration.SCREENLAYOUT_SIZE_LARGE

    def get_density(self) -> float:
        ctx = ApplicationLoader.applicationContext
        return ctx.getResources().getDisplayMetrics().density

    def get_screen_width_dp(self) -> int:
        ctx = ApplicationLoader.applicationContext
        dm = ctx.getResources().getDisplayMetrics()
        return int(dm.widthPixels / dm.density)

    def get_screen_height_dp(self) -> int:
        ctx = ApplicationLoader.applicationContext
        dm = ctx.getResources().getDisplayMetrics()
        return int(dm.heightPixels / dm.density)

class ThreadUtils:
    def run_on_ui(self, fn: Callable):
        run_on_ui_thread(fn)

    def run_async(self, fn: Callable, callback: Callable = None):
        def _run():
            try:
                result = fn()
            except Exception as e:
                _log('ThreadUtils.run_async error: ' + str(e))
                result = None
            if callback is not None:
                def _cb():
                    callback(result)
                run_on_ui_thread(_cb)
        t = threading.Thread(target=_run)
        t.daemon = True
        t.start()

    def delay(self, ms: int, fn: Callable) -> threading.Timer:
        t = threading.Timer(ms / 1000.0, fn)
        t.daemon = True
        t.start()
        return t

    def cancel_delayed(self, handle: threading.Timer) -> bool:
        handle.cancel()
        return True

class UtilsAPI:
    clipboard = ClipboardUtils()
    json_utils = JsonUtils()
    strings = StringUtils()
    time_utils = TimeUtils()
    colors = ColorUtils()
    device = DeviceUtils()
    threads = ThreadUtils()

_register_module('Utils', SDK_VERSION, 'Утилиты: Clipboard/Json/Strings/Time/Colors/Device/Threads')

# ===========================================================================
# MODULE: _plugin
# ===========================================================================

from dataclasses import dataclass, field

@dataclass
class PluginManifest:
    id: str
    name: str
    version: str
    min_lib_version: str = '2.0.0'
    author: str = ''
    description: str = ''
    permissions: List[str] = field(default_factory=list)
    dependencies: List[str] = field(default_factory=list)
    channel: str = ''
    update_url: str = ''

class PluginRegistry:
    _manifests: Dict[str, PluginManifest] = {}
    _lock = threading.RLock()

    def register(self, manifest: PluginManifest):
        with self._lock:
            self._manifests[manifest.id] = manifest

    def unregister(self, plugin_id: str):
        with self._lock:
            self._manifests.pop(plugin_id, None)

    def get(self, plugin_id: str) -> Optional[PluginManifest]:
        with self._lock:
            return self._manifests.get(plugin_id)

    def all(self) -> List[PluginManifest]:
        with self._lock:
            return list(self._manifests.values())

    def count(self) -> int:
        with self._lock:
            return len(self._manifests)

    def is_registered(self, plugin_id: str) -> bool:
        with self._lock:
            return plugin_id in self._manifests

    def get_dependents(self, plugin_id: str) -> List[str]:
        with self._lock:
            return [m.id for m in self._manifests.values() if plugin_id in m.dependencies]

    def check_dependencies(self, manifest: PluginManifest) -> List[str]:
        with self._lock:
            return [dep for dep in manifest.dependencies if dep not in self._manifests]

    def compare_versions(self, v1: str, v2: str) -> int:
        def _parts(v):
            try:
                return tuple(int(x) for x in v.split('.'))
            except Exception:
                return (0,)
        t1, t2 = _parts(v1), _parts(v2)
        if t1 < t2:
            return -1
        if t1 > t2:
            return 1
        return 0

    def resolve_load_order(self, manifests: List[PluginManifest]) -> List[PluginManifest]:
        id_map = {m.id: m for m in manifests}
        visited = set()
        in_stack = set()
        order = []

        def visit(mid):
            if mid in in_stack:
                _log('PluginRegistry: cycle detected at ' + mid)
                return False
            if mid in visited:
                return True
            m = id_map.get(mid)
            if m is None:
                return True
            in_stack.add(mid)
            for dep in m.dependencies:
                if dep in id_map:
                    if not visit(dep):
                        in_stack.discard(mid)
                        return False
            in_stack.discard(mid)
            visited.add(mid)
            order.append(m)
            return True

        for m in manifests:
            if m.id not in visited:
                if not visit(m.id):
                    for fm in manifests:
                        if fm.id not in visited and fm not in order:
                            order.append(fm)
                    break

        return order

class PluginIPC:
    _handlers: Dict[str, Dict[str, Callable]] = {}
    _lock = threading.RLock()

    def send(self, from_id: str, to_id: str, event: str, data: Any):
        with self._lock:
            plugin_handlers = self._handlers.get(to_id, {})
            cb = plugin_handlers.get(event)
        if cb is not None:
            _safe_call(cb, from_id, data)

    def on(self, plugin_id: str, event: str, cb: Callable[[str, Any], None]):
        with self._lock:
            if plugin_id not in self._handlers:
                self._handlers[plugin_id] = {}
            self._handlers[plugin_id][event] = cb

    def off(self, plugin_id: str):
        with self._lock:
            self._handlers.pop(plugin_id, None)

    def broadcast(self, from_id: str, event: str, data: Any):
        with self._lock:
            targets = [(pid, handlers.get(event)) for pid, handlers in self._handlers.items() if pid != from_id]
        for pid, cb in targets:
            if cb is not None:
                _safe_call(cb, from_id, data)

_register_module('Plugin', SDK_VERSION, 'PluginRegistry/Manifest/Dependencies/IPC')

