from dataclasses import dataclass

@dataclass
class GiftInfo:
    gift_id: int = 0
    from_user_id: int = 0
    to_user_id: int = 0
    date: int = 0
    message: str = ''
    stars_amount: int = 0
    is_pinned: bool = False
    is_saved: bool = False
    is_unlimited: bool = False
    slug: str = ''

class GiftsAPI:
    _buttons: list = []
    _menu_items: list = []

    def get_received_gifts(self, user_id: int, on_result: Callable[[List[GiftInfo]], None]):
        req = TLRPC.TL_payments_getUserStarGifts()
        req.user_id = self._input_user(user_id)
        req.offset = ''
        req.limit = 100

        def _on_response(res, err):
            gifts = []
            if err is None and res is not None:
                try:
                    for tl in res.gifts:
                        gifts.append(self._parse_gift(tl))
                except Exception as e:
                    _log('get_received_gifts parse error: ' + str(e))
            run_on_ui_thread(lambda: on_result(gifts))

        send_request(req, _on_response)

    def get_sent_gifts(self, on_result: Callable[[List[GiftInfo]], None]):
        cfg = get_user_config()
        own_id = cfg.clientUserId

        def _got_all(gifts):
            sent = [g for g in gifts if g.from_user_id == own_id]
            on_result(sent)

        self.get_received_gifts(own_id, _got_all)

    def send_gift(self, to_user_id: int, stars: int, message: str, on_done: Callable[[bool], None]):
        req = TLRPC.TL_payments_sendStarGift()
        req.user_id = self._input_user(to_user_id)
        gift = TLRPC.TL_starGiftUnique() if False else TLRPC.TL_inputInvoiceStarGift()
        try:
            req.gift = gift
        except Exception:
            pass
        try:
            req.message = TLRPC.TL_textWithEntities()
            req.message.text = message
        except Exception:
            pass

        def _on_response(res, err):
            ok = err is None and res is not None
            run_on_ui_thread(lambda: on_done(ok))

        send_request(req, _on_response)

    def pin_gift(self, gift_id: int, on_done: Callable[[bool], None]):
        req = TLRPC.TL_payments_saveStarGift()
        req.stargift_id = gift_id
        req.pinned = True

        def _on_response(res, err):
            ok = err is None and res is not None
            run_on_ui_thread(lambda: on_done(ok))

        send_request(req, _on_response)

    def unpin_gift(self, gift_id: int, on_done: Callable[[bool], None]):
        req = TLRPC.TL_payments_saveStarGift()
        req.stargift_id = gift_id
        req.pinned = False

        def _on_response(res, err):
            ok = err is None and res is not None
            run_on_ui_thread(lambda: on_done(ok))

        send_request(req, _on_response)

    def save_gift(self, gift_id: int, unsave: bool = False, on_done: Callable[[bool], None] = None):
        req = TLRPC.TL_payments_saveStarGift()
        req.stargift_id = gift_id
        req.unsave = unsave

        def _on_response(res, err):
            ok = err is None and res is not None
            if on_done is not None:
                run_on_ui_thread(lambda: on_done(ok))

        send_request(req, _on_response)

    def get_gift_history(self, on_result: Callable[[List[GiftInfo]], None]):
        cfg = get_user_config()
        own_id = cfg.clientUserId
        self.get_received_gifts(own_id, on_result)

    def add_gift_button(self, plugin_id: str, text: str, icon: str, on_click: Callable[[GiftInfo], None]):
        self._buttons.append({'plugin_id': plugin_id, 'text': text, 'icon': icon, 'on_click': on_click})

    def add_gift_menu_item(self, plugin_id: str, text: str, icon: str, on_click: Callable[[GiftInfo], None]):
        self._menu_items.append({'plugin_id': plugin_id, 'text': text, 'icon': icon, 'on_click': on_click})

    def get_buttons(self) -> list:
        return list(self._buttons)

    def get_menu_items(self) -> list:
        return list(self._menu_items)

    def _parse_gift(self, tl_obj: Any) -> GiftInfo:
        info = GiftInfo()
        try:
            info.gift_id = getattr(tl_obj, 'msg_id', 0) or getattr(tl_obj, 'stargift_id', 0)
            info.from_user_id = getattr(tl_obj, 'from_id', 0)
            info.date = getattr(tl_obj, 'date', 0)
            info.is_pinned = getattr(tl_obj, 'pinned', False)
            info.is_saved = not getattr(tl_obj, 'unsaved', True)
            info.slug = str(getattr(tl_obj, 'slug', ''))
            gift = getattr(tl_obj, 'gift', None)
            if gift is not None:
                info.stars_amount = getattr(gift, 'stars', 0)
                info.is_unlimited = not getattr(gift, 'limited', True)
            msg = getattr(tl_obj, 'message', None)
            if msg is not None:
                info.message = str(getattr(msg, 'text', ''))
        except Exception as e:
            _log('_parse_gift error: ' + str(e))
        return info

    def _input_user(self, user_id: int) -> Any:
        from org.telegram.messenger import MessagesController, UserConfig
        account = UserConfig.selectedAccount
        ctrl = MessagesController.getInstance(account)
        user = ctrl.getUser(user_id)
        inp = TLRPC.TL_inputUser()
        if user is not None:
            inp.user_id = user.id
            inp.access_hash = user.access_hash
        else:
            inp.user_id = user_id
            inp.access_hash = 0
        return inp

_register_module('Gifts', SDK_VERSION, 'Подарки: get/send/pin/save/history')

# ===========================================================================
# MODULE: _ui
# ===========================================================================

from dataclasses import dataclass, field

def _ctx():
    return ApplicationLoader.applicationContext

def _dp(value: float) -> int:
    try:
        return int(value * _ctx().getResources().getDisplayMetrics().density + 0.5)
    except Exception:
        return int(value * 3)

class BottomSheetBuilder:
    def __init__(self):
        self._title     = ""
        self._content   = None
        self._items: List[Dict] = []
        self._cancelable = True
        self._on_dismiss: Optional[Callable] = None

    def title(self, text: str) -> "BottomSheetBuilder":
        self._title = text
        return self

    def content(self, view: Any) -> "BottomSheetBuilder":
        self._content = view
        return self

    def item(self, text: str, icon: str = "", on_click: Optional[Callable] = None) -> "BottomSheetBuilder":
        self._items.append({"text": text, "icon": icon, "on_click": on_click})
        return self

    def cancelable(self, value: bool) -> "BottomSheetBuilder":
        self._cancelable = value
        return self

    def on_dismiss(self, cb: Callable) -> "BottomSheetBuilder":
        self._on_dismiss = cb
        return self

    def show(self) -> None:
        run_on_ui_thread(self._do_show)

    def _do_show(self) -> None:
        try:
            from org.telegram.ui.ActionBar import BottomSheet
            frag = get_last_fragment()
            if not frag:
                return
            ctx = frag.getParentActivity()
            builder = BottomSheet.Builder(ctx, self._cancelable)
            if self._title:
                builder.setTitle(self._title)
            if self._content:
                builder.setCustomView(self._content)
            if self._items:
                items_text = [i["text"] for i in self._items]
                builder.setItems(items_text, lambda d, which: (
                    _safe_call(self._items[which]["on_click"]) if self._items[which]["on_click"] else None
                ))
            sheet = builder.create()
            if self._on_dismiss:
                sheet.setOnDismissListener(lambda d: _safe_call(self._on_dismiss))
            sheet.show()
        except Exception as e:
            _log(f"BottomSheet show error: {e}")

class AlertDialogBuilder:
    def __init__(self):
        self._title   = ""
        self._message = ""
        self._positive_text = "OK"
        self._negative_text = ""
        self._neutral_text  = ""
        self._positive_cb: Optional[Callable] = None
        self._negative_cb: Optional[Callable] = None
        self._neutral_cb:  Optional[Callable] = None
        self._cancelable  = True
        self._custom_view = None

    def title(self, t: str) -> "AlertDialogBuilder":
        self._title = t; return self

    def message(self, m: str) -> "AlertDialogBuilder":
        self._message = m; return self

    def positive(self, text: str, cb: Optional[Callable] = None) -> "AlertDialogBuilder":
        self._positive_text = text; self._positive_cb = cb; return self

    def negative(self, text: str, cb: Optional[Callable] = None) -> "AlertDialogBuilder":
        self._negative_text = text; self._negative_cb = cb; return self

    def neutral(self, text: str, cb: Optional[Callable] = None) -> "AlertDialogBuilder":
        self._neutral_text = text; self._neutral_cb = cb; return self

    def cancelable(self, v: bool) -> "AlertDialogBuilder":
        self._cancelable = v; return self

    def custom_view(self, view: Any) -> "AlertDialogBuilder":
        self._custom_view = view; return self

    def show(self) -> None:
        run_on_ui_thread(self._do_show)

    def _do_show(self) -> None:
        try:
            from org.telegram.ui.ActionBar import AlertDialog
            frag = get_last_fragment()
            if not frag:
                return
            ctx = frag.getParentActivity()
            builder = AlertDialog.Builder(ctx)
            if self._title:
                builder.setTitle(self._title)
            if self._message:
                builder.setMessage(self._message)
            if self._custom_view:
                builder.setView(self._custom_view)
            builder.setPositiveButton(self._positive_text, lambda d, w: (
                _safe_call(self._positive_cb) if self._positive_cb else None
            ))
            if self._negative_text:
                builder.setNegativeButton(self._negative_text, lambda d, w: (
                    _safe_call(self._negative_cb) if self._negative_cb else None
                ))
            if self._neutral_text:
                builder.setNeutralButton(self._neutral_text, lambda d, w: (
                    _safe_call(self._neutral_cb) if self._neutral_cb else None
                ))
            dialog = builder.create()
            dialog.setCancelable(self._cancelable)
            dialog.show()
        except Exception as e:
            _log(f"AlertDialog show error: {e}")

class SnackbarHelper:
    @staticmethod
    def show(message: str, duration_ms: int = 3000, action_text: str = "", action_cb: Optional[Callable] = None) -> None:
        run_on_ui_thread(lambda: SnackbarHelper._do_show(message, duration_ms, action_text, action_cb))

    @staticmethod
    def _do_show(message: str, duration_ms: int, action_text: str, action_cb: Optional[Callable]) -> None:
        try:
            BulletinHelper.show_message(message)
        except Exception:
            try:
                from android.widget import Toast
                Toast.makeText(_ctx(), message, Toast.LENGTH_SHORT).show()
            except Exception as e:
                _log(f"Snackbar fallback error: {e}")

    @staticmethod
    def error(message: str) -> None:
        run_on_ui_thread(lambda: SnackbarHelper._do_error(message))

    @staticmethod
    def _do_error(message: str) -> None:
        try:
            BulletinHelper.show_error(message)
        except Exception:
            SnackbarHelper._do_show(message, 3000, "", None)

class ToastHelper:
    @staticmethod
    def show(message: str, long: bool = False) -> None:
        run_on_ui_thread(lambda: ToastHelper._do_show(message, long))

    @staticmethod
    def _do_show(message: str, long: bool) -> None:
        try:
            from android.widget import Toast
            duration = Toast.LENGTH_LONG if long else Toast.LENGTH_SHORT
            Toast.makeText(_ctx(), message, duration).show()
        except Exception as e:
            _log(f"Toast error: {e}")

@dataclass
class MenuItem:
    text:     str
    icon:     str     = ""
    on_click: Optional[Callable] = None
    danger:   bool    = False

class PopupMenuBuilder:
    def __init__(self):
        self._items: List[MenuItem] = []
        self._anchor_view: Any = None

    def anchor(self, view: Any) -> "PopupMenuBuilder":
        self._anchor_view = view; return self

    def item(self, text: str, icon: str = "", on_click: Optional[Callable] = None, danger: bool = False) -> "PopupMenuBuilder":
        self._items.append(MenuItem(text=text, icon=icon, on_click=on_click, danger=danger))
        return self

    def show(self) -> None:
        run_on_ui_thread(self._do_show)

    def _do_show(self) -> None:
        try:
            from android.widget import PopupMenu
            if not self._anchor_view:
                return
            from android.view import Gravity
            menu = PopupMenu(_ctx(), self._anchor_view, Gravity.END)
            for i, item in enumerate(self._items):
                menu.getMenu().add(0, i, i, item.text)
            menu.setOnMenuItemClickListener(lambda mi: (
                _safe_call(self._items[mi.getItemId()].on_click)
                if self._items[mi.getItemId()].on_click else None,
                True
            )[-1])
            menu.show()
        except Exception as e:
            _log(f"PopupMenu error: {e}")

@dataclass
class RecyclerItem:
    data:       Any
    view_type:  int = 0

class RecyclerBuilder:
    def __init__(self):
        self._items:       List[RecyclerItem] = []
        self._create_view: Optional[Callable[[int], Any]]              = None
        self._bind_view:   Optional[Callable[[Any, RecyclerItem], None]] = None
        self._layout:      str = "linear"
        self._columns:     int = 1
        self._on_click:    Optional[Callable[[RecyclerItem], None]] = None
        self._on_long_click: Optional[Callable[[RecyclerItem], None]] = None

    def items(self, data: List[Any]) -> "RecyclerBuilder":
        self._items = [RecyclerItem(d) for d in data]; return self

    def create_view(self, fn: Callable[[int], Any]) -> "RecyclerBuilder":
        self._create_view = fn; return self

    def bind_view(self, fn: Callable[[Any, RecyclerItem], None]) -> "RecyclerBuilder":
        self._bind_view = fn; return self

    def linear(self) -> "RecyclerBuilder":
        self._layout = "linear"; return self

    def grid(self, columns: int = 2) -> "RecyclerBuilder":
        self._layout = "grid"; self._columns = columns; return self

    def on_click(self, fn: Callable[[RecyclerItem], None]) -> "RecyclerBuilder":
        self._on_click = fn; return self

    def on_long_click(self, fn: Callable[[RecyclerItem], None]) -> "RecyclerBuilder":
        self._on_long_click = fn; return self

    def build(self) -> Any:
        run_on_ui_thread(lambda: None)
        try:
            from androidx.recyclerview.widget import RecyclerView, LinearLayoutManager, GridLayoutManager
            import java.lang.reflect.Proxy as Proxy

            ctx = _ctx()
            rv  = RecyclerView(ctx)

            if self._layout == "grid":
                rv.setLayoutManager(GridLayoutManager(ctx, self._columns))
            else:
                rv.setLayoutManager(LinearLayoutManager(ctx))

            items      = self._items
            create_fn  = self._create_view
            bind_fn    = self._bind_view
            click_fn   = self._on_click
            lclick_fn  = self._on_long_click

            class _Adapter(RecyclerView.Adapter):
                def getItemCount(self):
                    return len(items)

                def onCreateViewHolder(self, parent, view_type):
                    view = create_fn(view_type) if create_fn else RecyclerView(ctx)
                    return RecyclerView.ViewHolder(view)

                def onBindViewHolder(self, holder, pos):
                    item = items[pos]
                    if bind_fn:
                        bind_fn(holder.itemView, item)
                    if click_fn:
                        holder.itemView.setOnClickListener(
                            lambda v, i=item: _safe_call(click_fn, i)
                        )
                    if lclick_fn:
                        holder.itemView.setOnLongClickListener(
                            lambda v, i=item: (_safe_call(lclick_fn, i), True)[-1]
                        )

            rv.setAdapter(_Adapter())
            return rv
        except Exception as e:
            _log(f"RecyclerBuilder.build error: {e}")
            return None

class BadgeHelper:
    @staticmethod
    def set_count(view: Any, count: int, color: int = 0xFFFF3B30) -> None:
        run_on_ui_thread(lambda: BadgeHelper._do_set(view, count, color))

    @staticmethod
    def _do_set(view: Any, count: int, color: int) -> None:
        try:
            from com.google.android.material.badge import BadgeDrawable
            if count <= 0:
                view.setForeground(None)
                return
            from android.graphics.drawable import GradientDrawable
            from android.widget import TextView
            badge_view = TextView(_ctx())
            badge_view.setText(str(count) if count < 100 else "99+")
            badge_view.setTextSize(10)
            badge_view.setTextColor(0xFFFFFFFF)
            bg = GradientDrawable()
            bg.setShape(GradientDrawable.OVAL)
            bg.setColor(color)
            badge_view.setBackground(bg)
        except Exception as e:
            _log(f"BadgeHelper error: {e}")

    @staticmethod
    def clear(view: Any) -> None:
        run_on_ui_thread(lambda: BadgeHelper._do_set(view, 0, 0))

class LoadingBuilder:
    @staticmethod
    def create_progress_bar(color: int = 0xFF2196F3) -> Any:
        try:
            from android.widget import ProgressBar
            pb = ProgressBar(_ctx(), None, 16842874)  # progressBarStyleSmall
            try:
                from android.graphics import PorterDuff, PorterDuffColorFilter
                pb.getIndeterminateDrawable().setColorFilter(
                    PorterDuffColorFilter(color, PorterDuff.Mode.SRC_IN)
                )
            except Exception:
                pass
            return pb
        except Exception as e:
            _log(f"LoadingBuilder error: {e}")
            return None

    @staticmethod
    def create_progress_dialog(title: str, cancelable: bool = True) -> Any:
        try:
            from android.app import ProgressDialog
            pd = ProgressDialog(_ctx())
            pd.setMessage(title)
            pd.setCancelable(cancelable)
            pd.setIndeterminate(True)
            return pd
        except Exception as e:
            _log(f"ProgressDialog error: {e}")
            return None

class GradientView:
    @staticmethod
    def create(colors: List[int], orientation: str = "top_bottom") -> Any:
        try:
            from android.graphics.drawable import GradientDrawable
            orientations = {
                "top_bottom": GradientDrawable.Orientation.TOP_BOTTOM,
                "left_right": GradientDrawable.Orientation.LEFT_RIGHT,
                "tl_br":      GradientDrawable.Orientation.TL_BR,
                "tr_bl":      GradientDrawable.Orientation.TR_BL,
            }
            gd = GradientDrawable(
                orientations.get(orientation, GradientDrawable.Orientation.TOP_BOTTOM),
                colors
            )
            gd.setGradientType(GradientDrawable.LINEAR_GRADIENT)
            return gd
        except Exception as e:
            _log(f"GradientView error: {e}")
            return None

class CardBuilder:
    def __init__(self):
        self._content:      Any = None
        self._corner_dp:    float = 12.0
        self._elevation_dp: float = 4.0
        self._bg_color:     int   = 0xFFFFFFFF
        self._padding_dp:   int   = 12

    def content(self, view: Any) -> "CardBuilder":
        self._content = view; return self

    def corner(self, dp: float) -> "CardBuilder":
        self._corner_dp = dp; return self

    def elevation(self, dp: float) -> "CardBuilder":
        self._elevation_dp = dp; return self

    def background(self, color: int) -> "CardBuilder":
        self._bg_color = color; return self

    def build(self) -> Any:
        try:
            from com.google.android.material.card import MaterialCardView
            card = MaterialCardView(_ctx())
            card.setRadius(_dp(self._corner_dp))
            card.setCardElevation(_dp(self._elevation_dp))
            card.setCardBackgroundColor(self._bg_color)
            card.setContentPadding(
                _dp(self._padding_dp), _dp(self._padding_dp),
                _dp(self._padding_dp), _dp(self._padding_dp)
            )
            if self._content:
                card.addView(self._content)
            return card
        except Exception:
            try:
                from android.widget import FrameLayout
                from android.graphics.drawable import GradientDrawable
                fl = FrameLayout(_ctx())
                bg = GradientDrawable()
                bg.setColor(self._bg_color)
                bg.setCornerRadius(_dp(self._corner_dp))
                fl.setBackground(bg)
                pad = _dp(self._padding_dp)
                fl.setPadding(pad, pad, pad, pad)
                if self._content:
                    fl.addView(self._content)
                return fl
            except Exception as e:
                _log(f"CardBuilder error: {e}")
                return None

class UIAPI:
    def bottom_sheet(self) -> BottomSheetBuilder:
        return BottomSheetBuilder()

    def alert_dialog(self) -> AlertDialogBuilder:
        return AlertDialogBuilder()

    def popup_menu(self) -> PopupMenuBuilder:
        return PopupMenuBuilder()

    def recycler(self) -> RecyclerBuilder:
        return RecyclerBuilder()

    def card(self) -> CardBuilder:
        return CardBuilder()

    def snackbar(self, message: str, duration_ms: int = 3000) -> None:
        SnackbarHelper.show(message, duration_ms)

    def snackbar_error(self, message: str) -> None:
        SnackbarHelper.error(message)

    def toast(self, message: str, long: bool = False) -> None:
        ToastHelper.show(message, long)

    def progress_bar(self, color: int = 0xFF2196F3) -> Any:
        return LoadingBuilder.create_progress_bar(color)

    def progress_dialog(self, title: str, cancelable: bool = True) -> Any:
        return LoadingBuilder.create_progress_dialog(title, cancelable)

    def gradient(self, colors: List[int], orientation: str = "top_bottom") -> Any:
        return GradientView.create(colors, orientation)

    def badge(self, view: Any, count: int, color: int = 0xFFFF3B30) -> None:
        BadgeHelper.set_count(view, count, color)

    def dp(self, value: float) -> int:
        return _dp(value)

_register_module("UI", SDK_VERSION, "UI: BottomSheet/AlertDialog/Snackbar/Toast/Recycler/Card/Badge")

# ===========================================================================
# MODULE: ExsteraLib (main)
# ===========================================================================

__id__          = "exsteralib"
__name__        = "ExsteraLib"
__description__ = "SDK-библиотека для разработки плагинов ExteraGram"
__author__      = "@Slitlers"
__version__     = "1"
__icon__        = "fgsfds1/50"
__min_version__ = "11.9.0"

SDK_VERSION        = "1.0.0"
SDK_VERSION_LEGACY = "1"
VERIFIED_APK       = "12.2.10"
_LOG_TAG           = "[ExsteraLib]"

def _import_module(name: str, path: str) -> Optional[Any]:
    try:
        import importlib
        mod = importlib.import_module(path)
        log(f"{_LOG_TAG} ✓ {name}")
        return mod
    except Exception:
        log(f"{_LOG_TAG} ✗ {name}: {traceback.format_exc()}")
        return None

def _log(msg: str) -> None:
    log(f"{_LOG_TAG} {msg}")

def _safe_call(fn: Callable, *args, plugin_id: Optional[str] = None, **kwargs) -> Any:
    try:
        return fn(*args, **kwargs)
    except Exception:
        tag = f"[{plugin_id}]" if plugin_id else ""
        _log(f"{tag} callback error: {traceback.format_exc()}")
        return None

class _ExteraFacade:
    def __init__(self, owner: "ExsteraLib"):
        self._owner       = owner
        self._cache       = CacheAPI()
        self._events_api  = EventsAPI()
        self._storage     = StorageAPI()
        self._hook_api    = HookAPI(owner)
        self._chat        = ChatAPI()
        self._messages    = MessagesAPI(owner)
        self._compose     = ComposeAPI()
        self._theme       = ThemeAPI()
        self._profile     = ProfileAPI()
        self._settings    = SettingsAPI()
        self._network     = NetworkAPI()
        self._media       = MediaAPI()
        self._navigation  = NavigationAPI()
        self._notifs      = NotificationsAPI()
        self._scheduler   = SchedulerAPI()
        self._permissions = PermissionsAPI()
        self._animation   = AnimationAPI()
        self._ai          = AIAPI()
        self._devtools    = DevToolsAPI()
        self._utils       = UtilsAPI()
        self._plugin_reg  = PluginRegistry()
        self._ipc         = PluginIPC()
        self._stories     = StoriesAPI()
        self._nft         = NFTAPI()
        self._gifts       = GiftsAPI()
        self._ui          = UIAPI()

        self.hooks = self._hook_api

    def cache(self)       -> CacheAPI:       return self._cache
    def events(self)      -> EventsAPI:      return self._events_api
    def storage(self)     -> StorageAPI:     return self._storage
    def chat(self)        -> ChatAPI:        return self._chat
    def messages(self)    -> MessagesAPI:    return self._messages
    def compose(self)     -> ComposeAPI:     return self._compose
    def theme(self)       -> ThemeAPI:       return self._theme
    def profile(self)     -> ProfileAPI:     return self._profile
    def settings(self)    -> SettingsAPI:    return self._settings
    def network(self)     -> NetworkAPI:     return self._network
    def media(self)       -> MediaAPI:       return self._media
    def navigation(self)  -> NavigationAPI:  return self._navigation
    def notifications(self) -> NotificationsAPI: return self._notifs
    def scheduler(self)   -> SchedulerAPI:   return self._scheduler
    def permissions(self) -> PermissionsAPI: return self._permissions
    def animation(self)   -> AnimationAPI:   return self._animation
    def ai(self)          -> AIAPI:          return self._ai
    def devtools(self)    -> DevToolsAPI:    return self._devtools
    def utils(self)       -> UtilsAPI:       return self._utils
    def stories(self)     -> StoriesAPI:     return self._stories
    def nft(self)         -> NFTAPI:         return self._nft
    def gifts(self)       -> GiftsAPI:       return self._gifts
    def ui(self)          -> UIAPI:          return self._ui
    def registry(self)    -> PluginRegistry: return self._plugin_reg
    def ipc(self)         -> PluginIPC:      return self._ipc

    def version(self) -> str:
        return SDK_VERSION

    def version_legacy(self) -> str:
        return SDK_VERSION_LEGACY

Extera: _ExteraFacade

class ExsteraPlugin(BasePlugin):
    __min_lib_version__: Optional[str] = None

    def on_extera_load(self) -> None:
        pass

    def on_extera_unload(self) -> None:
        pass

    def on_plugin_load(self) -> None:
        if self.__min_lib_version__:
            have = tuple(int(x) for x in SDK_VERSION.split("."))
            need = tuple(int(x) for x in self.__min_lib_version__.split("."))
            if have < need:
                raise Exception(
                    f"{self.id} требует ExsteraLib >= {self.__min_lib_version__}, "
                    f"установлена {SDK_VERSION}"
                )
        _events.emit("plugin_loaded", self.id)
        self.on_extera_load()

    def on_plugin_unload(self) -> None:
        try:
            self.on_extera_unload()
        finally:
            Extera.storage().flush(self.id)
            _events.off_plugin(self.id)
            Extera.messages().off_plugin(self.id)
            Extera.compose().off_plugin(self.id)
            Extera.hooks.unhook_all(self.id)
            _events.emit("plugin_unloaded", self.id)

class ExsteraPlugin2(ExsteraPlugin):
    manifest: Optional[PluginManifest] = None

    def on_plugin_load(self) -> None:
        if self.manifest:
            Extera.registry().register(self.manifest)
        super().on_plugin_load()

    def on_plugin_unload(self) -> None:
        try:
            super().on_plugin_unload()
        finally:
            if self.manifest:
                Extera.registry().unregister(self.manifest.id)
                Extera.ipc().off(self.manifest.id)

class ExsteraLib(BasePlugin):

    def create_settings(self) -> List[Any]:
        items = [
            Header(text="ExsteraLib 1 "),
            Text(text=f"Сборка SDK: {SDK_VERSION}", icon="msg_info"),
            Divider(),
            Header(text="Статус модулей"),
        ]

        modules = ModuleRegistry.all()
        enabled = ModuleRegistry.enabled_count()
        total   = ModuleRegistry.total_count()

        items.append(
            Text(
                text=f"Загружено успешно: {enabled} из {total}",
                icon="msg_permissions",
            )
        )
        items.append(Divider())

        for info in sorted(modules, key=lambda m: m.name):
            if info.enabled:
                title = f"✅  {info.name} (v1)"
                subtext = info.description
                icon = "msg_check"
            else:
                title = f"❌  {info.name} (Ошибка)"
                subtext = f"Ошибка: {info.error}" if info.error else "Не удалось загрузить"
                icon = "msg_warning"

            items.append(
                Text(
                    text=title,
                    icon=icon,
                )
            )

        items.append(Divider())
        items.append(
            Text(
                text="Powered by @Slitlers",
                icon="msg_star",
            )
        )
        return items

    def on_plugin_load(self) -> None:
        global Extera
        Extera = _ExteraFacade(self)

        self._self_check()
        self.add_on_send_message_hook()

        _log(f"loaded v{SDK_VERSION}")

    def _self_check(self) -> None:
        checks = [
            ("ChatActivityEnterView.addTopView", lambda: hasattr(ChatActivityEnterView, "addTopView")),
            ("Theme.getColor",                  lambda: hasattr(Theme, "getColor")),
            ("Theme.key_chat_outBubble",         lambda: hasattr(Theme, "key_chat_outBubble")),
            ("MediaController.getInstance",      lambda: hasattr(MediaController, "getInstance")),
        ]
        broken = []
        for label, check in checks:
            try:
                if not check():
                    broken.append(label)
            except Exception:
                broken.append(label)

        if broken:
            msg = (
                f"ExsteraLib: часть API устарела для этой версии ExteraGram "
                f"(проверялось на {VERIFIED_APK}): {', '.join(broken)}"
            )
            _log(msg)
            run_on_ui_thread(lambda: BulletinHelper.show_error(msg))

    def on_plugin_unload(self) -> None:
        _log("unloaded")

    def on_send_message_hook(self, account: int, params: Any) -> HookResult:
        return Extera.messages().dispatch_send(account, params)

    def on_app_event(self, event_type: "AppEvent") -> None:
        if event_type == AppEvent.START:
            _events.emit("app_started")
        elif event_type == AppEvent.STOP:
            _events.emit("app_stopped")