class PromptBuilder:

    def __init__(self):
        self._parts: List[Dict[str, str]] = []

    def system(self, text: str) -> 'PromptBuilder':
        self._parts.append({'role': 'system', 'content': text})
        return self

    def user(self, text: str) -> 'PromptBuilder':
        self._parts.append({'role': 'user', 'content': text})
        return self

    def assistant(self, text: str) -> 'PromptBuilder':
        self._parts.append({'role': 'assistant', 'content': text})
        return self

    def build(self) -> str:
        return json.dumps({'messages': self._parts}, ensure_ascii=False)

    def build_text(self) -> str:
        lines = []
        for part in self._parts:
            role = part.get('role', 'user').capitalize()
            lines.append(f"{role}: {part.get('content', '')}")
        return '\n'.join(lines)

class AIAPI:

    def __init__(self):
        self._endpoint: str = ''
        self._api_key: str = ''
        self._model: str = 'gpt-3.5-turbo'

    def configure(self, endpoint: str, api_key: str = '', model: str = 'gpt-3.5-turbo'):
        self._endpoint = endpoint
        self._api_key = api_key
        self._model = model

    def is_configured(self) -> bool:
        return bool(self._endpoint)

    def translate(self, text: str, target_lang: str, on_result: Callable[[Optional[str]], None]):
        try:
            req = TLRPC.TL_messages_translateText()
            req.flags |= 2
            req.text = [TLRPC.TL_textWithEntities()]
            req.text[0].text = text
            req.to_lang = target_lang

            def _on_response(response, error):
                if error or not response:
                    run_on_ui_thread(lambda: on_result(None))
                    return
                try:
                    result_text = response.result[0].text
                    run_on_ui_thread(lambda: on_result(result_text))
                except Exception as e:
                    _log(f'translate parse error: {e}')
                    run_on_ui_thread(lambda: on_result(None))

            send_request(req, _on_response)
        except Exception as e:
            _log(f'translate error: {e}')
            run_on_ui_thread(lambda: on_result(None))

    def rewrite(self, text: str, style: str = 'formal', on_result: Callable[[Optional[str]], None] = None):
        if not self.is_configured():
            run_on_ui_thread(lambda: on_result('[AI] Not configured: call configure() first'))
            return
        self._call_endpoint(f'Rewrite in {style} style: {text}', on_result)

    def grammar_fix(self, text: str, on_result: Callable[[Optional[str]], None]):
        if not self.is_configured():
            run_on_ui_thread(lambda: on_result('[AI] Not configured: call configure() first'))
            return
        self._call_endpoint(f'Fix grammar and spelling: {text}', on_result)

    def summarize(self, text: str, on_result: Callable[[Optional[str]], None]):
        if not self.is_configured():
            run_on_ui_thread(lambda: on_result('[AI] Not configured: call configure() first'))
            return
        self._call_endpoint(f'Summarize briefly: {text}', on_result)

    def explain(self, text: str, on_result: Callable[[Optional[str]], None]):
        if not self.is_configured():
            run_on_ui_thread(lambda: on_result('[AI] Not configured: call configure() first'))
            return
        self._call_endpoint(f'Explain simply: {text}', on_result)

    def continue_text(self, text: str, on_result: Callable[[Optional[str]], None]):
        if not self.is_configured():
            run_on_ui_thread(lambda: on_result('[AI] Not configured: call configure() first'))
            return
        self._call_endpoint(f'Continue naturally: {text}', on_result)

    def smart_reply(self, context: List[str], on_result: Callable[[List[str]], None]):
        if not self.is_configured():
            run_on_ui_thread(lambda: on_result([]))
            return
        context_str = '\n'.join(context)
        prompt = f'Suggest 3 short replies to this conversation, return as JSON array: {context_str}'

        def _wrapped(raw: Optional[str]):
            if not raw:
                on_result([])
                return
            try:
                cleaned = raw.strip().strip('`').strip()
                if cleaned.startswith('json'):
                    cleaned = cleaned[4:].strip()
                replies = json.loads(cleaned)
                if isinstance(replies, list):
                    on_result(replies[:3])
                else:
                    on_result([])
            except Exception:
                on_result([])

        self._call_endpoint(prompt, _wrapped)

    def detect_language(self, text: str, on_result: Callable[[Optional[str]], None]):
        if not self.is_configured():
            run_on_ui_thread(lambda: on_result(None))
            return
        self._call_endpoint(f'Detect language code (2 letters) of: {text}', on_result)

    def _call_endpoint(self, prompt: str, on_result: Callable[[Optional[str]], None]):
        def _bg():
            try:
                import urllib.request
                payload = json.dumps({
                    'model': self._model,
                    'messages': [{'role': 'user', 'content': prompt}],
                    'max_tokens': 500,
                }).encode('utf-8')
                req = urllib.request.Request(
                    self._endpoint,
                    data=payload,
                    headers={
                        'Content-Type': 'application/json',
                        'Authorization': f'Bearer {self._api_key}',
                    },
                    method='POST',
                )
                with urllib.request.urlopen(req, timeout=30) as resp:
                    data = json.loads(resp.read().decode('utf-8'))
                result = data['choices'][0]['message']['content'].strip()
                run_on_ui_thread(lambda: on_result(result))
            except Exception as e:
                _log(f'_call_endpoint error: {e}')
                run_on_ui_thread(lambda: on_result(None))

        threading.Thread(target=_bg, daemon=True).start()

    def prompt_builder(self) -> PromptBuilder:
        return PromptBuilder()

_register_module('AI', SDK_VERSION, 'AI: translate/rewrite/grammar/summarize/smart-reply')

