from dataclasses import dataclass, field

@dataclass
class NFTInfo:
    nft_id: int = 0
    owner_id: int = 0
    title: str = ''
    collection: str = ''
    description: str = ''
    image_url: str = ''
    animation_url: str = ''
    price_stars: int = 0
    floor_price_stars: int = 0
    is_for_sale: bool = False
    attributes: Dict[str, str] = field(default_factory=dict)

class NFTAPI:
    _buttons: list = []
    _menu_items: list = []

    def get_user_nfts(self, user_id: int, on_result: Callable[[List[NFTInfo]], None]):
        req = TLRPC.TL_payments_getUserStarGifts()
        req.user_id = self._input_user(user_id)

        def _on_response(res, err):
            nfts = []
            if err is None and res is not None:
                try:
                    for gift in res.gifts:
                        if getattr(gift, 'slug', None) or getattr(getattr(gift, 'gift', None), 'limited', False):
                            nfts.append(self._parse_nft_from_tl(gift))
                except Exception as e:
                    _log('get_user_nfts parse error: ' + str(e))
            run_on_ui_thread(lambda: on_result(nfts))

        send_request(req, _on_response)

    def get_nft(self, nft_id: int, owner_id: int, on_result: Callable[[Optional[NFTInfo]], None]):
        def _got_nfts(nfts):
            found = next((n for n in nfts if n.nft_id == nft_id), None)
            on_result(found)

        self.get_user_nfts(owner_id, _got_nfts)

    def get_collection(self, collection_name: str, on_result: Callable[[List[NFTInfo]], None]):
        from org.telegram.messenger import UserConfig
        account = UserConfig.selectedAccount
        from org.telegram.messenger import UserConfig as UC
        own_id = UC.getInstance(account).getClientUserId()

        def _got_nfts(nfts):
            filtered = [n for n in nfts if n.collection == collection_name]
            on_result(filtered)

        self.get_user_nfts(own_id, _got_nfts)

    def transfer_nft(self, nft_id: int, to_user_id: int, on_done: Callable[[bool], None]):
        req = TLRPC.TL_payments_transferStarGift()
        req.stargift_id = nft_id
        req.to_id = self._input_user(to_user_id)

        def _on_response(res, err):
            ok = err is None and res is not None
            run_on_ui_thread(lambda: on_done(ok))

        send_request(req, _on_response)

    def add_nft_button(self, plugin_id: str, text: str, icon: str, on_click: Callable[[NFTInfo], None]):
        self._buttons.append({'plugin_id': plugin_id, 'text': text, 'icon': icon, 'on_click': on_click})

    def add_nft_menu_item(self, plugin_id: str, text: str, icon: str, on_click: Callable[[NFTInfo], None]):
        self._menu_items.append({'plugin_id': plugin_id, 'text': text, 'icon': icon, 'on_click': on_click})

    def get_buttons(self) -> list:
        return list(self._buttons)

    def get_menu_items(self) -> list:
        return list(self._menu_items)

    def share_nft(self, nft_info: NFTInfo):
        link = 'https://t.me/nft/' + (nft_info.nft_id if isinstance(nft_info.nft_id, str) else str(nft_info.nft_id))
        text = '%s — %s\n%s' % (nft_info.title, nft_info.collection, link)
        try:
            from org.telegram.messenger import ShareActivity
            ShareActivity.share(text)
        except Exception as e:
            _log('share_nft error: ' + str(e))

    def _parse_nft_from_tl(self, tl_obj: Any) -> NFTInfo:
        info = NFTInfo()
        try:
            info.nft_id = getattr(tl_obj, 'msg_id', 0) or getattr(tl_obj, 'stargift_id', 0)
            gift = getattr(tl_obj, 'gift', tl_obj)
            info.title = str(getattr(gift, 'title', ''))
            info.collection = str(getattr(gift, 'collection_name', ''))
            info.description = str(getattr(gift, 'description', ''))
            info.price_stars = getattr(gift, 'stars', 0)
            info.floor_price_stars = getattr(gift, 'resell_stars', 0) or info.price_stars
            info.is_for_sale = getattr(tl_obj, 'can_resell', False)
            info.slug = getattr(tl_obj, 'slug', '')
            raw_attrs = getattr(gift, 'attributes', None)
            if raw_attrs:
                for attr in raw_attrs:
                    k = str(getattr(attr, 'name', ''))
                    v = str(getattr(attr, 'value', ''))
                    if k:
                        info.attributes[k] = v
        except Exception as e:
            _log('_parse_nft_from_tl error: ' + str(e))
        return info

    def _input_user(self, user_id: int) -> Any:
        from org.telegram.messenger import MessagesController, UserConfig
        account = UserConfig.selectedAccount
        ctrl = MessagesController.getInstance(account)
        user = ctrl.getUser(user_id)
        inp = TLRPC.TL_inputUser()
        if user is not None:
            inp.user_id = user.id
            inp.access_hash = user.access_hash
        else:
            inp.user_id = user_id
            inp.access_hash = 0
        return inp

_register_module('NFT', SDK_VERSION, 'NFT: get/transfer/collection/metadata/кнопки')

