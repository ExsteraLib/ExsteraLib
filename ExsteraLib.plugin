SDK_VERSION       = "1.0.0"
SDK_VERSION_TUPLE = (2, 0, 0)
SDK_VERSION_LEGACY = "1"        # алиас для backward-compat проверок
VERIFIED_APK     = "12.2.10"
LOG_TAG          = "[ExsteraLib]"

class Logger:
    

    LEVEL_DEBUG = 0
    LEVEL_INFO  = 1
    LEVEL_WARN  = 2
    LEVEL_ERROR = 3

    _global_level = LEVEL_DEBUG
    _lock = threading.Lock()

    def __init__(self, tag: str, level: int = LEVEL_DEBUG):
        self._tag = tag
        self._level = level
        self._handlers: List[Callable[[int, str, str], None]] = []

    @classmethod
    def set_global_level(cls, level: int) -> None:
        
        cls._global_level = level

    def add_handler(self, handler: Callable[[int, str, str], None]) -> None:
        
        self._handlers.append(handler)

    def _emit(self, level: int, msg: str) -> None:
        if level < max(self._level, self._global_level):
            return
        prefix = {
            self.LEVEL_DEBUG: "D",
            self.LEVEL_INFO:  "I",
            self.LEVEL_WARN:  "W",
            self.LEVEL_ERROR: "E",
        }.get(level, "?")
        full = f"{LOG_TAG}[{self._tag}][{prefix}] {msg}"
        with self._lock:
            log(full)
        for h in self._handlers:
            try:
                h(level, self._tag, msg)
            except Exception:
                pass

    def debug(self, msg: str) -> None:
        
        self._emit(self.LEVEL_DEBUG, msg)

    def info(self, msg: str) -> None:
        
        self._emit(self.LEVEL_INFO, msg)

    def warn(self, msg: str, exc: Optional[Exception] = None) -> None:
        
        if exc:
            msg = f"{msg}\n{traceback.format_exc()}"
        self._emit(self.LEVEL_WARN, msg)

    def error(self, msg: str, exc: Optional[Exception] = None) -> None:
        
        if exc:
            msg = f"{msg}\n{traceback.format_exc()}"
        self._emit(self.LEVEL_ERROR, msg)

_root_log = Logger("Core")

def _log(msg: str) -> None:
    
    log(f"{LOG_TAG} {msg}")

def _safe_call(
    fn: Callable,
    *args,
    plugin_id: Optional[str] = None,
    logger: Optional[Logger] = None,
    **kwargs,
) -> Any:
    
    try:
        return fn(*args, **kwargs)
    except Exception:
        tag = f"[{plugin_id}]" if plugin_id else ""
        msg = f"{tag} callback error: {traceback.format_exc()}"
        if logger:
            logger.error(msg)
        else:
            _log(msg)
        return None

class _EventBus:
    

    def __init__(self):
        self._handlers: Dict[str, Dict[str, List[Dict]]] = {}
        self._lock = threading.RLock()

    def on(
        self,
        event: str,
        plugin_id: str,
        callback: Callable,
        priority: int = 0,
        once: bool = False,
    ) -> None:
        
        with self._lock:
            entry = {"cb": callback, "priority": priority, "once": once}
            (
                self._handlers
                    .setdefault(event, {})
                    .setdefault(plugin_id, [])
                    .append(entry)
            )
            self._handlers[event][plugin_id].sort(
                key=lambda x: x["priority"], reverse=True
            )

    def off(self, event: str, plugin_id: str, callback: Optional[Callable] = None) -> None:
        
        with self._lock:
            plugin_map = self._handlers.get(event, {})
            if plugin_id not in plugin_map:
                return
            if callback is None:
                plugin_map.pop(plugin_id, None)
            else:
                plugin_map[plugin_id] = [
                    e for e in plugin_map[plugin_id] if e["cb"] is not callback
                ]

    def off_plugin(self, plugin_id: str) -> None:
        
        with self._lock:
            for handlers in self._handlers.values():
                handlers.pop(plugin_id, None)

    def emit(self, event: str, *args, **kwargs) -> None:
        
        with self._lock:
            snapshot = {
                pid: list(entries)
                for pid, entries in self._handlers.get(event, {}).items()
            }
        to_remove: List[tuple] = []
        for plugin_id, entries in snapshot.items():
            for entry in entries:
                _safe_call(entry["cb"], *args, plugin_id=plugin_id, **kwargs)
                if entry["once"]:
                    to_remove.append((event, plugin_id, entry["cb"]))
        for ev, pid, cb in to_remove:
            self.off(ev, pid, cb)

    def has_subscribers(self, event: str) -> bool:
        
        with self._lock:
            return bool(self._handlers.get(event))

    def event_count(self) -> int:
        
        return len(self._handlers)

    def subscribers_count(self, event: str) -> int:
        
        with self._lock:
            return sum(
                len(entries)
                for entries in self._handlers.get(event, {}).values()
            )

_events: _EventBus = _EventBus()

class _HookRegistry:
    

    def __init__(self, owner: Any):
        self._owner = owner
        self._by_plugin: Dict[str, List[Any]] = {}
        self._lock = threading.RLock()

    def hook(
        self,
        plugin_id: str,
        java_method: Any,
        hook_obj: Any,
        priority: int = 0,
    ) -> None:
        
        handle = self._owner.hook_method(java_method, hook_obj, priority)
        with self._lock:
            self._by_plugin.setdefault(plugin_id, []).append(handle)

    def unhook(self, plugin_id: str, handle: Any) -> None:
        
        try:
            self._owner.unhook_method(handle)
        except Exception:
            _log(f"unhook failed for {plugin_id}: {traceback.format_exc()}")
        with self._lock:
            entries = self._by_plugin.get(plugin_id, [])
            if handle in entries:
                entries.remove(handle)

    def unhook_all(self, plugin_id: str) -> None:
        
        with self._lock:
            handles = self._by_plugin.pop(plugin_id, [])
        for handle in handles:
            try:
                self._owner.unhook_method(handle)
            except Exception:
                _log(f"unhook_all failed for {plugin_id}: {traceback.format_exc()}")

    def count(self, plugin_id: Optional[str] = None) -> int:
        
        with self._lock:
            if plugin_id:
                return len(self._by_plugin.get(plugin_id, []))
            return sum(len(v) for v in self._by_plugin.values())

    @staticmethod
    def find_method(java_class_path: str, signature_contains: str) -> Any:
        
        methods = find_class(java_class_path).getClass().getDeclaredMethods()
        for m in methods:
            if signature_contains in repr(m):
                return m
        raise LookupError(
            f"Метод не найден: {java_class_path} / '{signature_contains}' "
            f"(сигнатура могла измениться — проверялось на {VERIFIED_APK})"
        )

T = TypeVar("T")

class ServiceLocator:
    

    _registry: Dict[Any, Callable] = {}
    _singletons: Dict[Any, Any] = {}
    _lock = threading.RLock()

    @classmethod
    def register(
        cls,
        key: Any,
        factory: Callable[[], Any],
        singleton: bool = True,
    ) -> None:
        
        with cls._lock:
            cls._registry[key] = (factory, singleton)
            cls._singletons.pop(key, None)

    @classmethod
    def get(cls, key: Any) -> Any:
        
        with cls._lock:
            if key not in cls._registry:
                raise KeyError(f"ServiceLocator: не зарегистрировано: {key}")
            factory, is_singleton = cls._registry[key]
            if is_singleton:
                if key not in cls._singletons:
                    cls._singletons[key] = factory()
                return cls._singletons[key]
            return factory()

    @classmethod
    def has(cls, key: Any) -> bool:
        
        return key in cls._registry

    @classmethod
    def unregister(cls, key: Any) -> None:
        
        with cls._lock:
            cls._registry.pop(key, None)
            cls._singletons.pop(key, None)

class ModuleInfo:
    

    def __init__(
        self,
        name: str,
        version: str,
        description: str,
        enabled: bool = True,
    ):
        self.name        = name
        self.version     = version
        self.description = description
        self.enabled     = enabled
        self.load_time_ms: float = 0.0
        self.error: Optional[str] = None

class ModuleRegistry:
    

    _modules: Dict[str, ModuleInfo] = {}
    _lock = threading.RLock()

    @classmethod
    def register(
        cls,
        name: str,
        version: str,
        description: str,
        enabled: bool = True,
    ) -> ModuleInfo:
        
        info = ModuleInfo(name, version, description, enabled)
        with cls._lock:
            cls._modules[name] = info
        return info

    @classmethod
    def set_error(cls, name: str, error: str) -> None:
        
        with cls._lock:
            if name in cls._modules:
                cls._modules[name].enabled = False
                cls._modules[name].error = error

    @classmethod
    def set_load_time(cls, name: str, ms: float) -> None:
        
        with cls._lock:
            if name in cls._modules:
                cls._modules[name].load_time_ms = ms

    @classmethod
    def get(cls, name: str) -> Optional[ModuleInfo]:
        
        return cls._modules.get(name)

    @classmethod
    def all(cls) -> List[ModuleInfo]:
        
        with cls._lock:
            return list(cls._modules.values())

    @classmethod
    def enabled_count(cls) -> int:
        
        return sum(1 for m in cls._modules.values() if m.enabled)

    @classmethod
    def total_count(cls) -> int:
        
        return len(cls._modules)

def _register_module(name: str, version: str, description: str) -> None:
    
    t0 = time.time()
    info = ModuleRegistry.register(name, version, description)
    ModuleRegistry.set_load_time(name, (time.time() - t0) * 1000)
    _log(f"module '{name}' v{version} registered")

_register_module("Core", SDK_VERSION, "Ядро ExsteraLib SDK")

# ===========================================================================
# MODULE: _cache
# ===========================================================================

class _TTLEntry:
    

    __slots__ = ("value", "expires_at")

    def __init__(self, value: Any, ttl_seconds: Optional[float]):
        self.value = value
        self.expires_at = (
            time.time() + ttl_seconds if ttl_seconds is not None else None
        )

    def is_expired(self) -> bool:
        
        return self.expires_at is not None and time.time() > self.expires_at

class LRUCache:
    

    def __init__(
        self,
        max_size: int = 512,
        default_ttl: Optional[float] = None,
    ):
        
        self._max_size = max_size
        self._default_ttl = default_ttl
        self._store: OrderedDict = OrderedDict()
        self._lock = threading.RLock()
        self._hits = 0
        self._misses = 0

    def get(self, key: str, default: Any = None) -> Any:
        
        with self._lock:
            entry = self._store.get(key)
            if entry is None:
                self._misses += 1
                return default
            if entry.is_expired():
                del self._store[key]
                self._misses += 1
                return default
            self._store.move_to_end(key)
            self._hits += 1
            return entry.value

    def put(
        self,
        key: str,
        value: Any,
        ttl: Optional[float] = None,
    ) -> None:
        
        effective_ttl = ttl if ttl is not None else self._default_ttl
        with self._lock:
            if key in self._store:
                self._store.move_to_end(key)
            self._store[key] = _TTLEntry(value, effective_ttl)
            if len(self._store) > self._max_size:
                self._store.popitem(last=False)

    def invalidate(self, key: str) -> bool:
        
        with self._lock:
            if key in self._store:
                del self._store[key]
                return True
            return False

    def invalidate_prefix(self, prefix: str) -> int:
        
        with self._lock:
            keys = [k for k in self._store if k.startswith(prefix)]
            for k in keys:
                del self._store[k]
            return len(keys)

    def clear(self) -> None:
        
        with self._lock:
            self._store.clear()

    def evict_expired(self) -> int:
        
        with self._lock:
            expired = [k for k, v in self._store.items() if v.is_expired()]
            for k in expired:
                del self._store[k]
            return len(expired)

    def size(self) -> int:
        
        return len(self._store)

    def stats(self) -> dict:
        
        total = self._hits + self._misses
        return {
            "hits":     self._hits,
            "misses":   self._misses,
            "hit_rate": self._hits / total if total else 0.0,
            "size":     len(self._store),
            "max_size": self._max_size,
        }

    def get_or_compute(
        self,
        key: str,
        factory: Callable[[], Any],
        ttl: Optional[float] = None,
    ) -> Any:
        
        value = self.get(key)
        if value is None:
            value = factory()
            if value is not None:
                self.put(key, value, ttl)
        return value

class DiskCache:
    

    def __init__(self, namespace: str, max_entries: int = 256):
        
        self._namespace = namespace
        self._max_entries = max_entries
        self._lock = threading.RLock()
        self._dir = self._ensure_dir()

    def _ensure_dir(self) -> str:
        d = File(
            ApplicationLoader.applicationContext.getExternalCacheDir(),
            f"exsteralib_diskcache/{self._namespace}",
        )
        if not d.exists():
            d.mkdirs()
        return d.getAbsolutePath()

    def _path_for(self, key: str) -> str:
        safe = key.replace("/", "_").replace("\\", "_")[:120]
        return os.path.join(self._dir, f"{safe}.json")

    def get(self, key: str, default: Any = None) -> Any:
        
        path = self._path_for(key)
        try:
            with self._lock:
                with open(path, "r", encoding="utf-8") as f:
                    data = json.load(f)
            expires_at = data.get("expires_at")
            if expires_at is not None and time.time() > expires_at:
                os.remove(path)
                return default
            return data["value"]
        except Exception:
            return default

    def put(self, key: str, value: Any, ttl: Optional[float] = None) -> None:
        
        path = self._path_for(key)
        data = {
            "value": value,
            "expires_at": (time.time() + ttl) if ttl is not None else None,
            "created_at": time.time(),
        }
        with self._lock:
            with open(path, "w", encoding="utf-8") as f:
                json.dump(data, f, ensure_ascii=False)
        self._maybe_evict()

    def invalidate(self, key: str) -> bool:
        
        path = self._path_for(key)
        try:
            os.remove(path)
            return True
        except Exception:
            return False

    def clear(self) -> int:
        
        count = 0
        with self._lock:
            for f in os.listdir(self._dir):
                try:
                    os.remove(os.path.join(self._dir, f))
                    count += 1
                except Exception:
                    pass
        return count

    def evict_expired(self) -> int:
        
        count = 0
        with self._lock:
            for fname in list(os.listdir(self._dir)):
                path = os.path.join(self._dir, fname)
                try:
                    with open(path, "r", encoding="utf-8") as f:
                        data = json.load(f)
                    expires_at = data.get("expires_at")
                    if expires_at and time.time() > expires_at:
                        os.remove(path)
                        count += 1
                except Exception:
                    pass
        return count

    def _maybe_evict(self) -> None:
        
        with self._lock:
            try:
                files = [
                    (os.path.getmtime(os.path.join(self._dir, f)), f)
                    for f in os.listdir(self._dir)
                    if f.endswith(".json")
                ]
                if len(files) > self._max_entries:
                    files.sort()
                    for _, fname in files[: len(files) - self._max_entries]:
                        try:
                            os.remove(os.path.join(self._dir, fname))
                        except Exception:
                            pass
            except Exception:
                pass

    def size(self) -> int:
        
        try:
            return len([
                f for f in os.listdir(self._dir) if f.endswith(".json")
            ])
        except Exception:
            return 0

class ImageCache:
    

    def __init__(
        self,
        memory_size: int = 64,
        disk_ttl: float = 86400.0,
    ):
        
        self._memory = LRUCache(max_size=memory_size)
        self._disk   = DiskCache("images")
        self._disk_ttl = disk_ttl

    def get(self, key: str) -> Optional[bytes]:
        
        data = self._memory.get(key)
        if data is not None:
            return data
        disk_data = self._disk.get(key)
        if disk_data is not None:
            import base64
            try:
                raw = base64.b64decode(disk_data)
                self._memory.put(key, raw)
                return raw
            except Exception:
                return None
        return None

    def put(self, key: str, data: bytes) -> None:
        
        import base64
        self._memory.put(key, data)
        self._disk.put(key, base64.b64encode(data).decode(), ttl=self._disk_ttl)

    def invalidate(self, key: str) -> None:
        
        self._memory.invalidate(key)
        self._disk.invalidate(key)

    def clear(self) -> None:
        
        self._memory.clear()
        self._disk.clear()

class CacheAPI:
    

    def __init__(self):
        self._memory    = LRUCache(max_size=1024, default_ttl=None)
        self._disk_ns: dict = {}
        self._images    = ImageCache()
        self._lock      = threading.RLock()

    def memory(self) -> LRUCache:
        
        return self._memory

    def disk(self, namespace: str = "global") -> DiskCache:
        
        with self._lock:
            if namespace not in self._disk_ns:
                self._disk_ns[namespace] = DiskCache(namespace)
            return self._disk_ns[namespace]

    def images(self) -> ImageCache:
        
        return self._images

    def evict_all_expired(self) -> dict:
        
        mem_removed = self._memory.evict_expired()
        disk_removed = 0
        img_removed  = 0
        with self._lock:
            for dc in self._disk_ns.values():
                disk_removed += dc.evict_expired()
        return {
            "memory": mem_removed,
            "disk":   disk_removed,
            "images": img_removed,
        }

    def stats(self) -> dict:
        
        return {
            "memory": self._memory.stats(),
            "disk_namespaces": list(self._disk_ns.keys()),
        }

_register_module("Cache", SDK_VERSION, "LRU/Disk/Image кэш с TTL и статистикой")

