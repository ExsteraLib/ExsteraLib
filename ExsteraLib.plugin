        self, event: str, plugin_id: str, cb: Callable
    ) -> None:
        
        _events.on(event, plugin_id, cb)

    def once(self, event: str, plugin_id: str, cb: Callable) -> None:
        
        _events.on(event, plugin_id, cb, once=True)

    def off(self, event: str, plugin_id: str) -> None:
        
        _events.off(event, plugin_id)

    def off_plugin(self, plugin_id: str) -> None:
        
        _events.off_plugin(plugin_id)

    def _emit_app_started(self) -> None:
        _events.emit("app_started")

    def _emit_app_stopped(self) -> None:
        _events.emit("app_stopped")

    def _emit_chat_opened(self, dialog_id: int) -> None:
        _events.emit("chat_opened", dialog_id)

    def _emit_chat_closed(self, dialog_id: int) -> None:
        _events.emit("chat_closed", dialog_id)

    def _emit_profile_opened(self, user_id: int) -> None:
        _events.emit("profile_opened", user_id)

    def _emit_message_received(self, msg: Any) -> None:
        _events.emit("message_received", msg)

    def _emit_message_sent(self, account: int, params: Any) -> None:
        _events.emit("message_sent", account, params)

    def _emit_message_edited(self, msg: Any) -> None:
        _events.emit("message_edited", msg)

    def _emit_message_deleted(self, dialog_id: int, msg_ids: list) -> None:
        _events.emit("message_deleted", dialog_id, msg_ids)

    def _emit_theme_changed(self) -> None:
        _events.emit("theme_changed")

    def _emit_keyboard_opened(self, height: int) -> None:
        _events.emit("keyboard_opened", height)

    def _emit_keyboard_closed(self) -> None:
        _events.emit("keyboard_closed")

    def _emit_network_changed(self, is_connected: bool) -> None:
        _events.emit("network_changed", is_connected)
        if is_connected:
            _events.emit("network_connected")
        else:
            _events.emit("network_disconnected")

    def _emit_settings_opened(self) -> None:
        _events.emit("settings_opened")

    def _emit_story_opened(self, user_id: int) -> None:
        _events.emit("story_opened", user_id)

    def _emit_plugin_loaded(self, plugin_id: str) -> None:
        _events.emit("plugin_loaded", plugin_id)

    def _emit_plugin_unloaded(self, plugin_id: str) -> None:
        _events.emit("plugin_unloaded", plugin_id)

_register_module(
    "Events",
    SDK_VERSION,
    "Шина событий: app/chat/profile/message/story/theme/keyboard/network",
)

# ===========================================================================
# MODULE: _storage
# ===========================================================================

class _JsonStore:
    

    _FLUSH_DELAY = 0.3  # секунды

    def __init__(self, path: str):
        self._path = path
        self._lock = threading.RLock()
        self._data: Dict[str, Any] = {}
        self._flush_timer: Optional[threading.Timer] = None
        self._load()

    def _load(self) -> None:
        with self._lock:
            try:
                with open(self._path, "r", encoding="utf-8") as f:
                    self._data = json.load(f)
            except Exception:
                self._data = {}

    def _flush_now(self) -> None:
        with self._lock:
            try:
                os.makedirs(os.path.dirname(self._path), exist_ok=True)
                with open(self._path, "w", encoding="utf-8") as f:
                    json.dump(self._data, f, ensure_ascii=False, indent=2)
            except Exception as e:
                _log(f"_JsonStore flush error: {e}")
            self._flush_timer = None

    def _schedule_flush(self) -> None:
        with self._lock:
            if self._flush_timer is not None:
                return
            self._flush_timer = threading.Timer(self._FLUSH_DELAY, self._flush_now)
            self._flush_timer.daemon = True
            self._flush_timer.start()

    def get(self, key: str, default: Any = None) -> Any:
        
        with self._lock:
            return self._data.get(key, default)

    def get_all(self) -> Dict[str, Any]:
        
        with self._lock:
            return dict(self._data)

    def set(self, key: str, value: Any) -> None:
        
        with self._lock:
            self._data[key] = value
        self._schedule_flush()

    def update(self, data: Dict[str, Any]) -> None:
        
        with self._lock:
            self._data.update(data)
        self._schedule_flush()

    def pop(self, key: str, default: Any = None) -> Any:
        
        with self._lock:
            value = self._data.pop(key, default)
        self._schedule_flush()
        return value

    def clear(self) -> None:
        
        with self._lock:
            self._data = {}
        self._schedule_flush()

    def flush_sync(self) -> None:
        
        with self._lock:
            if self._flush_timer is not None:
                self._flush_timer.cancel()
                self._flush_timer = None
            try:
                os.makedirs(os.path.dirname(self._path), exist_ok=True)
                with open(self._path, "w", encoding="utf-8") as f:
                    json.dump(self._data, f, ensure_ascii=False, indent=2)
            except Exception as e:
                _log(f"_JsonStore flush_sync error: {e}")

    def contains(self, key: str) -> bool:
        
        with self._lock:
            return key in self._data

    def keys(self) -> list:
        
        with self._lock:
            return list(self._data.keys())

def _base_dir() -> str:
    
    d = File(
        ApplicationLoader.applicationContext.getExternalCacheDir(),
        "exsteralib_storage",
    )
    if not d.exists():
        d.mkdirs()
    return d.getAbsolutePath()

def _make_store(path: str) -> _JsonStore:
    
    full = os.path.join(_base_dir(), path)
    os.makedirs(os.path.dirname(full), exist_ok=True)
    return _JsonStore(full)

class StorageAPI:
    

    def __init__(self):
        self._plugin_stores:  Dict[str, _JsonStore] = {}
        self._account_stores: Dict[str, Dict[int, _JsonStore]] = {}
        self._chat_stores:    Dict[str, Dict[int, _JsonStore]] = {}
        self._lock = threading.RLock()

    def _plugin_store(self, plugin_id: str) -> _JsonStore:
        with self._lock:
            if plugin_id not in self._plugin_stores:
                self._plugin_stores[plugin_id] = _make_store(
                    f"plugins/{plugin_id}/data.json"
                )
            return self._plugin_stores[plugin_id]

    def get(self, plugin_id: str, key: str, default: Any = None) -> Any:
        
        return self._plugin_store(plugin_id).get(key, default)

    def set(self, plugin_id: str, key: str, value: Any) -> None:
        
        self._plugin_store(plugin_id).set(key, value)

    def pop(self, plugin_id: str, key: str, default: Any = None) -> Any:
        
        return self._plugin_store(plugin_id).pop(key, default)

    def clear(self, plugin_id: str) -> None:
        
        self._plugin_store(plugin_id).clear()

    def get_all(self, plugin_id: str) -> Dict[str, Any]:
        
        return self._plugin_store(plugin_id).get_all()

    def contains(self, plugin_id: str, key: str) -> bool:
        
        return self._plugin_store(plugin_id).contains(key)

    def _account_store(self, plugin_id: str, account: int) -> _JsonStore:
        with self._lock:
            if plugin_id not in self._account_stores:
                self._account_stores[plugin_id] = {}
            if account not in self._account_stores[plugin_id]:
                self._account_stores[plugin_id][account] = _make_store(
                    f"plugins/{plugin_id}/accounts/{account}.json"
                )
            return self._account_stores[plugin_id][account]

    def account_get(
        self, plugin_id: str, account: int, key: str, default: Any = None
    ) -> Any:
        
        return self._account_store(plugin_id, account).get(key, default)

    def account_set(
        self, plugin_id: str, account: int, key: str, value: Any
    ) -> None:
        
        self._account_store(plugin_id, account).set(key, value)

    def account_pop(
        self, plugin_id: str, account: int, key: str, default: Any = None
    ) -> Any:
        
        return self._account_store(plugin_id, account).pop(key, default)

    def account_clear(self, plugin_id: str, account: int) -> None:
        
        self._account_store(plugin_id, account).clear()

    def account_get_all(self, plugin_id: str, account: int) -> Dict[str, Any]:
        
        return self._account_store(plugin_id, account).get_all()

    def _chat_store(self, plugin_id: str, dialog_id: int) -> _JsonStore:
        with self._lock:
            if plugin_id not in self._chat_stores:
                self._chat_stores[plugin_id] = {}
            if dialog_id not in self._chat_stores[plugin_id]:
                self._chat_stores[plugin_id][dialog_id] = _make_store(
                    f"plugins/{plugin_id}/chats/{dialog_id}.json"
                )
            return self._chat_stores[plugin_id][dialog_id]

    def chat_get(
        self, plugin_id: str, dialog_id: int, key: str, default: Any = None
    ) -> Any:
        
        return self._chat_store(plugin_id, dialog_id).get(key, default)

    def chat_set(
        self, plugin_id: str, dialog_id: int, key: str, value: Any
    ) -> None:
        
        self._chat_store(plugin_id, dialog_id).set(key, value)

    def chat_pop(
        self, plugin_id: str, dialog_id: int, key: str, default: Any = None
    ) -> Any:
        
        return self._chat_store(plugin_id, dialog_id).pop(key, default)

    def chat_clear(self, plugin_id: str, dialog_id: int) -> None:
        
        self._chat_store(plugin_id, dialog_id).clear()

    def chat_get_all(self, plugin_id: str, dialog_id: int) -> Dict[str, Any]:
        
        return self._chat_store(plugin_id, dialog_id).get_all()

    def flush(self, plugin_id: str) -> None:
        
        if plugin_id in self._plugin_stores:
            self._plugin_stores[plugin_id].flush_sync()
        if plugin_id in self._account_stores:
            for store in self._account_stores[plugin_id].values():
                store.flush_sync()
        if plugin_id in self._chat_stores:
            for store in self._chat_stores[plugin_id].values():
                store.flush_sync()

    def export_plugin_data(self, plugin_id: str) -> Dict[str, Any]:
        
        return {
            "plugin": self.get_all(plugin_id),
            "accounts": {
                str(acc): store.get_all()
                for acc, store in self._account_stores.get(plugin_id, {}).items()
            },
            "chats": {
                str(cid): store.get_all()
                for cid, store in self._chat_stores.get(plugin_id, {}).items()
            },
        }

    def import_plugin_data(
        self, plugin_id: str, data: Dict[str, Any], merge: bool = False
    ) -> None:
        
        if not merge:
            self.clear(plugin_id)
        plugin_data = data.get("plugin", {})
        self._plugin_store(plugin_id).update(plugin_data)

        for acc_str, acc_data in data.get("accounts", {}).items():
            try:
                acc = int(acc_str)
            except ValueError:
                continue
            if not merge:
                self.account_clear(plugin_id, acc)
            self._account_store(plugin_id, acc).update(acc_data)

        for cid_str, chat_data in data.get("chats", {}).items():
            try:
                cid = int(cid_str)
            except ValueError:
                continue
            if not merge:
                self.chat_clear(plugin_id, cid)
            self._chat_store(plugin_id, cid).update(chat_data)

_register_module(
    "Storage",
    SDK_VERSION,
    "JSON-хранилище: plugin / per-account / per-chat с экспортом/импортом",
)

# ===========================================================================
# MODULE: _hook
# ===========================================================================

from enum import Enum

class HookType(Enum):
    
    BEFORE  = "before"    # Вызывается ДО оригинального метода
    AFTER   = "after"     # Вызывается ПОСЛЕ оригинального метода
    REPLACE = "replace"   # Полностью заменяет оригинальный метод

class HookHandle:
    

    def __init__(
        self,
        plugin_id: str,
        hook_type: HookType,
        class_path: str,
        method_name: str,
        raw_handle: Any,
    ):
        self.plugin_id   = plugin_id
        self.hook_type   = hook_type
        self.class_path  = class_path
        self.method_name = method_name
        self._raw        = raw_handle
        self.active      = True

    def __repr__(self) -> str:
        return (
            f"<HookHandle {self.hook_type.value} "
            f"{self.class_path}.{self.method_name} "
            f"plugin={self.plugin_id} active={self.active}>"
        )

class FieldProxy:
    

    def __init__(self, obj: Any, field_name: str):
        
        self._obj   = obj
        self._field = field_name

    def get(self, default: Any = None) -> Any:
        
        try:
            return get_private_field(self._obj, self._field)
        except Exception:
            return default

    def set(self, value: Any) -> bool:
        
        try:
            set_private_field(self._obj, self._field, value)
            return True
        except Exception:
            _log(f"FieldProxy.set failed for '{self._field}': {traceback.format_exc()}")
            return False

class HookCallback:
    

    def before(self, this: Any, args: list) -> Any:
        
        pass

    def after(self, this: Any, args: list, result: Any) -> Any:
        
        pass

    def replace(self, this: Any, args: list) -> Any:
        
        pass

class HookAPI:
    

    def __init__(self, owner: Any):
        
        self._owner     = owner
        self._handles:  Dict[str, List[HookHandle]] = {}
        self._registry: List[HookHandle]            = []
        self._lock      = threading.RLock()

    def method(
        self,
        plugin_id: str,
        class_path: str,
        method_signature_contains: str,
        callback: HookCallback,
        hook_type: HookType = HookType.BEFORE,
        priority: int = 0,
    ) -> Optional[HookHandle]:
        
        try:
            java_method = _find_method(class_path, method_signature_contains)
            raw = self._owner.hook_method(java_method, callback, priority)
            handle = HookHandle(
                plugin_id=plugin_id,
                hook_type=hook_type,
                class_path=class_path,
                method_name=method_signature_contains,
                raw_handle=raw,
            )
            with self._lock:
                self._handles.setdefault(plugin_id, []).append(handle)
                self._registry.append(handle)
            _log(
                f"hooked {class_path}::{method_signature_contains} "
                f"[{hook_type.value}] for {plugin_id}"
            )
            return handle
        except Exception:
            _log(
                f"hook failed for {plugin_id} "
                f"→ {class_path}.{method_signature_contains}: "
                f"{traceback.format_exc()}"
            )
            return None

    def constructor(
        self,
        plugin_id: str,
        class_path: str,
        callback: HookCallback,
        priority: int = 0,
    ) -> Optional[HookHandle]:
        
        try:
            cls = find_class(class_path)
            constructors = cls.getClass().getDeclaredConstructors()
            if not constructors:
                _log(f"constructor: no constructors found in {class_path}")
                return None
            raw = self._owner.hook_method(constructors[0], callback, priority)
            handle = HookHandle(
                plugin_id=plugin_id,
                hook_type=HookType.BEFORE,
                class_path=class_path,
                method_name="<init>",
                raw_handle=raw,
            )
            with self._lock:
                self._handles.setdefault(plugin_id, []).append(handle)
                self._registry.append(handle)
            _log(f"hooked constructor {class_path} for {plugin_id}")
            return handle
        except Exception:
            _log(f"constructor hook failed for {class_path}: {traceback.format_exc()}")
            return None

    def field_get(self, obj: Any, field_name: str) -> Any:
        
        try:
            return get_private_field(obj, field_name)
        except Exception:
            _log(f"field_get '{field_name}' failed: {traceback.format_exc()}")
            return None

    def field_set(self, obj: Any, field_name: str, value: Any) -> bool:
        
        try:
            set_private_field(obj, field_name, value)
            return True
        except Exception:
            _log(f"field_set '{field_name}' failed: {traceback.format_exc()}")
            return False

    def proxy(self, obj: Any, field_name: str) -> FieldProxy:
        
        return FieldProxy(obj, field_name)

    def unhook(self, handle: Optional[HookHandle]) -> bool:
        
        if handle is None or not handle.active:
            return False
        try:
            self._owner.unhook_method(handle._raw)
            handle.active = False
            with self._lock:
                for lst in self._handles.values():
                    if handle in lst:
                        lst.remove(handle)
                if handle in self._registry:
                    self._registry.remove(handle)
            return True
        except Exception:
            _log(f"unhook failed: {traceback.format_exc()}")
            return False

    def unhook_all(self, plugin_id: str) -> int:
        
        with self._lock:
            handles = self._handles.pop(plugin_id, [])
        count = 0
        for handle in handles:
            if not handle.active:
                continue
            try:
                self._owner.unhook_method(handle._raw)
                handle.active = False
                if handle in self._registry:
                    self._registry.remove(handle)
                count += 1
            except Exception:
                _log(f"unhook_all failed for {plugin_id}: {traceback.format_exc()}")
        _log(f"unhook_all: {count} hooks removed for {plugin_id}")
        return count

    def list_hooks(self, plugin_id: Optional[str] = None) -> List[HookHandle]:
        
        with self._lock:
            if plugin_id:
                return [
                    h for h in self._handles.get(plugin_id, []) if h.active
                ]
            return [h for h in self._registry if h.active]

    def count(self, plugin_id: Optional[str] = None) -> int:
        
        return len(self.list_hooks(plugin_id))

def _find_method(class_path: str, signature_contains: str) -> Any:
    
    try:
        cls = find_class(class_path)
        methods = cls.getClass().getDeclaredMethods()
        for m in methods:
            if signature_contains in repr(m):
                return m
        raise LookupError(
            f"Метод не найден: {class_path} / '{signature_contains}' "
            f"(проверялось на APK {VERIFIED_APK})"
        )
    except LookupError:
        raise
    except Exception as e:
        raise LookupError(
            f"Ошибка поиска метода {class_path}.{signature_contains}: {e}"
        )

_register_module(
    "Hook",
    SDK_VERSION,
    "Java-хуки: Method/Constructor/Field, Before/After/Replace, реестр хуков",
)

# ===========================================================================
# MODULE: _network
# ===========================================================================

class RequestInterceptor:
    

    def on_request(self, request: Any, meta: Dict[str, Any]) -> Any:
        
        return request

    def on_response(self, response: Any, meta: Dict[str, Any]) -> Any:
        
        return response

    def on_error(self, error: Any, meta: Dict[str, Any]) -> Optional[Any]:
        
        return None

class NetworkAPI:
    

    def __init__(self):
        self._interceptors: List[RequestInterceptor] = []
        self._lock = threading.RLock()
        self._pending: int = 0

    def request(
        self,
        tl_object: Any,
        on_result: Callable[[Any, Any], None],
        retry: int = 0,
        timeout_ms: int = 0,
    ) -> None:
        
        meta = {"type": "tl", "class": type(tl_object).__name__}
        tl_object = self._apply_request_interceptors(tl_object, meta)

        def _cb(response, error):
            if error and retry > 0:
                _log(f"network retry [{retry}] for {meta['class']}: {error}")
                threading.Timer(
                    1.0,
                    lambda: self.request(tl_object, on_result, retry - 1, timeout_ms),
                ).start()
                return

            resp = self._apply_response_interceptors(response, meta)
            err  = self._apply_error_interceptors(error, meta)
            run_on_ui_thread(lambda: _safe_call(on_result, resp, err))

        with self._lock:
            self._pending += 1

        try:
            send_request(tl_object, _cb)
        finally:
            with self._lock:
                self._pending -= 1

    def new_tl(self, class_name: str) -> Any:
        
        cls = getattr(TLRPC, class_name)
        return cls()

    def get(
        self,
        url: str,
        headers: Optional[Dict[str, str]] = None,
        on_result: Optional[Callable[[Optional[Dict], Optional[str]], None]] = None,
        timeout_ms: int = 10000,
        retry: int = 2,
    ) -> None:
        
        threading.Thread(
            target=self._do_http_request,
            args=("GET", url, None, headers or {}, on_result, timeout_ms, retry),
            daemon=True,
        ).start()

    def post(
        self,
        url: str,
        body: Optional[Any] = None,
        headers: Optional[Dict[str, str]] = None,
        on_result: Optional[Callable[[Optional[Dict], Optional[str]], None]] = None,
        timeout_ms: int = 10000,
        retry: int = 1,
    ) -> None:
        
        threading.Thread(
            target=self._do_http_request,
            args=("POST", url, body, headers or {}, on_result, timeout_ms, retry),
            daemon=True,
        ).start()

    def _do_http_request(
        self,
        method: str,
        url: str,
        body: Any,
        headers: Dict[str, str],
        on_result: Optional[Callable],
        timeout_ms: int,
        retry: int,
    ) -> None:
        
        meta = {"type": "http", "method": method, "url": url}
        last_error = None

        for attempt in range(max(1, retry + 1)):
            try:
                from java.net import URL, HttpURLConnection
                from java.io import BufferedReader, InputStreamReader, DataOutputStream
                import java.lang.StringBuilder as JStringBuilder

                conn = URL(url).openConnection()
                conn.setRequestMethod(method)
                conn.setConnectTimeout(timeout_ms)
                conn.setReadTimeout(timeout_ms)
                conn.setRequestProperty("User-Agent", "ExsteraLib/2.0")
                conn.setRequestProperty("Accept", "application/json")

                for k, v in headers.items():
                    conn.setRequestProperty(k, v)

                if method == "POST" and body is not None:
                    conn.setDoOutput(True)
                    if isinstance(body, dict):
                        body_str = json.dumps(body, ensure_ascii=False)
                        conn.setRequestProperty("Content-Type", "application/json")
                    else:
                        body_str = str(body)
                    body_bytes = body_str.encode("utf-8")
                    os_stream = conn.getOutputStream()
                    dos = DataOutputStream(os_stream)
                    dos.write(body_bytes)
                    dos.flush()
                    dos.close()

                code = conn.getResponseCode()
                is_error = code >= 400

                stream = conn.getErrorStream() if is_error else conn.getInputStream()
                reader = BufferedReader(InputStreamReader(stream, "UTF-8"))
                sb = JStringBuilder()
                line = reader.readLine()
                while line is not None:
                    sb.append(line)
                    line = reader.readLine()
                reader.close()
                conn.disconnect()

                raw = str(sb.toString())

                if is_error:
                    if attempt < retry:
                        time.sleep(1.5 ** attempt)
                        continue
                    if on_result:
                        run_on_ui_thread(
                            lambda: _safe_call(on_result, None, f"HTTP {code}: {raw}")
                        )
                    return

                try:
                    data = json.loads(raw)
                except Exception:
                    data = raw

                data = self._apply_response_interceptors(data, meta)
                if on_result:
                    run_on_ui_thread(lambda d=data: _safe_call(on_result, d, None))
                return

            except Exception as e:
                last_error = str(e)
                if attempt < retry:
                    time.sleep(1.0)
                    continue

        if on_result:
            run_on_ui_thread(
                lambda: _safe_call(on_result, None, last_error or "Unknown error")
            )

    def add_interceptor(self, interceptor: RequestInterceptor) -> None:
        
        with self._lock:
            self._interceptors.append(interceptor)

    def remove_interceptor(self, interceptor: RequestInterceptor) -> None:
        
        with self._lock:
            if interceptor in self._interceptors:
                self._interceptors.remove(interceptor)

    def _apply_request_interceptors(self, req: Any, meta: Dict) -> Any:
        with self._lock:
            interceptors = list(self._interceptors)
        for ic in interceptors:
            try:
                req = ic.on_request(req, meta) or req
            except Exception:
                _log(f"interceptor.on_request error: {traceback.format_exc()}")
        return req

    def _apply_response_interceptors(self, resp: Any, meta: Dict) -> Any:
        with self._lock:
            interceptors = list(self._interceptors)
        for ic in interceptors:
            try:
                result = ic.on_response(resp, meta)
                if result is not None:
                    resp = result
            except Exception:
                _log(f"interceptor.on_response error: {traceback.format_exc()}")
        return resp

    def _apply_error_interceptors(self, error: Any, meta: Dict) -> Any:
        if error is None:
            return None
        with self._lock:
            interceptors = list(self._interceptors)
        for ic in interceptors:
            try:
                override = ic.on_error(error, meta)
                if override is not None:
                    return override
            except Exception:
                _log(f"interceptor.on_error error: {traceback.format_exc()}")
        return error

    def pending_count(self) -> int:
        
        return self._pending

    def check_connection(self, on_result: Callable[[bool], None]) -> None:
        
        def _check():
            try:
                from java.net import URL
                conn = URL("https://www.google.com").openConnection()
                conn.setConnectTimeout(3000)
                conn.connect()
                conn.disconnect()
                run_on_ui_thread(lambda: _safe_call(on_result, True))
            except Exception:
                run_on_ui_thread(lambda: _safe_call(on_result, False))

        threading.Thread(target=_check, daemon=True).start()

_register_module(
    "Network",
    SDK_VERSION,
    "Сеть: TL-запросы/HTTP GET-POST/retry/timeout/перехватчики",
)

# ===========================================================================
# MODULE: _theme
# ===========================================================================

THEME_KEYS: Dict[str, str] = {
    "bubble_in":          "key_chat_inBubble",
    "bubble_out":         "key_chat_outBubble",
    "bubble_in_selected": "key_chat_inBubbleSelected",
    "bubble_out_selected":"key_chat_outBubbleSelected",
    "bubble_shadow":      "key_chat_inBubbleShadow",
    "text_in":            "key_chat_inTimeText",
    "text_out":           "key_chat_outTimeText",
    "text_message_in":    "key_chat_messageTextIn",
    "text_message_out":   "key_chat_messageTextOut",
    "wallpaper":          "key_chat_wallpaper",
    "service_bg":         "key_chat_serviceBackground",
    "window_bg":          "key_windowBackgroundWhite",
    "window_bg_gray":     "key_windowBackgroundGray",
    "window_bg_gray_text":"key_windowBackgroundGrayShadow",
    "actionbar_bg":       "key_actionBarDefault",
    "actionbar_title":    "key_actionBarDefaultTitle",
    "actionbar_subtitle": "key_actionBarDefaultSubtitle",
    "actionbar_icon":     "key_actionBarDefaultIcon",
    "actionbar_menu":     "key_actionBarDefaultMenu",
    "actionbar_selector": "key_actionBarDefaultSelector",
    "chat_name":          "key_chats_name",
    "chat_message":       "key_chats_message",
    "chat_date":          "key_chats_date",
    "chat_unread":        "key_chats_unreadCounter",
    "chat_unread_text":   "key_chats_unreadCounterText",
    "chat_muted":         "key_chats_unreadCounterMuted",
    "chat_verified":      "key_chats_verifiedBackground",
    "chat_online":        "key_chats_onlineDot",
    "input_bg":           "key_chat_messagePanelBackground",
    "input_text":         "key_chat_messagePanelText",
    "input_hint":         "key_chat_messagePanelHint",
    "input_send":         "key_chat_messagePanelSend",
    "input_icons":        "key_chat_messagePanelIcons",
    "avatar_bg":          "key_avatar_backgroundBlue",
    "avatar_text":        "key_avatar_text",
    "profile_title":      "key_profile_title",
    "profile_status":     "key_profile_status",
    "divider":            "key_divider",
    "divider_shadow":     "key_divider_shadow",
    "button_bg":          "key_featuredStickers_addButton",
    "button_text":        "key_featuredStickers_addButtonText",
    "reaction_bg":        "key_chat_inReactionButtonBackground",
    "reaction_text":      "key_chat_inReactionButtonText",
    "media_player":       "key_player_actionBarTitle",
    "media_progress":     "key_player_progress",
    "accent":             "key_switchTrackChecked",
    "link":               "key_chat_messageLinkIn",
    "link_out":           "key_chat_messageLinkOut",
    "mention":            "key_chat_messageMentionIn",
}

class ThemeAPI:
    

    def color(self, key: str) -> int:
        
        full_key = THEME_KEYS.get(key)
        if full_key is None:
            raise KeyError(
                f"ThemeAPI: неизвестный ключ '{key}'. "
                f"Доступные ключи: {list(THEME_KEYS.keys())}"
            )
        return self.raw_color(full_key)

    def raw_color(self, theme_key_name: str) -> int:
        
        try:
            key = getattr(Theme, theme_key_name)
        except AttributeError:
            raise AttributeError(
                f"Theme.{theme_key_name} не найден — "
                f"поле могло измениться в этой версии клиента"
            )
        return int(Theme.getColor(key))

    def bubble_color(self, direction: str = "out") -> int:
        
        if direction == "in":
            return self.color("bubble_in")
        return self.color("bubble_out")

    def get_accent_color(self) -> int:
        
        return self.color("accent")

    def get_background_color(self) -> int:
        
        return self.color("window_bg")

    def get_actionbar_color(self) -> int:
        
        return self.color("actionbar_bg")

    def get_text_color(self) -> int:
        
        return self.color("actionbar_title")

    def get_all_keys(self) -> List[str]:
        
        return list(THEME_KEYS.keys())

    def get_all_raw_keys(self) -> Dict[str, str]:
        
        return dict(THEME_KEYS)

    def is_dark(self) -> bool:
        
        return bool(Theme.isCurrentThemeDark())

    def is_amoled(self) -> bool:
        
        bg = self.get_background_color()
        r = (bg >> 16) & 0xFF
        g = (bg >> 8)  & 0xFF
        b = bg         & 0xFF
        luminance = 0.299 * r + 0.587 * g + 0.114 * b
        return luminance < 20

    def current_theme_name(self) -> Optional[str]:
        
        info = Theme.getActiveTheme()
        if not info:
            return None
        try:
            return str(info.name)
        except Exception:
            return None

    def on_changed(self, plugin_id: str, cb) -> None:
        
        _events.on("theme_changed", plugin_id, cb)

    def dp_to_px(self, dp: float) -> int:
        
        try:
            ctx = ApplicationLoader.applicationContext
            density = ctx.getResources().getDisplayMetrics().density
            return int(dp * density + 0.5)
        except Exception:
            return int(dp * 3)  # fallback xxhdpi

    def sp_to_px(self, sp: float) -> int:
        
        try:
            ctx = ApplicationLoader.applicationContext
            scaled_density = ctx.getResources().getDisplayMetrics().scaledDensity
            return int(sp * scaled_density + 0.5)
        except Exception:
            return int(sp * 3)

    def get_corner_radius_dp(self) -> float:
        
        try:
            from org.telegram.messenger import SharedConfig
            return float(SharedConfig.bubbleRadius)
        except Exception:
            return 17.0

    def create_color_state_list(self, normal: int, pressed: int) -> Any:
        
        try:
            from android.content.res import ColorStateList
            states = [[16842919], []]  # android.R.attr.state_pressed, empty
            colors = [pressed, normal]
            return ColorStateList(states, colors)
        except Exception as e:
            _log(f"create_color_state_list error: {e}")
            return None

    def get_ripple_drawable(self, color: int, corner_dp: int = 0) -> Any:
        
        try:
            from android.graphics.drawable import RippleDrawable, ColorDrawable, GradientDrawable
            from android.content.res import ColorStateList

            mask: Any
            if corner_dp > 0:
                mask = GradientDrawable()
                mask.setShape(GradientDrawable.RECTANGLE)
                mask.setCornerRadius(self.dp_to_px(corner_dp))
                mask.setColor(0xFFFFFFFF)
            else:
                mask = ColorDrawable(0xFFFFFFFF)

            csl = ColorStateList([[]], [color])
            return RippleDrawable(csl, None, mask)
        except Exception as e:
            _log(f"get_ripple_drawable error: {e}")
            return None

    def apply_color_filter(self, drawable: Any, color: int) -> Any:
        
        try:
            from android.graphics import PorterDuff, PorterDuffColorFilter
            drawable.setColorFilter(PorterDuffColorFilter(color, PorterDuff.Mode.SRC_IN))
            return drawable
        except Exception as e:
            _log(f"apply_color_filter error: {e}")
            return drawable

_register_module(
    "Theme",
    SDK_VERSION,
    "Цвета/drawable/ripple темы Telegram, AMOLED, dp/sp конвертация",
)

# ===========================================================================
# MODULE: _chat
# ===========================================================================

from dataclasses import dataclass, field
from enum import Enum

from org.telegram.messenger import MessagesController, UserConfig

class ChatType(Enum):
    
    UNKNOWN  = "unknown"
    USER     = "user"
    GROUP    = "group"
    SUPERGROUP = "supergroup"
    CHANNEL  = "channel"
    BOT      = "bot"
    FORUM    = "forum"

@dataclass
class ChatInfo:
    
    dialog_id:   int
    title:       str
    chat_type:   ChatType
    is_verified: bool = False
    is_scam:     bool = False
    is_premium:  bool = False
    unread_count: int = 0
    members_count: int = 0
    description: str  = ""
    username:    str  = ""
    pinned_msg_id: int = 0

@dataclass
class MemberInfo:
    
    user_id:    int
    first_name: str
    last_name:  str = ""
    username:   str = ""
    is_admin:   bool = False
    is_owner:   bool = False
    is_bot:     bool = False
    is_premium: bool = False

class ChatAPI:
    

    def current_dialog_id(self) -> Optional[int]:
        
        frag = get_last_fragment()
        if not frag:
            return None
        try:
            return int(get_private_field(frag, "dialog_id"))
        except Exception:
            return None

    def current_fragment(self) -> Any:
        
        return get_last_fragment()

    def messages_controller(self) -> Any:
        
        return get_messages_controller()

    def account(self) -> int:
        
        return get_account_instance()

    def user_config(self) -> Any:
        
        return get_user_config()

    def is_open(self) -> bool:
        
        return self.current_dialog_id() is not None

    def get_all_dialogs(self) -> List[Any]:
        
        mc = get_messages_controller()
        if not mc:
            return []
        try:
            dialogs = mc.getAllDialogs()
            return list(dialogs) if dialogs else []
        except Exception:
            return []

    def get_channels(self) -> List[Any]:
        
        result = []
        for d in self.get_all_dialogs():
            try:
                peer_id = d.id if hasattr(d, "id") else 0
                if peer_id < 0:
                    chat = self._get_chat_obj(-peer_id)
                    if chat and getattr(chat, "broadcast", False) and not getattr(chat, "forum", False):
                        result.append(d)
            except Exception:
                pass
        return result

    def get_groups(self) -> List[Any]:
        
        result = []
        for d in self.get_all_dialogs():
            try:
                peer_id = d.id if hasattr(d, "id") else 0
                if peer_id < 0:
                    chat = self._get_chat_obj(-peer_id)
                    if chat and not getattr(chat, "broadcast", False) and not getattr(chat, "forum", False):
                        result.append(d)
            except Exception:
                pass
        return result

    def get_bots(self) -> List[Any]:
        
        result = []
        for d in self.get_all_dialogs():
            try:
                peer_id = d.id if hasattr(d, "id") else 0
                if peer_id > 0:
                    user = self._get_user_obj(peer_id)
                    if user and getattr(user, "bot", False):
                        result.append(d)
            except Exception:
                pass
        return result

    def get_forums(self) -> List[Any]:
        
        result = []
        for d in self.get_all_dialogs():
            try:
                peer_id = d.id if hasattr(d, "id") else 0
                if peer_id < 0:
                    chat = self._get_chat_obj(-peer_id)
                    if chat and getattr(chat, "forum", False):
                        result.append(d)
            except Exception:
                pass
        return result

    def get_archived(self) -> List[Any]:
        
        mc = get_messages_controller()
        if not mc:
            return []
        try:
            archived = mc.getArchivedDialogs()
            return list(archived) if archived else []
        except Exception:
            return []

    def search(self, query: str, limit: int = 20) -> List[Any]:
        
        query_lower = query.lower()
        results = []
        for d in self.get_all_dialogs():
            try:
                title = self._get_dialog_title(d).lower()
                if query_lower in title:
                    results.append(d)
                    if len(results) >= limit:
                        break
            except Exception:
                pass
        return results

    def get_topics(self, dialog_id: int) -> List[Any]:
        
        mc = get_messages_controller()
        if not mc:
            return []
        try:
            topics = mc.getTopics(-dialog_id if dialog_id > 0 else dialog_id)
            return list(topics) if topics else []
        except Exception:
            return []

    def get_folders(self) -> List[Any]:
        
        mc = get_messages_controller()
        if not mc:
            return []
        try:
            filters = mc.getDialogFilters()
            return list(filters) if filters else []
        except Exception:
            return []

    def create_folder(
        self,
        name: str,
        include_dialogs: Optional[List[int]] = None,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_updateDialogFilter()
        req.filter = TLRPC.TL_dialogFilter()
        req.filter.title = name
        req.filter.id = self._next_filter_id()
        req.filter.flags |= 2  # has_rules
        if include_dialogs:
            for did in include_dialogs:
                peer = self._dialog_id_to_input_peer(did)
                if peer:
                    req.filter.include_peers.add(peer)

        def _on_result(response, error):
            if on_done:
                _safe_call(on_done, error is None)

        send_request(req, _on_result)

    def delete_folder(
        self,
        folder_id: int,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_updateDialogFilter()
        req.id = folder_id

        def _on_result(response, error):
            if on_done:
                _safe_call(on_done, error is None)

        send_request(req, _on_result)

    def pin(
        self,
        dialog_id: int,
        pinned: bool = True,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_toggleDialogPin()
        req.peer = self._dialog_id_to_input_dialog_peer(dialog_id)
        req.pinned = pinned

        def _on_result(response, error):
            if on_done:
                _safe_call(on_done, error is None)

        send_request(req, _on_result)

    def archive(
        self,
        dialog_ids: List[int],
        folder_id: int = 1,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_folders_editPeerFolders()
        for did in dialog_ids:
            fp = TLRPC.TL_inputFolderPeer()
            fp.peer = self._dialog_id_to_input_peer(did)
            fp.folder_id = folder_id
            req.folder_peers.add(fp)

        def _on_result(response, error):
            if on_done:
                _safe_call(on_done, error is None)

        send_request(req, _on_result)

    def delete(
        self,
        dialog_id: int,
        also_for_everyone: bool = False,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        mc = get_messages_controller()
        if not mc:
            if on_done:
                on_done(False)
            return
        try:
            if dialog_id > 0:
                req = TLRPC.TL_messages_deleteHistory()
                req.peer = self._dialog_id_to_input_peer(dialog_id)
                req.just_clear = False
                req.revoke = also_for_everyone
                req.max_id = 0

                def _on_result(response, error):
                    if on_done:
                        _safe_call(on_done, error is None)

                send_request(req, _on_result)
            else:
                chat = self._get_chat_obj(-dialog_id)
                if chat and getattr(chat, "megagroup", False):
                    req = TLRPC.TL_channels_leaveChannel()
                    req.channel = self._chat_to_input_channel(chat)
                else:
                    req = TLRPC.TL_messages_deleteChatUser()
                    req.chat_id = -dialog_id
                    req.user_id = self._self_input_user()

                def _on_result(response, error):
                    if on_done:
                        _safe_call(on_done, error is None)

                send_request(req, _on_result)
        except Exception as e:
            _log(f"chat.delete error: {e}")
            if on_done:
                on_done(False)

    def clear_history(
        self,
        dialog_id: int,
        revoke: bool = False,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_deleteHistory()
        req.peer = self._dialog_id_to_input_peer(dialog_id)
        req.just_clear = True
        req.revoke = revoke
        req.max_id = 0

        def _on_result(response, error):
            if on_done:
                _safe_call(on_done, error is None)

        send_request(req, _on_result)

    def mark_as_read(
        self,
        dialog_id: int,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        mc = get_messages_controller()
        if not mc:
            if on_done:
                on_done(False)
            return
        try:
            mc.readAllDialogMentions(dialog_id)
            if on_done:
                on_done(True)
        except Exception:
            if on_done:
                on_done(False)

    def get_members(
        self,
        dialog_id: int,
        limit: int = 200,
        on_result: Optional[Callable[[List[MemberInfo]], None]] = None,
    ) -> None:
        
        if dialog_id >= 0:
            if on_result:
                on_result([])
            return

        chat = self._get_chat_obj(-dialog_id)
        if chat and getattr(chat, "megagroup", False) or getattr(chat, "broadcast", False):
            req = TLRPC.TL_channels_getParticipants()
            req.channel = self._chat_to_input_channel(chat)
            req.filter = TLRPC.TL_channelParticipantsRecent()
            req.offset = 0
            req.limit = limit
            req.hash = 0

            def _on_result(response, error):
                members = []
                if response and hasattr(response, "participants"):
                    for p in response.participants:
                        user = self._get_user_obj_from_response(response, p.user_id)
                        info = MemberInfo(
                            user_id=p.user_id,
                            first_name=getattr(user, "first_name", "") or "",
                            last_name=getattr(user, "last_name", "") or "",
                            username=getattr(user, "username", "") or "",
                            is_admin=isinstance(p, (
                                TLRPC.TL_channelParticipantAdmin,
                                TLRPC.TL_channelParticipantCreator,
                            )),
                            is_owner=isinstance(p, TLRPC.TL_channelParticipantCreator),
                            is_bot=getattr(user, "bot", False),
                            is_premium=getattr(user, "premium", False),
                        )
                        members.append(info)
                if on_result:
                    run_on_ui_thread(lambda: _safe_call(on_result, members))

            send_request(req, _on_result)
        else:
            req = TLRPC.TL_messages_getFullChat()
            req.chat_id = -dialog_id

            def _on_full(response, error):
                members = []
                if response and hasattr(response, "full_chat"):
                    fc = response.full_chat
                    if hasattr(fc, "participants") and hasattr(fc.participants, "participants"):
                        for p in fc.participants.participants:
                            user = self._get_user_from_list(response.users, p.user_id)
                            info = MemberInfo(
                                user_id=p.user_id,
                                first_name=getattr(user, "first_name", "") or "",
                                last_name=getattr(user, "last_name", "") or "",
                                username=getattr(user, "username", "") or "",
                                is_admin=isinstance(p, TLRPC.TL_chatParticipantAdmin),
                                is_owner=isinstance(p, TLRPC.TL_chatParticipantCreator),
                                is_bot=getattr(user, "bot", False),
                            )
                            members.append(info)
                if on_result:
                    run_on_ui_thread(lambda: _safe_call(on_result, members))

            send_request(req, _on_full)

    def get_admins(
        self,
        dialog_id: int,
        on_result: Optional[Callable[[List[MemberInfo]], None]] = None,
    ) -> None:
        
        if dialog_id >= 0:
            if on_result:
                on_result([])
            return

        chat = self._get_chat_obj(-dialog_id)
        if not (getattr(chat, "megagroup", False) or getattr(chat, "broadcast", False)):
            if on_result:
                on_result([])
            return

        req = TLRPC.TL_channels_getParticipants()
        req.channel = self._chat_to_input_channel(chat)
        req.filter = TLRPC.TL_channelParticipantsAdmins()
        req.offset = 0
        req.limit = 200
        req.hash = 0

        def _on_result(response, error):
            members = []
            if response and hasattr(response, "participants"):
                for p in response.participants:
                    user = self._get_user_obj_from_response(response, p.user_id)
                    info = MemberInfo(
                        user_id=p.user_id,
                        first_name=getattr(user, "first_name", "") or "",
                        last_name=getattr(user, "last_name", "") or "",
                        username=getattr(user, "username", "") or "",
                        is_admin=True,
                        is_owner=isinstance(p, TLRPC.TL_channelParticipantCreator),
                        is_bot=getattr(user, "bot", False),
                        is_premium=getattr(user, "premium", False),
                    )
                    members.append(info)
            if on_result:
                run_on_ui_thread(lambda: _safe_call(on_result, members))

        send_request(req, _on_result)

    def get_owner(
        self,
        dialog_id: int,
        on_result: Optional[Callable[[Optional[MemberInfo]], None]] = None,
    ) -> None:
        
        if dialog_id >= 0:
            if on_result:
                on_result(None)
            return

        chat = self._get_chat_obj(-dialog_id)
        req = TLRPC.TL_channels_getParticipants()
        req.channel = self._chat_to_input_channel(chat)
        req.filter = TLRPC.TL_channelParticipantsAdmins()
        req.offset = 0
        req.limit = 200
        req.hash = 0

        def _on_result(response, error):
            owner = None
            if response and hasattr(response, "participants"):
                for p in response.participants:
                    if isinstance(p, TLRPC.TL_channelParticipantCreator):
                        user = self._get_user_obj_from_response(response, p.user_id)
                        owner = MemberInfo(
                            user_id=p.user_id,
                            first_name=getattr(user, "first_name", "") or "",
                            last_name=getattr(user, "last_name", "") or "",
                            username=getattr(user, "username", "") or "",
                            is_admin=True,
                            is_owner=True,
                        )
                        break
            if on_result:
                run_on_ui_thread(lambda: _safe_call(on_result, owner))

        send_request(req, _on_result)

    def get_info(
        self,
        dialog_id: int,
        on_result: Optional[Callable[[Optional[ChatInfo]], None]] = None,
    ) -> None:
        
        if dialog_id > 0:
            req = TLRPC.TL_users_getFullUser()
            req.id = self._user_id_to_input_user(dialog_id)

            def _on_user(response, error):
                info = None
                if response and hasattr(response, "full_user"):
                    user = self._get_user_obj(dialog_id)
                    fu = response.full_user
                    info = ChatInfo(
                        dialog_id=dialog_id,
                        title=(getattr(user, "first_name", "") or "") + " " + (getattr(user, "last_name", "") or ""),
                        chat_type=ChatType.BOT if getattr(user, "bot", False) else ChatType.USER,
                        is_verified=getattr(user, "verified", False),
                        is_scam=getattr(user, "scam", False),
                        is_premium=getattr(user, "premium", False),
                        username=getattr(user, "username", "") or "",
                        description=getattr(fu, "about", "") or "",
                    )
                if on_result:
                    run_on_ui_thread(lambda: _safe_call(on_result, info))

            send_request(req, _on_user)
        else:
            chat = self._get_chat_obj(-dialog_id)
            if chat and (getattr(chat, "megagroup", False) or getattr(chat, "broadcast", False)):
                req = TLRPC.TL_channels_getFullChannel()
                req.channel = self._chat_to_input_channel(chat)

                def _on_channel(response, error):
                    info = None
                    if response and hasattr(response, "full_chat"):
                        fc = response.full_chat
                        c  = chat
                        is_forum   = getattr(c, "forum", False)
                        is_channel = getattr(c, "broadcast", False)
                        info = ChatInfo(
                            dialog_id=dialog_id,
                            title=getattr(c, "title", "") or "",
                            chat_type=(
                                ChatType.FORUM if is_forum
                                else ChatType.CHANNEL if is_channel
                                else ChatType.SUPERGROUP
                            ),
                            is_verified=getattr(c, "verified", False),
                            is_scam=getattr(c, "scam", False),
                            members_count=getattr(fc, "participants_count", 0),
                            description=getattr(fc, "about", "") or "",
                            username=getattr(c, "username", "") or "",
                        )
                    if on_result:
                        run_on_ui_thread(lambda: _safe_call(on_result, info))

                send_request(req, _on_channel)
            else:
                req = TLRPC.TL_messages_getFullChat()
                req.chat_id = -dialog_id

                def _on_full(response, error):
                    info = None
                    if response and hasattr(response, "full_chat"):
                        c  = self._get_chat_obj(-dialog_id)
                        fc = response.full_chat
                        parts = getattr(getattr(fc, "participants", None), "participants", [])
                        info = ChatInfo(
                            dialog_id=dialog_id,
                            title=getattr(c, "title", "") or "",
                            chat_type=ChatType.GROUP,
                            members_count=len(parts) if parts else 0,
                            description=getattr(fc, "about", "") or "",
                        )
                    if on_result:
                        run_on_ui_thread(lambda: _safe_call(on_result, info))

                send_request(req, _on_full)

    def get_unread_count(self, dialog_id: int) -> int:
        
        mc = get_messages_controller()
        if not mc:
            return 0
        try:
            dialogs = mc.getAllDialogs()
            for d in dialogs:
                if d.id == dialog_id:
                    return getattr(d, "unread_count", 0)
            return 0
        except Exception:
            return 0

    def get_total_unread_count(self) -> int:
        
        total = 0
        for d in self.get_all_dialogs():
            try:
                total += getattr(d, "unread_count", 0)
            except Exception:
                pass
        return total

    def open_chat(self, dialog_id: int) -> None:
        
        from org.telegram.messenger import AndroidUtilities

        def _open():
            try:
                mc = get_messages_controller()
                frag = get_last_fragment()
                if frag and hasattr(frag, "presentFragment"):
                    from org.telegram.ui import ChatActivity
                    args = AndroidUtilities.createBundleForChat(dialog_id, 0)
                    frag.presentFragment(ChatActivity(args))
            except Exception as e:
                _log(f"open_chat error: {e}")

        ui(_open)

    def close_chat(self) -> None:
        
        run_on_ui_thread(lambda: self._do_close_chat())

    def _do_close_chat(self) -> None:
        frag = get_last_fragment()
        if frag and hasattr(frag, "finishFragment"):
            try:
                frag.finishFragment()
            except Exception as e:
                _log(f"close_chat error: {e}")

    def _get_chat_obj(self, chat_id: int) -> Any:
        mc = get_messages_controller()
        if not mc:
            return None
        try:
            return mc.getChat(chat_id)
        except Exception:
            return None

    def _get_user_obj(self, user_id: int) -> Any:
        mc = get_messages_controller()
        if not mc:
            return None
        try:
            return mc.getUser(user_id)
        except Exception:
            return None

    def _get_user_obj_from_response(self, response: Any, user_id: int) -> Any:
        try:
            for u in response.users:
                if u.id == user_id:
                    return u
        except Exception:
            pass
        return self._get_user_obj(user_id)

    def _get_user_from_list(self, users: Any, user_id: int) -> Any:
        try:
            for u in users:
                if u.id == user_id:
                    return u
        except Exception:
            pass
        return None

    def _get_dialog_title(self, dialog: Any) -> str:
        try:
            peer_id = dialog.id
            if peer_id > 0:
                user = self._get_user_obj(peer_id)
                if user:
                    return f"{getattr(user, 'first_name', '')} {getattr(user, 'last_name', '')}".strip()
            else:
                chat = self._get_chat_obj(-peer_id)
                if chat:
                    return getattr(chat, "title", "") or ""
        except Exception:
            pass
        return ""

    def _dialog_id_to_input_peer(self, dialog_id: int) -> Any:
        if dialog_id > 0:
            user = self._get_user_obj(dialog_id)
            if user:
                peer = TLRPC.TL_inputPeerUser()
                peer.user_id = dialog_id
                peer.access_hash = getattr(user, "access_hash", 0)
                return peer
        else:
            chat = self._get_chat_obj(-dialog_id)
            if chat:
                if getattr(chat, "megagroup", False) or getattr(chat, "broadcast", False):
                    peer = TLRPC.TL_inputPeerChannel()
                    peer.channel_id = -dialog_id
                    peer.access_hash = getattr(chat, "access_hash", 0)
                    return peer
                else:
                    peer = TLRPC.TL_inputPeerChat()
                    peer.chat_id = -dialog_id
                    return peer
        return TLRPC.TL_inputPeerEmpty()

    def _dialog_id_to_input_dialog_peer(self, dialog_id: int) -> Any:
        peer = TLRPC.TL_inputDialogPeer()
        peer.peer = self._dialog_id_to_input_peer(dialog_id)
        return peer

    def _chat_to_input_channel(self, chat: Any) -> Any:
        ch = TLRPC.TL_inputChannel()
        ch.channel_id = chat.id
        ch.access_hash = getattr(chat, "access_hash", 0)
        return ch

    def _user_id_to_input_user(self, user_id: int) -> Any:
        user = self._get_user_obj(user_id)
        iu = TLRPC.TL_inputUser()
        iu.user_id = user_id
        iu.access_hash = getattr(user, "access_hash", 0) if user else 0
        return iu

    def _self_input_user(self) -> Any:
        uc = get_user_config()
        iu = TLRPC.TL_inputUserSelf()
        return iu

    def _next_filter_id(self) -> int:
        folders = self.get_folders()
        used = set(getattr(f, "id", 0) for f in folders)
        for i in range(2, 256):
            if i not in used:
                return i
        return 2

_register_module(
    "Chat",
    SDK_VERSION,
    "Чаты/каналы/группы/форумы/папки/участники/поиск/архив/действия",
)

# ===========================================================================
# MODULE: _messages
# ===========================================================================

from dataclasses import dataclass, field

@dataclass
class MessageTemplate:
    
    name:    str
    text:    str
    aliases: List[str] = field(default_factory=list)

    def render(self, **kwargs) -> str:
        
        result = self.text
        for key, value in kwargs.items():
            result = result.replace(f"{{{key}}}", str(value))
        return result

class MacroRegistry:
    

    _macros: Dict[str, str] = {}
    _lock = threading.RLock()

    @classmethod
    def register(cls, trigger: str, expansion: str) -> None:
        
        with cls._lock:
            cls._macros[trigger] = expansion

    @classmethod
    def unregister(cls, trigger: str) -> None:
        
        with cls._lock:
            cls._macros.pop(trigger, None)

    @classmethod
    def expand(cls, text: str) -> Optional[str]:
        
        with cls._lock:
            return cls._macros.get(text.strip())

    @classmethod
    def all(cls) -> Dict[str, str]:
        
        with cls._lock:
            return dict(cls._macros)

@dataclass
class MessageMenuContext:
    
    plugin_id:   str
    cell:        Any
    message:     Any
    _menu_items: List[Dict[str, Any]] = field(default_factory=list)

    def add_menu(
        self,
        text: str,
        on_click: Callable[["MessageMenuContext"], None],
        icon: str = "",
    ) -> None:
        
        self._menu_items.append({"text": text, "on_click": on_click, "icon": icon})

class MessagesAPI:
    

    def __init__(self, owner: Any):
        self._owner = owner
        self._long_click_handlers: Dict[str, List[Callable]] = {}
        self._templates: Dict[str, MessageTemplate] = {}
        self._auto_translate_langs: Dict[str, str] = {}
        self._lock = threading.RLock()

    def on_long_click(
        self,
        plugin_id: str,
        cb: Callable[[MessageMenuContext], None],
        text: str = "",
        icon: str = "",
    ) -> None:
        
        with self._lock:
            self._long_click_handlers.setdefault(plugin_id, []).append(cb)
        item_id = f"{plugin_id}_extera_menu"
        self._owner.add_menu_item(MenuItemData(
            menu_type=MenuItemType.CHAT_ACTION_MENU,
            text=text or "Extera menu",
            icon=icon or "msg_info",
            item_id=item_id,
            priority=50,
            on_click=lambda ctx: self._dispatch_long_click(plugin_id, ctx),
        ))

    def _dispatch_long_click(self, plugin_id: str, click_ctx: Any) -> None:
        cell    = getattr(click_ctx, "cell", None)
        message = getattr(click_ctx, "message", None)
        menu_ctx = MessageMenuContext(
            plugin_id=plugin_id,
            cell=cell,
            message=message,
        )
        with self._lock:
            handlers = list(self._long_click_handlers.get(plugin_id, []))
        for cb in handlers:
            _safe_call(cb, menu_ctx, plugin_id=plugin_id)
        for item in menu_ctx._menu_items:
            _safe_call(item["on_click"], menu_ctx, plugin_id=plugin_id)

    def on_send(
        self,
        plugin_id: str,
        cb: Callable[[int, Any], Optional[str]],
    ) -> None:
        
        _events.on("on_send_message", plugin_id, cb)

    def dispatch_send(self, account: int, params: Any) -> HookResult:
        
        handlers = _events._handlers.get("on_send_message", {})
        for plugin_id, entries in list(handlers.items()):
            for entry in entries:
                result = _safe_call(entry["cb"], account, params, plugin_id=plugin_id)
                if result is False:
                    return HookResult(strategy=HookStrategy.CANCEL)
                if isinstance(result, str):
                    params.message = result
                    return HookResult(strategy=HookStrategy.MODIFY, params=params)
        return HookResult()

    def send_text(
        self,
        peer: int,
        text: str,
        reply_to_msg_id: int = 0,
        silent: bool = False,
    ) -> None:
        
        params = {
            "peer":          peer,
            "message":       text,
            "reply_to_id":   reply_to_msg_id,
            "silent":        silent,
        }
        send_message(params)

    def send_markdown(
        self,
        peer: int,
        markdown: str,
        reply_to_msg_id: int = 0,
    ) -> None:
        
        entities, text = self._parse_markdown(markdown)
        req = TLRPC.TL_messages_sendMessage()
        req.peer = self._peer_id_to_input_peer(peer)
        req.message = text
        req.random_id = self._random_id()
        req.no_webpage = True
        if reply_to_msg_id:
            req.flags |= 1
            req.reply_to_msg_id = reply_to_msg_id
        if entities:
            req.flags |= 8
            req.entities = entities

        send_request(req, lambda r, e: None)

    def send_html(self, peer: int, html: str, reply_to_msg_id: int = 0) -> None:
        
        entities, text = self._parse_html(html)
        req = TLRPC.TL_messages_sendMessage()
        req.peer = self._peer_id_to_input_peer(peer)
        req.message = text
        req.random_id = self._random_id()
        req.no_webpage = True
        if reply_to_msg_id:
            req.flags |= 1
            req.reply_to_msg_id = reply_to_msg_id
        if entities:
            req.flags |= 8
            req.entities = entities
        send_request(req, lambda r, e: None)

    def send_spoiler(self, peer: int, text: str, reply_to_msg_id: int = 0) -> None:
        
        entity = TLRPC.TL_messageEntitySpoiler()
        entity.offset = 0
        entity.length = len(text)
        req = TLRPC.TL_messages_sendMessage()
        req.peer = self._peer_id_to_input_peer(peer)
        req.message = text
        req.random_id = self._random_id()
        req.flags |= 8
        req.entities = [entity]
        if reply_to_msg_id:
            req.flags |= 1
            req.reply_to_msg_id = reply_to_msg_id
        send_request(req, lambda r, e: None)

    def edit(
        self,
        peer: int,
        message_id: int,
        new_text: str,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_editMessage()
        req.flags |= 2048
        req.peer = self._peer_id_to_input_peer(peer)
        req.id = message_id
        req.message = new_text
        req.no_webpage = True

        def _on_result(response, error):
            if on_done:
                _safe_call(on_done, error is None)

        send_request(req, _on_result)

    def delete(
        self,
        peer: int,
        message_ids: List[int],
        revoke: bool = True,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        if peer < 0:
            mc = get_messages_controller()
            chat = mc.getChat(-peer) if mc else None
            if chat and (getattr(chat, "megagroup", False) or getattr(chat, "broadcast", False)):
                req = TLRPC.TL_channels_deleteMessages()
                req.channel = self._chat_to_input_channel(chat)
                req.id = message_ids
            else:
                req = TLRPC.TL_messages_deleteMessages()
                req.id = message_ids
                req.revoke = revoke
        else:
            req = TLRPC.TL_messages_deleteMessages()
            req.id = message_ids
            req.revoke = revoke

        def _on_result(response, error):
            if on_done:
                _safe_call(on_done, error is None)

        send_request(req, _on_result)

    def reply(
        self,
        peer: int,
        reply_to_msg_id: int,
        text: str,
    ) -> None:
        
        self.send_text(peer, text, reply_to_msg_id=reply_to_msg_id)

    def forward(
        self,
        from_peer: int,
        message_ids: List[int],
        to_peer: int,
        silent: bool = False,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_forwardMessages()
        req.from_peer = self._peer_id_to_input_peer(from_peer)
        req.to_peer   = self._peer_id_to_input_peer(to_peer)
        req.id = message_ids
        req.silent = silent
        for _ in message_ids:
            req.random_id.add(self._random_id())

        def _on_result(response, error):
            if on_done:
                _safe_call(on_done, error is None)

        send_request(req, _on_result)

    def pin(
        self,
        peer: int,
        message_id: int,
        unpin: bool = False,
        silent: bool = True,
        pm_oneside: bool = False,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_updatePinnedMessage()
        req.peer      = self._peer_id_to_input_peer(peer)
        req.id        = message_id
        req.unpin     = unpin
        req.silent    = silent
        req.pm_oneside = pm_oneside

        def _on_result(response, error):
            if on_done:
                _safe_call(on_done, error is None)

        send_request(req, _on_result)

    def send_reaction(
        self,
        peer: int,
        message_id: int,
        emoji: str,
        big: bool = False,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_sendReaction()
        req.peer       = self._peer_id_to_input_peer(peer)
        req.msg_id     = message_id
        req.big        = big
        reaction = TLRPC.TL_reactionEmoji()
        reaction.emoticon = emoji
        req.reaction.add(reaction)

        def _on_result(response, error):
            if on_done:
                _safe_call(on_done, error is None)

        send_request(req, _on_result)

    def clear_reaction(
        self,
        peer: int,
        message_id: int,
        on_done: Optional[Callable[[bool], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_sendReaction()
        req.peer   = self._peer_id_to_input_peer(peer)
        req.msg_id = message_id

        def _on_result(response, error):
            if on_done:
                _safe_call(on_done, error is None)

        send_request(req, _on_result)

    def get_message(
        self,
        peer: int,
        message_id: int,
        on_result: Optional[Callable[[Optional[Any]], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_getMessages()
        req.id.add(TLRPC.TL_inputMessageID(message_id))

        def _on_result(response, error):
            msg = None
            if response and hasattr(response, "messages") and response.messages:
                msg = response.messages[0]
            if on_result:
                run_on_ui_thread(lambda: _safe_call(on_result, msg))

        send_request(req, _on_result)

    def get_history(
        self,
        peer: int,
        offset_id: int = 0,
        limit: int = 20,
        on_result: Optional[Callable[[List[Any]], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_getHistory()
        req.peer      = self._peer_id_to_input_peer(peer)
        req.offset_id = offset_id
        req.limit     = limit
        req.offset_date = 0
        req.max_id    = 0
        req.min_id    = 0
        req.hash      = 0

        def _on_result(response, error):
            messages = []
            if response and hasattr(response, "messages"):
                messages = list(response.messages)
            if on_result:
                run_on_ui_thread(lambda: _safe_call(on_result, messages))

        send_request(req, _on_result)

    def search_in_chat(
        self,
        peer: int,
        query: str,
        limit: int = 20,
        on_result: Optional[Callable[[List[Any]], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_search()
        req.peer   = self._peer_id_to_input_peer(peer)
        req.q      = query
        req.filter = TLRPC.TL_inputMessagesFilterEmpty()
        req.min_date = 0
        req.max_date = 0
        req.offset_id = 0
        req.add_offset = 0
        req.limit  = limit
        req.max_id = 0
        req.min_id = 0
        req.hash   = 0

        def _on_result(response, error):
            messages = []
            if response and hasattr(response, "messages"):
                messages = list(response.messages)
            if on_result:
                run_on_ui_thread(lambda: _safe_call(on_result, messages))

        send_request(req, _on_result)

    def apply_autocorrect(self, text: str) -> str:
        
        text = re.sub(r" {2,}", " ", text)
        text = re.sub(r" +([,.!?;:])", r"\1", text)
        text = re.sub(r"([,.!?;:])([^\s\d])", r"\1 \2", text)
        if text:
            text = text[0].upper() + text[1:]
        return text

    def apply_macros(self, text: str) -> str:
        
        expanded = MacroRegistry.expand(text)
        return expanded if expanded is not None else text

    def render_template(self, name: str, **kwargs) -> Optional[str]:
        
        with self._lock:
            tmpl = self._templates.get(name)
        if tmpl is None:
            return None
        return tmpl.render(**kwargs)

    def register_template(self, template: MessageTemplate) -> None:
        
        with self._lock:
            self._templates[template.name] = template
            for alias in template.aliases:
                self._templates[alias] = template

    def translate(
        self,
        peer: int,
        message_id: int,
        target_lang: str,
        on_result: Optional[Callable[[Optional[str]], None]] = None,
    ) -> None:
        
        req = TLRPC.TL_messages_translateText()
        req.flags |= 1
        req.peer   = self._peer_id_to_input_peer(peer)
        req.id.add(message_id)
        req.to_lang = target_lang

        def _on_result(response, error):
            text = None
            if response and hasattr(response, "result") and response.result:
                try:
                    text = str(response.result[0].text)
                except Exception:
                    pass
            if on_result:
                run_on_ui_thread(lambda: _safe_call(on_result, text))

        send_request(req, _on_result)

    def off_plugin(self, plugin_id: str) -> None:
        
        with self._lock:
            self._long_click_handlers.pop(plugin_id, None)
        _events.off_plugin(plugin_id)

    def _peer_id_to_input_peer(self, peer: int) -> Any:
        mc = get_messages_controller()
        if peer > 0:
            user = mc.getUser(peer) if mc else None
            ip = TLRPC.TL_inputPeerUser()
            ip.user_id    = peer
            ip.access_hash = getattr(user, "access_hash", 0) if user else 0
            return ip
        else:
            chat = mc.getChat(-peer) if mc else None
            if chat and (getattr(chat, "megagroup", False) or getattr(chat, "broadcast", False)):
                ip = TLRPC.TL_inputPeerChannel()
                ip.channel_id  = -peer
                ip.access_hash = getattr(chat, "access_hash", 0)
                return ip
            else:
                ip = TLRPC.TL_inputPeerChat()
                ip.chat_id = -peer
                return ip

    def _chat_to_input_channel(self, chat: Any) -> Any:
        ch = TLRPC.TL_inputChannel()
        ch.channel_id  = chat.id
        ch.access_hash = getattr(chat, "access_hash", 0)
        return ch

    def _random_id(self) -> int:
        import random
        return random.randint(-(2**63), 2**63 - 1)

    def _parse_markdown(self, text: str):
        
        entities = []
        parts = re.split(r"\*\*(.*?)\*\*", text)
        plain = ""
        for i, part in enumerate(parts):
            if i % 2 == 1:
                e = TLRPC.TL_messageEntityBold()
                e.offset = len(plain)
                e.length = len(part)
                entities.append(e)
            plain += part
        text2 = plain
        plain = ""
        entities2 = []
        parts = re.split(r"__(.*?)__", text2)
        for i, part in enumerate(parts):
            if i % 2 == 1:
                e = TLRPC.TL_messageEntityItalic()
                e.offset = len(plain)
                e.length = len(part)
                entities2.append(e)
            plain += part
        entities.extend(entities2)
        parts = re.split(r"`(.*?)`", plain)
        plain2 = ""
        entities3 = []
        for i, part in enumerate(parts):
            if i % 2 == 1:
                e = TLRPC.TL_messageEntityCode()
                e.offset = len(plain2)
                e.length = len(part)
                entities3.append(e)
            plain2 += part
        entities.extend(entities3)
        return entities, plain2

    def _parse_html(self, html: str):
        
        entities = []
        tag_map = {
            "b": TLRPC.TL_messageEntityBold,
            "strong": TLRPC.TL_messageEntityBold,
            "i": TLRPC.TL_messageEntityItalic,
            "em": TLRPC.TL_messageEntityItalic,
            "u": TLRPC.TL_messageEntityUnderline,
            "s": TLRPC.TL_messageEntityStrike,
            "del": TLRPC.TL_messageEntityStrike,
            "code": TLRPC.TL_messageEntityCode,
            "pre": TLRPC.TL_messageEntityPre,
        }
        stack = []
        result = ""
        i = 0
        while i < len(html):
            if html[i] == "<":
                end = html.find(">", i)
                if end == -1:
                    result += html[i]
                    i += 1
                    continue
                tag_full = html[i+1:end]
                i = end + 1
                if tag_full.startswith("/"):
                    tag_name = tag_full[1:].strip().lower()
                    for j in range(len(stack)-1, -1, -1):
                        if stack[j][0] == tag_name:
                            cls = stack[j][1]
                            offset = stack[j][2]
                            e = cls()
                            e.offset = offset
                            e.length = len(result) - offset
                            if tag_name == "pre":
                                e.language = ""
                            entities.append(e)
                            stack.pop(j)
                            break
                elif tag_full.lower().startswith("a ") or tag_full.lower() == "a":
                    href_match = re.search(r'href=["\']([^"\']*)["\']', tag_full)
                    url = href_match.group(1) if href_match else ""
                    stack.append(("a", None, len(result), url))
                else:
                    tag_name = tag_full.strip().lower()
                    cls = tag_map.get(tag_name)
                    if cls:
                        stack.append((tag_name, cls, len(result)))
            else:
                result += html[i]
                i += 1
        for item in stack:
            if item[0] == "a" and len(item) >= 4:
                e = TLRPC.TL_messageEntityTextUrl()
                e.offset = item[2]
                e.length = len(result) - item[2]
                e.url    = item[3]
                entities.append(e)
        return entities, result

_register_module(
    "Messages",
    SDK_VERSION,
    "Сообщения: send/edit/delete/pin/react/forward/translate/macros/templates",
)

# ===========================================================================
# MODULE: _compose
# ===========================================================================

class ComposeAPI:
    

    _poll_lock      = threading.RLock()
    _poll_running   = False
    _poll_last_text = ""
    _poll_interval  = 0.4   # секунды

    def _enter_view(self) -> Any:
        
        frag = get_last_fragment()
        if not frag:
            return None
        try:
            return get_private_field(frag, "chatActivityEnterView")
        except Exception:
            return None

    def get_text(self) -> Optional[str]:
        
        view = self._enter_view()
        if not view:
            return None
        try:
            return str(view.getFieldText())
        except Exception:
            return None

    def set_text(self, text: str) -> bool:
        
        view = self._enter_view()
        if not view:
            return False
        run_on_ui_thread(lambda: view.setFieldText(text))
        return True

    def clear(self) -> bool:
        
        return self.set_text("")

    def append_text(self, text: str) -> bool:
        
        current = self.get_text() or ""
        return self.set_text(current + text)

    def get_char_count(self) -> int:
        
        text = self.get_text()
        return len(text) if text else 0

    def set_max_chars(self, limit: int) -> bool:
        
        view = self._enter_view()
        if not view:
            return False

        def _apply():
            try:
                from org.telegram.ui.Components import EditTextCaption
                field = None
                try:
                    field = get_private_field(view, "messageEditText")
                except Exception:
                    pass
                if field is None:
                    return
                if limit > 0:
                    from android.text import InputFilter
                    field.setFilters([InputFilter.LengthFilter(limit)])
                else:
                    field.setFilters([])
            except Exception as e:
                _log(f"set_max_chars error: {e}")

        run_on_ui_thread(_apply)
        return True

    def get_cursor_position(self) -> int:
        
        view = self._enter_view()
        if not view:
            return 0
        try:
            field = get_private_field(view, "messageEditText")
            if field:
                return int(field.getSelectionStart())
        except Exception:
            pass
        return 0

    def set_cursor_position(self, pos: int) -> bool:
        
        view = self._enter_view()
        if not view:
            return False

        def _set():
            try:
                field = get_private_field(view, "messageEditText")
                if field:
                    text = field.getText()
                    safe_pos = min(max(0, pos), len(str(text)))
                    field.setSelection(safe_pos)
            except Exception as e:
                _log(f"set_cursor_position error: {e}")

        run_on_ui_thread(_set)
        return True

    def add_view(self, view: Any, height: int) -> bool:
        
        enter_view = self._enter_view()
        if not enter_view:
            return False
        run_on_ui_thread(lambda: enter_view.addTopView(view, height))
        return True

    def hide_view(self, animated: bool = True) -> bool:
        
        enter_view = self._enter_view()
        if not enter_view:
            return False
        run_on_ui_thread(lambda: enter_view.hideTopView(animated))
        return True

    def is_view_visible(self) -> bool:
        
        enter_view = self._enter_view()
        if not enter_view:
            return False
        try:
            return bool(enter_view.isTopViewVisible())
        except Exception:
            return False

    def get_send_button(self) -> Any:
        
        enter_view = self._enter_view()
        return enter_view.getSendButton() if enter_view else None

    def get_attach_button(self) -> Any:
        
        enter_view = self._enter_view()
        return enter_view.getAttachButton() if enter_view else None

    def add_button(
        self,
        plugin_id: str,
        icon_name: str,
        tooltip: str,
        on_click: Callable,
        size_dp: int = 48,
    ) -> bool:
        
        enter_view = self._enter_view()
        if not enter_view:
            return False

        def _create():
            try:
                from android.widget import ImageButton
                from android.view import View

                ctx = ApplicationLoader.applicationContext if hasattr(self, '_ctx') else None
                try:
                    ctx = AL.applicationContext
                except Exception:
                    pass

                if not ctx:
                    return

                from android.widget import ImageButton as IBtn
                btn = IBtn(ctx)
                try:
                    drawable = T.createSimpleSelectorRoundRectDrawable(
                        self._dp(4),
                        0x00000000,
                        0x20000000
                    )
                    btn.setBackground(drawable)
                except Exception:
                    pass

                try:
                    res_id = ctx.getResources().getIdentifier(
                        icon_name, "drawable", ctx.getPackageName()
                    )
                    if res_id != 0:
                        btn.setImageResource(res_id)
                except Exception:
                    pass

                btn.setContentDescription(tooltip)
                btn.setOnClickListener(lambda v: _safe_call(on_click, plugin_id=plugin_id))
                btn.setOnLongClickListener(lambda v: False)

                size_px = self._dp(size_dp)
                enter_view.addTopView(btn, size_px)
            except Exception as e:
                _log(f"add_button error: {e}")

        run_on_ui_thread(_create)
        return True

    def _dp(self, value: int) -> int:
        try:
            dm = AL.applicationContext.getResources().getDisplayMetrics()
            return int(value * dm.density + 0.5)
        except Exception:
            return value * 3

    def show_hint(self, text: str, duration_ms: int = 2000) -> None:
        
        def _show():
            try:
                BulletinHelper.show_message(text)
            except Exception as e:
                _log(f"show_hint error: {e}")

        run_on_ui_thread(_show)

    def set_placeholder(self, text: str) -> bool:
        
        view = self._enter_view()
        if not view:
            return False

        def _set():
            try:
                field = get_private_field(view, "messageEditText")
                if field:
                    field.setHint(text)
            except Exception as e:
                _log(f"set_placeholder error: {e}")

        run_on_ui_thread(_set)
        return True

    def get_reply_to_message(self) -> Any:
        
        view = self._enter_view()
        if not view:
            return None
        try:
            return get_private_field(view, "replyingMessageObject")
        except Exception:
            return None

    def get_editing_message(self) -> Any:
        
        view = self._enter_view()
        if not view:
            return None
        try:
            return get_private_field(view, "editingMessageObject")
        except Exception:
            return None

    def on_text_changed(self, plugin_id: str, cb: Callable[[str], None]) -> None:
        
        _events.on("compose_watch", plugin_id, cb)
        self._ensure_poller_started()

    def _ensure_poller_started(self) -> None:
        with self._poll_lock:
            if ComposeAPI._poll_running:
                return
            ComposeAPI._poll_running   = True
            ComposeAPI._poll_last_text = self.get_text() or ""
        self._schedule_tick()

    def _schedule_tick(self) -> None:
        t = threading.Timer(self._poll_interval, self._tick)
        t.daemon = True
        t.start()

    def _tick(self) -> None:
        subscribers = _events._handlers.get("compose_watch", {})
        if not subscribers:
            with self._poll_lock:
                ComposeAPI._poll_running = False
            return

        current = self.get_text() or ""
        if current != ComposeAPI._poll_last_text:
            ComposeAPI._poll_last_text = current
            for plugin_id, entries in list(subscribers.items()):
                for entry in entries:
                    _safe_call(entry["cb"], current, plugin_id=plugin_id)

        self._schedule_tick()

    def off_plugin(self, plugin_id: str) -> None:
        
        _events.off_plugin(plugin_id)

_register_module(
    "Compose",
    SDK_VERSION,
    "Поле ввода: text/cursor/view/buttons/hint/placeholder/autocomplete",
)

# ===========================================================================
# MODULE: _profile
# ===========================================================================

from dataclasses import dataclass, field

@dataclass
class UserProfile:
    
    user_id:             int
    first_name:          str
    last_name:           str        = ""
    username:            str        = ""
    bio:                 str        = ""
    phone:               str        = ""
    is_premium:          bool       = False
    is_verified:         bool       = False
    is_bot:              bool       = False
    is_online:           bool       = False
    last_seen_str:       str        = ""
    common_chats_count:  int        = 0
    language_code:       str        = ""
    avatar_url:          str        = ""
    access_hash:         int        = 0

    @property
    def full_name(self) -> str:
        
        return f"{self.first_name} {self.last_name}".strip()

    @property
    def display_name(self) -> str:
        
        return f"@{self.username}" if self.username else self.full_name

@dataclass
class ProfileButton:
    
    plugin_id: str
    text:      str
    icon:      str
    on_click:  Callable[[int], None]

@dataclass
class ProfileBadge:
    
    plugin_id:  str
    user_id:    int
    text:       str
    color:      int       = 0xFF2196F3
    icon:       str       = ""

class ProfileAPI:
    

    def __init__(self):
        self._profile_buttons: List[ProfileButton] = []
        self._profile_badges:  Dict[int, List[ProfileBadge]] = {}
        self._sections:        List[Dict] = []
        self._lock = threading.RLock()

    def get_user(
        self,
        user_id: int,
        on_result: Callable[[Optional[UserProfile]], None],
    ) -> None:
        
        mc = get_messages_controller()
        local_user = mc.getUser(user_id) if mc else None
        if local_user and getattr(local_user, "min", False) is False:
            profile = self._build_profile_from_tl(local_user, None)
            run_on_ui_thread(lambda: _safe_call(on_result, profile))
            return

        self.get_full_user(user_id, on_result)

    def get_full_user(
        self,
        user_id: int,
        on_result: Callable[[Optional[UserProfile]], None],
    ) -> None:
        
        mc = get_messages_controller()
        user = mc.getUser(user_id) if mc else None

        iu = TLRPC.TL_inputUser()
        iu.user_id    = user_id
        iu.access_hash = getattr(user, "access_hash", 0) if user else 0

        req = TLRPC.TL_users_getFullUser()
        req.id = iu

        def _on_result(response, error):
            if error or not response:
                run_on_ui_thread(lambda: _safe_call(on_result, None))
                return
            full_user = getattr(response, "full_user", None)
            users     = getattr(response, "users", [])
            tl_user   = None
            for u in users:
                if getattr(u, "id", 0) == user_id:
                    tl_user = u
                    break
            if tl_user is None and mc:
                tl_user = mc.getUser(user_id)
            profile = self._build_profile_from_tl(tl_user, full_user)
            run_on_ui_thread(lambda: _safe_call(on_result, profile))

        send_request(req, _on_result)

    def _build_profile_from_tl(
        self,
        user: Any,
        full_user: Any,
    ) -> Optional[UserProfile]:
        
        if user is None:
            return None

        status = getattr(user, "status", None)
        is_online = False
        last_seen_str = "неизвестно"
        if status is not None:
            type_name = type(status).__name__
            if "UserStatusOnline" in type_name:
                is_online = True
                last_seen_str = "в сети"
            elif "UserStatusOffline" in type_name:
                was_online = getattr(status, "was_online", 0)
                last_seen_str = self._format_last_seen(was_online)
            elif "UserStatusRecently" in type_name:
                last_seen_str = "недавно"
            elif "UserStatusLastWeek" in type_name:
                last_seen_str = "на прошлой неделе"
            elif "UserStatusLastMonth" in type_name:
                last_seen_str = "в прошлом месяце"

        bio = ""
        common_chats_count = 0
        if full_user:
            bio                = str(getattr(full_user, "about",              "") or "")
            common_chats_count = int(getattr(full_user, "common_chats_count", 0))

        return UserProfile(
            user_id             = int(getattr(user, "id",         0)),
            first_name          = str(getattr(user, "first_name", "") or ""),
            last_name           = str(getattr(user, "last_name",  "") or ""),
            username            = str(getattr(user, "username",   "") or ""),
            bio                 = bio,
            phone               = str(getattr(user, "phone",      "") or ""),
            is_premium          = bool(getattr(user, "premium",   False)),
            is_verified         = bool(getattr(user, "verified",  False)),
            is_bot              = bool(getattr(user, "bot",       False)),
            is_online           = is_online,
            last_seen_str       = last_seen_str,
            common_chats_count  = common_chats_count,
            language_code       = str(getattr(user, "lang_code",  "") or ""),
            access_hash         = int(getattr(user, "access_hash",0)),
        )

    def get_username(self, user_id: int) -> Optional[str]:
        
        mc = get_messages_controller()
        if not mc:
            return None
        user = mc.getUser(user_id)
        if not user:
            return None
        username = getattr(user, "username", None)
        return str(username) if username else None

    def get_bio(
        self,
        user_id: int,
        on_result: Callable[[Optional[str]], None],
    ) -> None:
        
        self.get_full_user(user_id, lambda p: on_result(p.bio if p else None))

    def is_premium(self, user_id: int) -> bool:
        
        mc = get_messages_controller()
        if not mc:
            return False
        user = mc.getUser(user_id)
        return bool(getattr(user, "premium", False)) if user else False

    def is_verified(self, user_id: int) -> bool:
        
        mc = get_messages_controller()
        if not mc:
            return False
        user = mc.getUser(user_id)
        return bool(getattr(user, "verified", False)) if user else False

    def is_bot(self, user_id: int) -> bool:
        
        mc = get_messages_controller()
        if not mc:
            return False
        user = mc.getUser(user_id)
        return bool(getattr(user, "bot", False)) if user else False

    def is_online(self, user_id: int) -> bool:
        
        mc = get_messages_controller()
        if not mc:
            return False
        user = mc.getUser(user_id)
        if not user:
            return False
        status = getattr(user, "status", None)
        if not status:
            return False
        return "UserStatusOnline" in type(status).__name__

    def get_last_seen(self, user_id: int) -> str:
        
        mc = get_messages_controller()
        if not mc:
            return "неизвестно"
        user = mc.getUser(user_id)
        if not user:
            return "неизвестно"
        status = getattr(user, "status", None)
        if not status:
            return "неизвестно"
        type_name = type(status).__name__
        if "UserStatusOnline" in type_name:
            return "в сети"
        if "UserStatusOffline" in type_name:
            return self._format_last_seen(getattr(status, "was_online", 0))
        if "UserStatusRecently" in type_name:
            return "недавно"
        if "UserStatusLastWeek" in type_name:
            return "на прошлой неделе"
        if "UserStatusLastMonth" in type_name:
            return "в прошлом месяце"
        return "неизвестно"

    def get_phone(self, user_id: int) -> Optional[str]:
        
        mc = get_messages_controller()
        if not mc:
            return None
        user = mc.getUser(user_id)
        if not user:
            return None
        phone = getattr(user, "phone", None)
        return str(phone) if phone else None

    def get_common_chats(
        self,
        user_id: int,
        on_result: Callable[[List[Any]], None],
    ) -> None:
        
        req = TLRPC.TL_messages_getCommonChats()

        mc = get_messages_controller()
        user = mc.getUser(user_id) if mc else None
        iu = TLRPC.TL_inputUser()
        iu.user_id    = user_id
        iu.access_hash = getattr(user, "access_hash", 0) if user else 0

        req.user_id   = iu
        req.max_id    = 0
        req.limit     = 100

        def _on_result(response, error):
            chats = []
            if response and hasattr(response, "chats"):
                chats = list(response.chats)
            run_on_ui_thread(lambda: _safe_call(on_result, chats))

        send_request(req, _on_result)

    def get_language_code(self, user_id: int) -> Optional[str]:
        
        mc = get_messages_controller()
        if not mc:
            return None
        user = mc.getUser(user_id)
        if not user:
            return None
        code = getattr(user, "lang_code", None)
        return str(code) if code else None

    def add_profile_button(
        self,
        plugin_id: str,
        text: str,
        icon: str,
        on_click: Callable[[int], None],
    ) -> None:
        
        with self._lock:
            self._profile_buttons.append(
                ProfileButton(plugin_id=plugin_id, text=text, icon=icon, on_click=on_click)
            )

    def get_registered_buttons(self, user_id: Optional[int] = None) -> List[ProfileButton]:
        
        with self._lock:
            return list(self._profile_buttons)

    def add_profile_section(
        self,
        plugin_id: str,
        title: str,
        items: List[Any],
    ) -> None:
        
        with self._lock:
            self._sections.append({
                "plugin_id": plugin_id,
                "title":     title,
                "items":     items,
            })

    def add_profile_badge(
        self,
        plugin_id: str,
        user_id: int,
        badge_text: str,
        badge_color: int = 0xFF2196F3,
        icon: str = "",
    ) -> None:
        
        badge = ProfileBadge(
            plugin_id=plugin_id,
            user_id=user_id,
            text=badge_text,
            color=badge_color,
            icon=icon,
        )
        with self._lock:
            self._profile_badges.setdefault(user_id, []).append(badge)

    def get_badges_for_user(self, user_id: int) -> List[ProfileBadge]:
        
        with self._lock:
            return list(self._profile_badges.get(user_id, []))

    def get_registered_sections(self) -> List[Dict]:
        
        with self._lock:
            return list(self._sections)

    def _format_last_seen(self, timestamp: int) -> str:
        
        if not timestamp:
            return "неизвестно"
        try:
            delta = int(time.time()) - timestamp
            if delta < 60:
                return "только что"
            if delta < 3600:
                mins = delta // 60
                return f"{mins} мин. назад"
            if delta < 86400:
                hours = delta // 3600
                return f"{hours} ч. назад"
            days = delta // 86400
            if days == 1:
                return "вчера"
            if days < 7:
                return f"{days} дн. назад"
            return f"{days // 7} нед. назад"
        except Exception:
            return "неизвестно"

_register_module(
    "Profile",
    SDK_VERSION,
    "Профиль: user/bio/premium/verified/badges/кнопки/разделы",
)

# ===========================================================================
# MODULE: _media
# ===========================================================================

from dataclasses import dataclass
from org.telegram.messenger import MediaController, ApplicationLoader, FileLoader

_MIME_MAP = {
    '.jpg': 'image/jpeg', '.jpeg': 'image/jpeg', '.png': 'image/png',
    '.gif': 'image/gif', '.webp': 'image/webp', '.mp4': 'video/mp4',
    '.mp3': 'audio/mpeg', '.ogg': 'audio/ogg', '.opus': 'audio/opus',
    '.webm': 'video/webm', '.mov': 'video/quicktime',
}

@dataclass
class MediaInfo:
    file_path: str
    file_size: int = 0
    mime_type: str = ''
    duration_ms: int = 0
    width: int = 0
    height: int = 0
    is_downloaded: bool = False

class MediaAPI:
    def _controller(self):
        return MediaController.getInstance()

    def play_message(self, message_object, silent=False) -> bool:
        return _safe_call(lambda: self._controller().playMessage(message_object, silent), False)

    def is_playing(self, message_object) -> bool:
        return _safe_call(lambda: self._controller().isPlayingMessage(message_object), False)

    def stop_playback(self, notify=True, refresh=True):
        _safe_call(lambda: self._controller().cleanupPlayer(notify, refresh))

    def pause(self) -> bool:
        def _do():
            ctrl = self._controller()
            current = _safe_call(lambda: ctrl.getPlayingMessageObject(), None)
            if current is not None:
                return _safe_call(lambda: ctrl.pauseMessage(current), False)
            return _safe_call(lambda: ctrl.pauseAudio(), False)
        return _safe_call(_do, False)

    def resume(self) -> bool:
        def _do():
            ctrl = self._controller()
            current = _safe_call(lambda: ctrl.getPlayingMessageObject(), None)
            if current is not None:
                return _safe_call(lambda: ctrl.resumeMessage(current), False)
            return _safe_call(lambda: ctrl.resumeAudio(), False)
        return _safe_call(_do, False)

    def get_current_playing(self) -> Optional[Any]:
        return _safe_call(lambda: self._controller().getPlayingMessageObject(), None)

    def get_playback_position(self) -> float:
        return _safe_call(lambda: float(self._controller().getPlaybackPosition()), 0.0)

    def set_playback_speed(self, speed: float):
        _safe_call(lambda: self._controller().setPlaybackSpeed(speed))

    def is_downloaded(self, message_object) -> bool:
        path = self.get_file_path(message_object)
        return path is not None and os.path.exists(path)

    def get_file_path(self, message_object) -> Optional[str]:
        def _do():
            f = FileLoader.getPathToMessage(message_object)
            if f is None:
                return None
            abs_path = f.getAbsolutePath()
            return abs_path if abs_path else None
        return _safe_call(_do, None)

    def get_file_size(self, message_object) -> int:
        def _do():
            path = self.get_file_path(message_object)
            if path is None:
                return 0
            return File(path).length()
        return _safe_call(_do, 0)

    def get_mime_type(self, message_object) -> Optional[str]:
        def _do():
            mime = getattr(getattr(message_object, 'media', None), 'mimeType', None)
            if mime:
                return mime
            path = self.get_file_path(message_object)
            if path:
                ext = os.path.splitext(path)[1].lower()
                return _MIME_MAP.get(ext, None)
            return None
        return _safe_call(_do, None)

    def download_media(self, message_object, on_progress: Callable[[float], None], on_done: Callable[[Optional[str]], None]):
        account = _safe_call(lambda: message_object.currentAccount, 0)

        def _worker():
            try:
                media = getattr(message_object, 'media', None)
                if media is None:
                    run_on_ui_thread(lambda: on_done(None))
                    return
                doc = getattr(media, 'document', None) or getattr(media, 'photo', None)
                FileLoader.getInstance(account).loadFile(doc, message_object, FileLoader.PRIORITY_HIGH, 0)
                while True:
                    path = self.get_file_path(message_object)
                    if path and os.path.exists(path):
                        run_on_ui_thread(lambda: on_done(path))
                        return
                    progress = _safe_call(lambda: FileLoader.getInstance(account).getLoadedFileProgress(doc), 0.0)
                    if on_progress:
                        run_on_ui_thread(lambda p=progress: on_progress(p))
                    threading.Event().wait(0.5)
            except Exception as e:
                _log(f'download_media error: {e}')
                run_on_ui_thread(lambda: on_done(None))

        threading.Thread(target=_worker, daemon=True).start()

    def compress_image(self, file_path: str, quality: int, on_done: Callable[[Optional[str]], None]):
        def _worker():
            try:
                from android.graphics import BitmapFactory, Bitmap
                bmp = BitmapFactory.decodeFile(file_path)
                if bmp is None:
                    run_on_ui_thread(lambda: on_done(None))
                    return
                out_path = file_path + f'_compressed_{quality}.jpg'
                fos = FileOutputStream(out_path)
                bmp.compress(Bitmap.CompressFormat.JPEG, quality, fos)
                fos.flush()
                fos.close()
                bmp.recycle()
                run_on_ui_thread(lambda: on_done(out_path))
            except Exception as e:
                _log(f'compress_image error: {e}')
                run_on_ui_thread(lambda: on_done(None))

        threading.Thread(target=_worker, daemon=True).start()

    def get_image_dimensions(self, file_path: str) -> Optional[Tuple[int, int]]:
        def _do():
            from android.graphics import BitmapFactory
            opts = BitmapFactory.Options()
            opts.inJustDecodeBounds = True
            BitmapFactory.decodeFile(file_path, opts)
            if opts.outWidth > 0 and opts.outHeight > 0:
                return (opts.outWidth, opts.outHeight)
            return None
        return _safe_call(_do, None)

    def create_thumbnail(self, file_path: str, width: int, height: int, on_done: Callable[[Optional[bytes]], None]):
        def _worker():
            try:
                from android.graphics import BitmapFactory, Bitmap
                from java.io import ByteArrayOutputStream
                bmp = BitmapFactory.decodeFile(file_path)
                if bmp is None:
                    run_on_ui_thread(lambda: on_done(None))
                    return
                scaled = Bitmap.createScaledBitmap(bmp, width, height, True)
                bmp.recycle()
                baos = ByteArrayOutputStream()
                scaled.compress(Bitmap.CompressFormat.JPEG, 80, baos)
                scaled.recycle()
                data = bytes(baos.toByteArray())
                run_on_ui_thread(lambda: on_done(data))
            except Exception as e:
                _log(f'create_thumbnail error: {e}')
                run_on_ui_thread(lambda: on_done(None))

        threading.Thread(target=_worker, daemon=True).start()

    def get_exif(self, file_path: str) -> Dict[str, Any]:
        def _do():
            from androidx.exifinterface.media import ExifInterface
            exif = ExifInterface(file_path)
            tags = {
                'datetime':   ExifInterface.TAG_DATETIME,
                'gps_lat':    ExifInterface.TAG_GPS_LATITUDE,
                'gps_lon':    ExifInterface.TAG_GPS_LONGITUDE,
                'make':       ExifInterface.TAG_MAKE,
                'model':      ExifInterface.TAG_MODEL,
                'width':      ExifInterface.TAG_IMAGE_WIDTH,
                'height':     ExifInterface.TAG_IMAGE_LENGTH,
                'flash':      ExifInterface.TAG_FLASH,
            }
            result = {}
            for key, tag in tags.items():
                val = exif.getAttribute(tag)
                if val is not None:
                    result[key] = val
            return result
        return _safe_call(_do, {})

    def get_media_info(self, message_object) -> MediaInfo:
        def _do():
            media = getattr(message_object, 'media', None)
            path = self.get_file_path(message_object) or ''
            size = self.get_file_size(message_object)
            mime = self.get_mime_type(message_object) or ''
            duration = int(getattr(media, 'duration', 0) * 1000) if media else 0
            w = getattr(media, 'w', 0) if media else 0
            h = getattr(media, 'h', 0) if media else 0
            downloaded = bool(path and os.path.exists(path))
            return MediaInfo(path, size, mime, duration, w, h, downloaded)
        return _safe_call(_do, MediaInfo(''))

_register_module('Media', SDK_VERSION, 'Медиа: play/download/compress/thumbnail/EXIF')

# ===========================================================================
# MODULE: _navigation
# ===========================================================================

from org.telegram.messenger import AndroidUtilities

class NavigationAPI:
    def open_chat(self, dialog_id: int):
        def _do():
            from org.telegram.ui import ChatActivity
            from android.os import Bundle
            frag = get_last_fragment()
            if frag is None:
                return
            args = AndroidUtilities.createBundleForChat(dialog_id, 0)
            frag.presentFragment(ChatActivity(args))
        run_on_ui_thread(_do)

    def open_profile(self, user_id: int):
        def _do():
            from org.telegram.ui import ProfileActivity
            from android.os import Bundle
            frag = get_last_fragment()
            if frag is None:
                return
            args = Bundle()
            args.putLong('user_id', user_id)
            frag.presentFragment(ProfileActivity(args))
        run_on_ui_thread(_do)

    def open_message(self, dialog_id: int, message_id: int):
        def _do():
            from org.telegram.ui import ChatActivity
            frag = get_last_fragment()
            if frag is None:
                return
            args = AndroidUtilities.createBundleForChat(dialog_id, 0)
            args.putInt('message_id', message_id)
            frag.presentFragment(ChatActivity(args))
        run_on_ui_thread(_do)

    def open_settings(self):
        def _do():
            from org.telegram.ui import SettingsActivity
            frag = get_last_fragment()
            if frag is None:
                return
            frag.presentFragment(SettingsActivity())
        run_on_ui_thread(_do)

    def open_extera_settings(self):
        def _do():
            frag = get_last_fragment()
            if frag is None:
                return
            try:
                from xyz.extera.ui import ExteraSettings
                frag.presentFragment(ExteraSettings())
            except Exception:
                self.open_settings()
        run_on_ui_thread(_do)

    def open_plugin_settings(self, plugin_id: str):
        def _do():
            try:
                from xyz.extera.plugins import PluginsController
                PluginsController.getInstance().openSettings(plugin_id)
            except Exception as e:
                _log(f'open_plugin_settings({plugin_id}) error: {e}')
        run_on_ui_thread(_do)

    def open_story(self, user_id: int, story_id: int):
        def _do():
            from org.telegram.ui import StoryViewer
            from android.os import Bundle
            frag = get_last_fragment()
            if frag is None:
                return
            args = Bundle()
            args.putLong('user_id', user_id)
            args.putInt('story_id', story_id)
            frag.presentFragment(StoryViewer(args))
        run_on_ui_thread(_do)

    def show_bottom_sheet(self, sheet_view):
        def _do():
            from org.telegram.ui.ActionBar import BottomSheet
            frag = get_last_fragment()
            if frag is None:
                return
            ctx = frag.getParentActivity()
            builder = BottomSheet.Builder(ctx)
            builder.setCustomView(sheet_view)
            builder.show()
        run_on_ui_thread(_do)

    def pop_back(self):
        def _do():
            frag = get_last_fragment()
            if frag is not None:
                frag.finishFragment()
        run_on_ui_thread(_do)

    def can_go_back(self) -> bool:
        def _do():
            frag = get_last_fragment()
            return frag is not None and frag.getParentLayout() is not None
        return _safe_call(_do, False)

    def open_url(self, url: str):
        def _do():
            try:
                from org.telegram.ui import LaunchActivity
                ctx = ApplicationLoader.applicationContext
                LaunchActivity.openUrl(url, ctx)
            except Exception:
                try:
                    from org.telegram.ui import Browser
                    ctx = ApplicationLoader.applicationContext
                    Browser.openUrl(ctx, url)
                except Exception as e:
                    _log(f'open_url({url}) error: {e}')
        run_on_ui_thread(_do)

    def open_username(self, username: str):
        req = TLRPC.TL_contacts_resolveUsername()
        req.username = username

        def _on_result(result, error):
            if error is not None or result is None:
                _log(f'open_username({username}) error: {error}')
                return
            peer = result.peer
            if peer.user_id != 0:
                self.open_profile(peer.user_id)
            elif peer.channel_id != 0:
                self.open_chat(-peer.channel_id)
            elif peer.chat_id != 0:
                self.open_chat(-peer.chat_id)

        send_request(req, _on_result)

    def open_phone(self, phone: str):
        req = TLRPC.TL_contacts_resolvePhone()
        req.phone = phone

        def _on_result(result, error):
            if error is not None or result is None:
                _log(f'open_phone({phone}) error: {error}')
                return
            if result.users:
                self.open_profile(result.users[0].id)

        send_request(req, _on_result)

    def get_back_stack_depth(self) -> int:
        def _do():
            frag = get_last_fragment()
            if frag is None:
                return 0
            layout = frag.getParentLayout()
            if layout is None:
                return 0
            return layout.getFragmentCount()
        return _safe_call(_do, 0)

_register_module('Navigation', SDK_VERSION, 'Навигация: чаты/профили/сообщения/настройки/BottomSheet')

# ===========================================================================
# MODULE: _settings
# ===========================================================================

from dataclasses import dataclass, field
from enum import Enum

class SettingType(Enum):
    HEADER          = "header"
    FOOTER          = "footer"
    DESCRIPTION     = "description"
    DIVIDER         = "divider"
    BUTTON          = "button"
    DANGER_BUTTON   = "danger_button"
    ICON_BUTTON     = "icon_button"
    IMAGE_BUTTON    = "image_button"
    SWITCH          = "switch"
    CHECKBOX        = "checkbox"
    RADIO           = "radio"
    DROPDOWN        = "dropdown"
    INPUT           = "input"
    PASSWORD        = "password"
    NUMBER          = "number"
    SLIDER          = "slider"
    SEEKBAR         = "seekbar"
    COLOR_PICKER    = "color_picker"
    GRADIENT_PICKER = "gradient_picker"
    BLUR_PICKER     = "blur_picker"
    EMOJI_PICKER    = "emoji_picker"
    ICON_PICKER     = "icon_picker"
    FONT_PICKER     = "font_picker"
    MULTI_SELECT    = "multi_select"
    ABOUT_CARD      = "about_card"
    DEVELOPER_CARD  = "developer_card"
    VERSION_CARD    = "version_card"
    LICENSE_CARD    = "license_card"
    DONATE_CARD     = "donate_card"
    FAQ_CARD        = "faq_card"
    PREMIUM_CARD    = "premium_card"
    EXPERIMENTAL    = "experimental"
    IMPORT          = "import"
    EXPORT          = "export"
    BACKUP          = "backup"
    RESTORE         = "restore"
    CUSTOM          = "custom"

@dataclass
class SettingItem:
    
    setting_type:  SettingType
    key:           str           = ""
    text:          str           = ""
    subtext:       str           = ""
    icon:          str           = ""
    default:       Any           = None
    on_change:     Optional[Callable]   = None
    on_click:      Optional[Callable]   = None
    visible_when:  Optional[Callable[[], bool]] = None
    hidden:        bool          = False
    search_tags:   List[str]     = field(default_factory=list)
    meta:          Dict[str, Any] = field(default_factory=dict)

    def is_visible(self) -> bool:
        
        if self.hidden:
            return False
        if self.visible_when is not None:
            try:
                return bool(self.visible_when())
            except Exception:
                return True
        return True

    def matches_search(self, query: str) -> bool:
        
        if not query:
            return True
        q = query.lower()
        if q in self.text.lower():
            return True
        if q in self.subtext.lower():
            return True
        for tag in self.search_tags:
            if q in tag.lower():
                return True
        return False

class SettingsAPI:
    

    def header(self, text: str, icon: str = "") -> SettingItem:
        
        return SettingItem(
            setting_type=SettingType.HEADER,
            text=text,
            icon=icon,
        )

    def footer(self, text: str) -> SettingItem:
        
        return SettingItem(setting_type=SettingType.FOOTER, text=text)

    def description(self, text: str, icon: str = "") -> SettingItem:
        
        return SettingItem(
            setting_type=SettingType.DESCRIPTION,
            text=text,
            icon=icon,
        )

    def divider(self) -> SettingItem:
        
        return SettingItem(setting_type=SettingType.DIVIDER)

    def button(
        self,
        key: str,
        text: str,
        icon: str = "",
        on_click: Optional[Callable] = None,
        subtext: str = "",
        search_tags: Optional[List[str]] = None,
    ) -> SettingItem:
        
        return SettingItem(
            setting_type=SettingType.BUTTON,
            key=key,
            text=text,
            icon=icon,
            on_click=on_click,
            subtext=subtext,
            search_tags=search_tags or [],
        )

    def danger_button(
        self,
        key: str,
        text: str,
        icon: str = "",
        on_click: Optional[Callable] = None,
        subtext: str = "",
    ) -> SettingItem:
        
        return SettingItem(
            setting_type=SettingType.DANGER_BUTTON,
            key=key,
            text=text,
            icon=icon,
            on_click=on_click,
            subtext=subtext,
        )

    def icon_button(
        self,
        key: str,
        text: str,
        icon: str,
        on_click: Optional[Callable] = None,
    ) -> SettingItem:
        
        return SettingItem(
            setting_type=SettingType.ICON_BUTTON,
            key=key,
            text=text,
            icon=icon,
            on_click=on_click,
        )

    def switch(
        self,
        key: str,
        text: str,
        default: bool = False,
        icon: str = "",
        subtext: str = "",
        on_change: Optional[Callable[[bool], None]] = None,
        visible_when: Optional[Callable[[], bool]] = None,
        search_tags: Optional[List[str]] = None,
    ) -> SettingItem:
        
        return SettingItem(
            setting_type=SettingType.SWITCH,
            key=key,
            text=text,
            default=default,
            icon=icon,
            subtext=subtext,
            on_change=on_change,
            visible_when=visible_when,
            search_tags=search_tags or [],
        )

    def checkbox(
        self,
        key: str,
        text: str,
        default: bool = False,
        icon: str = "",
        on_change: Optional[Callable[[bool], None]] = None,
        visible_when: Optional[Callable[[], bool]] = None,
    ) -> SettingItem:
        
        return SettingItem(
            setting_type=SettingType.CHECKBOX,
            key=key,
            text=text,
            default=default,
            icon=icon,
            on_change=on_change,
            visible_when=visible_when,
        )

    def radio(
        self,
        key: str,
        text: str,
        group: str,
        value: Any,
        default: bool = False,
        icon: str = "",
        on_change: Optional[Callable[[Any], None]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.RADIO,
            key=key,
            text=text,
            default=default,
            icon=icon,
            on_change=on_change,
        )
        item.meta["group"] = group
        item.meta["value"] = value
        return item

    def dropdown(
        self,
        key: str,
        text: str,
        items: List[str],
        default: int = 0,
        icon: str = "",
        on_change: Optional[Callable[[int, str], None]] = None,
        visible_when: Optional[Callable[[], bool]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.DROPDOWN,
            key=key,
            text=text,
            default=default,
            icon=icon,
            on_change=on_change,
            visible_when=visible_when,
        )
        item.meta["items"] = items
        return item

    def input(
        self,
        key: str,
        text: str,
        default: str = "",
        icon: str = "",
        subtext: str = "",
        placeholder: str = "",
        max_length: int = 0,
        on_change: Optional[Callable[[str], None]] = None,
        visible_when: Optional[Callable[[], bool]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.INPUT,
            key=key,
            text=text,
            default=default,
            icon=icon,
            subtext=subtext,
            on_change=on_change,
            visible_when=visible_when,
        )
        item.meta["placeholder"] = placeholder
        item.meta["max_length"]  = max_length
        return item

    def password(
        self,
        key: str,
        text: str,
        default: str = "",
        icon: str = "",
        on_change: Optional[Callable[[str], None]] = None,
    ) -> SettingItem:
        
        return SettingItem(
            setting_type=SettingType.PASSWORD,
            key=key,
            text=text,
            default=default,
            icon=icon,
            on_change=on_change,
        )

    def number(
        self,
        key: str,
        text: str,
        default: int = 0,
        min_val: int = 0,
        max_val: int = 9999,
        icon: str = "",
        on_change: Optional[Callable[[int], None]] = None,
        visible_when: Optional[Callable[[], bool]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.NUMBER,
            key=key,
            text=text,
            default=default,
            icon=icon,
            on_change=on_change,
            visible_when=visible_when,
        )
        item.meta["min"] = min_val
        item.meta["max"] = max_val
        return item

    def slider(
        self,
        key: str,
        text: str,
        min_val: float = 0.0,
        max_val: float = 100.0,
        default: float = 50.0,
        step: float = 1.0,
        icon: str = "",
        format_value: Optional[Callable[[float], str]] = None,
        on_change: Optional[Callable[[float], None]] = None,
        visible_when: Optional[Callable[[], bool]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.SLIDER,
            key=key,
            text=text,
            default=default,
            icon=icon,
            on_change=on_change,
            visible_when=visible_when,
        )
        item.meta["min"]          = min_val
        item.meta["max"]          = max_val
        item.meta["step"]         = step
        item.meta["format_value"] = format_value
        return item

    def seekbar(
        self,
        key: str,
        text: str,
        min_val: int = 0,
        max_val: int = 100,
        default: int = 50,
        icon: str = "",
        on_change: Optional[Callable[[int], None]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.SEEKBAR,
            key=key,
            text=text,
            default=default,
            icon=icon,
            on_change=on_change,
        )
        item.meta["min"] = min_val
        item.meta["max"] = max_val
        return item

    def color_picker(
        self,
        key: str,
        text: str,
        default: int = 0xFF2196F3,
        icon: str = "",
        alpha: bool = True,
        on_change: Optional[Callable[[int], None]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.COLOR_PICKER,
            key=key,
            text=text,
            default=default,
            icon=icon,
            on_change=on_change,
        )
        item.meta["alpha"] = alpha
        return item

    def gradient_picker(
        self,
        key: str,
        text: str,
        default: Optional[List[int]] = None,
        icon: str = "",
        on_change: Optional[Callable[[List[int]], None]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.GRADIENT_PICKER,
            key=key,
            text=text,
            default=default or [0xFF2196F3, 0xFF9C27B0],
            icon=icon,
            on_change=on_change,
        )
        return item

    def blur_picker(
        self,
        key: str,
        text: str,
        default: int = 10,
        icon: str = "",
        on_change: Optional[Callable[[int], None]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.BLUR_PICKER,
            key=key,
            text=text,
            default=default,
            icon=icon,
            on_change=on_change,
        )
        item.meta["min"] = 0
        item.meta["max"] = 25
        return item

    def emoji_picker(
        self,
        key: str,
        text: str,
        default: str = "",
        icon: str = "",
        on_change: Optional[Callable[[str], None]] = None,
    ) -> SettingItem:
        
        return SettingItem(
            setting_type=SettingType.EMOJI_PICKER,
            key=key,
            text=text,
            default=default,
            icon=icon,
            on_change=on_change,
        )

    def icon_picker(
        self,
        key: str,
        text: str,
        icons: List[str],
        default: str = "",
        on_change: Optional[Callable[[str], None]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.ICON_PICKER,
            key=key,
            text=text,
            default=default,
            on_change=on_change,
        )
        item.meta["icons"] = icons
        return item

    def font_picker(
        self,
        key: str,
        text: str,
        fonts: List[str],
        default: str = "Roboto",
        icon: str = "",
        on_change: Optional[Callable[[str], None]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.FONT_PICKER,
            key=key,
            text=text,
            default=default,
            icon=icon,
            on_change=on_change,
        )
        item.meta["fonts"] = fonts
        return item

    def multi_select(
        self,
        key: str,
        text: str,
        options: List[str],
        default: Optional[List[str]] = None,
        icon: str = "",
        on_change: Optional[Callable[[List[str]], None]] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.MULTI_SELECT,
            key=key,
            text=text,
            default=default or [],
            icon=icon,
            on_change=on_change,
        )
        item.meta["options"] = options
        return item

    def about_card(
        self,
        plugin_name: str,
        author: str,
        version: str,
        description: str = "",
        icon: str = "",
        channel: str = "",
        source: str = "",
        on_click: Optional[Callable] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.ABOUT_CARD,
            text=plugin_name,
            subtext=f"v{version} • {author}",
            icon=icon,
            on_click=on_click,
        )
        item.meta.update({
            "plugin_name": plugin_name,
            "author":      author,
            "version":     version,
            "description": description,
            "channel":     channel,
            "source":      source,
        })
        return item

    def developer_card(
        self,
        name: str,
        username: str,
        role: str = "Developer",
        avatar_url: str = "",
        on_click: Optional[Callable] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.DEVELOPER_CARD,
            text=name,
            subtext=f"@{username} • {role}",
            on_click=on_click,
        )
        item.meta.update({
            "name":       name,
            "username":   username,
            "role":       role,
            "avatar_url": avatar_url,
        })
        return item

    def version_card(
        self,
        plugin_version: str,
        lib_version: str,
        apk_version: str = "",
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.VERSION_CARD,
            text="Версии",
            subtext=f"Плагин {plugin_version} • ExsteraLib {lib_version}",
        )
        item.meta.update({
            "plugin_version": plugin_version,
            "lib_version":    lib_version,
            "apk_version":    apk_version,
        })
        return item

    def license_card(
        self,
        license_name: str = "MIT",
        license_url: str = "",
        on_click: Optional[Callable] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.LICENSE_CARD,
            text=f"Лицензия: {license_name}",
            on_click=on_click,
        )
        item.meta["license_url"] = license_url
        return item

    def donate_card(
        self,
        text: str = "Поддержать разработчика",
        url: str = "",
        icon: str = "msg_gift_premium",
        on_click: Optional[Callable] = None,
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.DONATE_CARD,
            text=text,
            icon=icon,
            on_click=on_click,
        )
        item.meta["url"] = url
        return item

    def faq_card(
        self,
        questions: List[Dict[str, str]],
        icon: str = "msg_help",
    ) -> SettingItem:
        
        item = SettingItem(
            setting_type=SettingType.FAQ_CARD,
            text="FAQ",
            icon=icon,
        )
        item.meta["questions"] = questions
        return item

    def premium_card(
        self,
        text: str = "Доступно только Premium пользователям",
        icon: str = "msg_premium_lock",
        on_click: Optional[Callable] = None,
    ) -> SettingItem:
        
        return SettingItem(
            setting_type=SettingType.PREMIUM_CARD,
            text=text,
            icon=icon,
            on_click=on_click,
        )

    def experimental(
        self,
        key: str,
        text: str,
        subtext: str = "Экспериментальная функция — может работать нестабильно",
        default: bool = False,
        on_change: Optional[Callable[[bool], None]] = None,
    ) -> SettingItem:
        
        return SettingItem(
            setting_type=SettingType.EXPERIMENTAL,
            key=key,
            text=text,
            subtext=subtext,
            default=default,
            icon="msg_settings",
            on_change=on_change,
        )

    def import_settings(
        self,
        plugin_id: str,
        on_import: Optional[Callable[[Dict[str, Any]], None]] = None,
    ) -> SettingItem:
        
        def _click():
            self._do_import(plugin_id, on_import)

        item = SettingItem(
            setting_type=SettingType.IMPORT,
            text="Импорт настроек",
            icon="msg_download",
            on_click=_click,
        )
        item.meta["plugin_id"] = plugin_id
        return item

    def export_settings(
        self,
        plugin_id: str,
        data_provider: Callable[[], Dict[str, Any]],
    ) -> SettingItem:
        
        def _click():
            self._do_export(plugin_id, data_provider)

        item = SettingItem(
            setting_type=SettingType.EXPORT,
            text="Экспорт настроек",
            icon="msg_share",
            on_click=_click,
        )
        item.meta["plugin_id"] = plugin_id
        return item

    def backup(
        self,
        plugin_id: str,
        data_provider: Callable[[], Dict[str, Any]],
    ) -> SettingItem:
        
        def _click():
            self._do_backup(plugin_id, data_provider)

        item = SettingItem(
            setting_type=SettingType.BACKUP,
            text="Создать резервную копию",
            icon="msg_saved",
            on_click=_click,
        )
        return item

    def restore(
        self,
        plugin_id: str,
        on_restore: Optional[Callable[[Dict[str, Any]], None]] = None,
    ) -> SettingItem:
        
        def _click():
            self._do_restore(plugin_id, on_restore)

        item = SettingItem(
            setting_type=SettingType.RESTORE,
            text="Восстановить из резервной копии",
            icon="msg_retry",
            on_click=_click,
        )
        return item

    def search(self, items: List[SettingItem], query: str) -> List[SettingItem]:
        
        if not query:
            return [item for item in items if item.is_visible()]
        return [
            item for item in items
            if item.is_visible() and item.matches_search(query)
            and item.setting_type not in (SettingType.DIVIDER, SettingType.HEADER)
        ]

    def filter_visible(self, items: List[SettingItem]) -> List[SettingItem]:
        
        return [item for item in items if item.is_visible()]

    def text(self, text: str, icon: str = "", on_click: Optional[Callable] = None) -> Any:
        
        return Text(text=text, icon=icon, on_click=on_click)

    def selector(
        self,
        key: str,
        text: str,
        items: List[str],
        default: int = 0,
        icon: str = "",
    ) -> Any:
        
        return Selector(key=key, text=text, items=items, default=default, icon=icon)

    def _do_export(self, plugin_id: str, data_provider: Callable) -> None:
        try:
            data = data_provider()
            export_dir = File(
                ApplicationLoader.applicationContext.getExternalFilesDir(None),
                "exsteralib_exports"
            )
            export_dir.mkdirs()
            filename = f"{plugin_id}_settings_{int(time.time())}.json"
            path = os.path.join(export_dir.getAbsolutePath(), filename)
            with open(path, "w", encoding="utf-8") as f:
                json.dump(data, f, ensure_ascii=False, indent=2)
            _log(f"Settings exported to {path}")
        except Exception as e:
            _log(f"export_settings error: {e}")

    def _do_import(self, plugin_id: str, on_import: Optional[Callable]) -> None:
        try:
            export_dir = File(
                ApplicationLoader.applicationContext.getExternalFilesDir(None),
                "exsteralib_exports"
            )
            if not export_dir.exists():
                return
            files = [
                f for f in os.listdir(export_dir.getAbsolutePath())
                if f.startswith(plugin_id) and f.endswith(".json")
            ]
            if not files:
                _log(f"import_settings: no files found for {plugin_id}")
                return
            files.sort(reverse=True)
            path = os.path.join(export_dir.getAbsolutePath(), files[0])
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            if on_import:
                run_on_ui_thread(lambda: on_import(data))
        except Exception as e:
            _log(f"import_settings error: {e}")

    def _do_backup(self, plugin_id: str, data_provider: Callable) -> None:
        self._do_export(f"{plugin_id}_backup", data_provider)

    def _do_restore(self, plugin_id: str, on_restore: Optional[Callable]) -> None:
        self._do_import(f"{plugin_id}_backup", on_restore)

_register_module(
    "Settings",
    SDK_VERSION,
    "Конструктор настроек: 30+ типов элементов, поиск, import/export, per-account/chat",
)

# ===========================================================================
# MODULE: _notifications
# ===========================================================================

class NotificationsAPI:

    CHANNEL_ID = 'exsteralib_notifications'
    CHANNEL_NAME = 'ExsteraLib Plugins'

    _notif_counter = 0
    _lock = threading.RLock()

    _notif_builders: Dict[int, Any] = {}

    def _ensure_channel(self):
        try:
            from android.os import Build
            from android.app import NotificationChannel, NotificationManager
            if Build.VERSION.SDK_INT >= 26:
                ctx = ApplicationLoader.applicationContext
                manager = ctx.getSystemService(NotificationManager)
                channel = NotificationChannel(
                    self.CHANNEL_ID,
                    self.CHANNEL_NAME,
                    NotificationManager.IMPORTANCE_DEFAULT,
                )
                manager.createNotificationChannel(channel)
        except Exception as e:
            _log(f'_ensure_channel: {e}')

    def _next_id(self) -> int:
        with self._lock:
            NotificationsAPI._notif_counter += 1
            return NotificationsAPI._notif_counter

    def _get_manager(self):
        from android.app import NotificationManager
        from android.content import Context
        return ApplicationLoader.applicationContext.getSystemService(Context.NOTIFICATION_SERVICE)

    def _resolve_icon(self, icon_name: str) -> int:
        try:
            ctx = ApplicationLoader.applicationContext
            return ctx.getResources().getIdentifier(icon_name, 'drawable', ctx.getPackageName())
        except Exception:
            return 0

    def create_notification(self, title: str, text: str, icon: str = 'msg_info',
                            channel_id: str = '', on_click=None) -> int:
        self._ensure_channel()
        from androidx.core.app import NotificationCompat
        try:
            ctx = ApplicationLoader.applicationContext
            cid = channel_id or self.CHANNEL_ID
            builder = NotificationCompat.Builder(ctx, cid)
            icon_res = self._resolve_icon(icon)
            if icon_res:
                builder.setSmallIcon(icon_res)
            builder.setContentTitle(title)
            builder.setContentText(text)
            builder.setAutoCancel(True)

            if on_click:
                from android.app import PendingIntent
                from android.content import Intent
                intent = Intent()
                intent.setAction(f'exsteralib.notif.click.{id(on_click)}')
                pi = PendingIntent.getBroadcast(ctx, 0, intent,
                                                PendingIntent.FLAG_IMMUTABLE | PendingIntent.FLAG_UPDATE_CURRENT)
                builder.setContentIntent(pi)

            notif_id = self._next_id()
            self._notif_builders[notif_id] = builder
            self._get_manager().notify(notif_id, builder.build())
            return notif_id
        except Exception as e:
            _log(f'create_notification: {e}')
            return -1

    def update_notification(self, notif_id: int, title: str, text: str,
                            progress: Optional[int] = None):
        try:
            builder = self._notif_builders.get(notif_id)
            if not builder:
                _log(f'update_notification: unknown id {notif_id}')
                return
            builder.setContentTitle(title)
            builder.setContentText(text)
            if progress is not None:
                builder.setProgress(100, progress, False)
            self._get_manager().notify(notif_id, builder.build())
        except Exception as e:
            _log(f'update_notification: {e}')

    def cancel_notification(self, notif_id: int):
        try:
            self._get_manager().cancel(notif_id)
            self._notif_builders.pop(notif_id, None)
        except Exception as e:
            _log(f'cancel_notification: {e}')

    def create_progress_notification(self, title: str, text: str, max_val: int = 100) -> int:
        self._ensure_channel()
        from androidx.core.app import NotificationCompat
        try:
            ctx = ApplicationLoader.applicationContext
            builder = NotificationCompat.Builder(ctx, self.CHANNEL_ID)
            builder.setContentTitle(title)
            builder.setContentText(text)
            builder.setProgress(max_val, 0, False)
            builder.setOngoing(True)
            notif_id = self._next_id()
            self._notif_builders[notif_id] = builder
            self._get_manager().notify(notif_id, builder.build())
            return notif_id
        except Exception as e:
            _log(f'create_progress_notification: {e}')
            return -1

    def update_progress(self, notif_id: int, progress: int, text: str = ''):
        try:
            builder = self._notif_builders.get(notif_id)
            if not builder:
                return
            if text:
                builder.setContentText(text)
            builder.setProgress(100, max(0, min(100, progress)), False)
            if progress >= 100:
                builder.setOngoing(False)
            self._get_manager().notify(notif_id, builder.build())
        except Exception as e:
            _log(f'update_progress: {e}')

    def create_download_notification(self, title: str, file_name: str) -> int:
        return self.create_progress_notification(
            title, f'Downloading: {file_name}'
        )

    def create_upload_notification(self, title: str, file_name: str) -> int:
        return self.create_progress_notification(
            title, f'Uploading: {file_name}'
        )

    def add_action_button(self, notif_id: int, action_text: str, action_icon: str,
                          action_data: str = ''):
        try:
            from android.app import PendingIntent
            from android.content import Intent
            from androidx.core.app import NotificationCompat
            builder = self._notif_builders.get(notif_id)
            if not builder:
                _log(f'add_action_button: unknown id {notif_id}')
                return
            ctx = ApplicationLoader.applicationContext
            intent = Intent()
            intent.setAction(f'exsteralib.notif.action.{notif_id}.{action_data}')
            pi = PendingIntent.getBroadcast(ctx, notif_id, intent,
                                            PendingIntent.FLAG_IMMUTABLE | PendingIntent.FLAG_UPDATE_CURRENT)
            icon_res = self._resolve_icon(action_icon)
            builder.addAction(icon_res, action_text, pi)
            self._get_manager().notify(notif_id, builder.build())
        except Exception as e:
            _log(f'add_action_button: {e}')

    def show_media_notification(self, title: str, artist: str, duration_ms: int,
                                bitmap_bytes=None) -> int:
        self._ensure_channel()
        try:
            from androidx.core.app import NotificationCompat
            from androidx.media.app import NotificationCompat as MediaNotifCompat
            from android.graphics import BitmapFactory
            ctx = ApplicationLoader.applicationContext
            builder = NotificationCompat.Builder(ctx, self.CHANNEL_ID)
            builder.setContentTitle(title)
            builder.setContentText(artist)
            builder.setStyle(MediaNotifCompat.MediaStyle())
            builder.setOngoing(True)

            if bitmap_bytes:
                bmp = BitmapFactory.decodeByteArray(bitmap_bytes, 0, len(bitmap_bytes))
                builder.setLargeIcon(bmp)

            notif_id = self._next_id()
            self._notif_builders[notif_id] = builder
            self._get_manager().notify(notif_id, builder.build())
            return notif_id
        except Exception as e:
            _log(f'show_media_notification: {e}')
            return -1

    def cancel_all(self):
        try:
            self._get_manager().cancelAll()
            self._notif_builders.clear()
        except Exception as e:
            _log(f'cancel_all: {e}')

_register_module('Notifications', SDK_VERSION, 'Уведомления: create/progress/download/upload/media/actions')

# ===========================================================================
# MODULE: _scheduler
# ===========================================================================

from dataclasses import dataclass, field

@dataclass
class TaskHandle:
    task_id: str
    cancelled: bool = False

class SchedulerAPI:
    _tasks: Dict[str, Any] = {}
    _lock = threading.RLock()
    _id_counter = 0

    def _generate_id(self) -> str:
        with self._lock:
            self._id_counter += 1
            return f'task_{self._id_counter}'

    def delay(self, fn: Callable, ms: int, task_id: str = '') -> TaskHandle:
        tid = task_id or self._generate_id()
        handle = TaskHandle(task_id=tid)

        def _wrapped():
            if not handle.cancelled:
                _safe_call(fn)
            self._cleanup_done(tid)

        timer = threading.Timer(ms / 1000.0, _wrapped)
        with self._lock:
            self._tasks[tid] = {'timer': timer, 'handle': handle, 'type': 'delay'}
        timer.daemon = True
        timer.start()
        return handle

    def repeat(self, fn: Callable, interval_ms: int, task_id: str = '', max_runs: int = 0) -> TaskHandle:
        tid = task_id or self._generate_id()
        handle = TaskHandle(task_id=tid)
        stop_event = threading.Event()

        def _loop():
            runs = 0
            while not stop_event.is_set() and not handle.cancelled:
                stop_event.wait(interval_ms / 1000.0)
                if stop_event.is_set() or handle.cancelled:
                    break
                _safe_call(fn)
                runs += 1
                if max_runs > 0 and runs >= max_runs:
                    break
            self._cleanup_done(tid)

        t = threading.Thread(target=_loop, daemon=True)
        with self._lock:
            self._tasks[tid] = {'thread': t, 'stop_event': stop_event, 'handle': handle, 'type': 'repeat'}
        t.start()
        return handle

    def cancel(self, handle: TaskHandle) -> bool:
        if handle.cancelled:
            return False
        handle.cancelled = True
        with self._lock:
            entry = self._tasks.get(handle.task_id)
        if entry is None:
            return False
        if entry['type'] == 'delay':
            timer = entry.get('timer')
            if timer:
                timer.cancel()
        elif entry['type'] == 'repeat':
            stop_event = entry.get('stop_event')
            if stop_event:
                stop_event.set()
        self._cleanup_done(handle.task_id)
        return True

    def cancel_all(self) -> int:
        with self._lock:
            entries = list(self._tasks.items())
        count = 0
        for tid, entry in entries:
            handle = entry.get('handle')
            if handle and not handle.cancelled:
                self.cancel(handle)
                count += 1
        return count

    def run_async(self, fn: Callable, on_done: Callable = None, args: tuple = ()) -> TaskHandle:
        tid = self._generate_id()
        handle = TaskHandle(task_id=tid)

        def _worker():
            if handle.cancelled:
                return
            result = _safe_call(lambda: fn(*args), None)
            if on_done and not handle.cancelled:
                try:
                    run_on_ui_thread(lambda: on_done(result))
                except Exception:
                    _safe_call(lambda: on_done(result))
            self._cleanup_done(tid)

        t = threading.Thread(target=_worker, daemon=True)
        with self._lock:
            self._tasks[tid] = {'thread': t, 'handle': handle, 'type': 'async'}
        t.start()
        return handle

    def run_at(self, fn: Callable, unix_timestamp: int) -> TaskHandle:
        delay_s = unix_timestamp - time.time()
        if delay_s <= 0:
            return self.run_async(fn)
        return self.delay(fn, int(delay_s * 1000))

    def active_count(self) -> int:
        with self._lock:
            return sum(
                1 for entry in self._tasks.values()
                if not entry.get('handle', TaskHandle('')).cancelled
            )

    def _cleanup_done(self, task_id: str):
        with self._lock:
            self._tasks.pop(task_id, None)

_register_module('Scheduler', SDK_VERSION, 'Планировщик: delay/repeat/async/cancel')

# ===========================================================================
# MODULE: _permissions
# ===========================================================================

_pending_callbacks: Dict[int, Callable] = {}
_pending_multi_callbacks: Dict[int, Dict] = {}
_request_code_counter = [1000]

def _next_request_code() -> int:
    _request_code_counter[0] += 1
    return _request_code_counter[0]

def _on_permissions_result(request_code: int, permissions: List[str], grant_results: List[int]):
    from android.content.pm import PackageManager
    single_cb = _pending_callbacks.pop(request_code, None)
    if single_cb is not None:
        granted = bool(grant_results and grant_results[0] == PackageManager.PERMISSION_GRANTED)
        run_on_ui_thread(lambda: single_cb(granted))
        return
    multi_cb_entry = _pending_multi_callbacks.pop(request_code, None)
    if multi_cb_entry is not None:
        cb = multi_cb_entry['callback']
        result: Dict[str, bool] = {}
        for i, perm in enumerate(permissions):
            result[perm] = (i < len(grant_results) and grant_results[i] == PackageManager.PERMISSION_GRANTED)
        run_on_ui_thread(lambda: cb(result))

class PermissionsAPI:
    CAMERA = 'android.permission.CAMERA'
    READ_EXTERNAL = 'android.permission.READ_EXTERNAL_STORAGE'
    WRITE_EXTERNAL = 'android.permission.WRITE_EXTERNAL_STORAGE'
    RECORD_AUDIO = 'android.permission.RECORD_AUDIO'
    READ_CONTACTS = 'android.permission.READ_CONTACTS'
    ACCESS_LOCATION = 'android.permission.ACCESS_FINE_LOCATION'
    READ_MEDIA_IMAGES = 'android.permission.READ_MEDIA_IMAGES'
    READ_MEDIA_VIDEO = 'android.permission.READ_MEDIA_VIDEO'
    POST_NOTIFICATIONS = 'android.permission.POST_NOTIFICATIONS'

    ALL_PERMISSIONS = [
        'android.permission.CAMERA',
        'android.permission.READ_EXTERNAL_STORAGE',
        'android.permission.WRITE_EXTERNAL_STORAGE',
        'android.permission.RECORD_AUDIO',
        'android.permission.READ_CONTACTS',
        'android.permission.ACCESS_FINE_LOCATION',
        'android.permission.READ_MEDIA_IMAGES',
        'android.permission.READ_MEDIA_VIDEO',
        'android.permission.POST_NOTIFICATIONS',
    ]

    def _context(self):
        return ApplicationLoader.applicationContext

    def _activity(self):
        try:
            from org.telegram.ui import LaunchActivity
            return LaunchActivity.instance
        except Exception:
            return None

    def is_granted(self, permission: str) -> bool:
        def _do():
            from androidx.core.content import ContextCompat
            from android.content.pm import PackageManager
            return ContextCompat.checkSelfPermission(self._context(), permission) == PackageManager.PERMISSION_GRANTED
        return _safe_call(_do, False)

    def is_denied(self, permission: str) -> bool:
        return not self.is_granted(permission)

    def check_multiple(self, permissions: List[str]) -> Dict[str, bool]:
        return {p: self.is_granted(p) for p in permissions}

    def request(self, permission: str, on_result: Callable[[bool], None]):
        def _do():
            if self.is_granted(permission):
                on_result(True)
                return
            activity = self._activity()
            if activity is None:
                _log('request: no activity available')
                on_result(False)
                return
            from androidx.core.app import ActivityCompat
            code = _next_request_code()
            _pending_callbacks[code] = on_result
            ActivityCompat.requestPermissions(activity, [permission], code)
        run_on_ui_thread(_do)

    def request_multiple(self, permissions: List[str], on_result: Callable[[Dict[str, bool]], None]):
        def _do():
            already_granted = {p for p in permissions if self.is_granted(p)}
            to_request = [p for p in permissions if p not in already_granted]

            if not to_request:
                on_result({p: True for p in permissions})
                return

            activity = self._activity()
            if activity is None:
                _log('request_multiple: no activity available')
                on_result({p: False for p in permissions})
                return

            from androidx.core.app import ActivityCompat
            code = _next_request_code()
            _pending_multi_callbacks[code] = {
                'callback': lambda result: on_result({**{p: True for p in already_granted}, **result}),
            }
            ActivityCompat.requestPermissions(activity, to_request, code)
        run_on_ui_thread(_do)

    def should_show_rationale(self, permission: str) -> bool:
        def _do():
            activity = self._activity()
            if activity is None:
                return False
            return activity.shouldShowRequestPermissionRationale(permission)
        return _safe_call(_do, False)

    def open_app_settings(self):
        def _do():
            from android.content import Intent
            from android.net import Uri
            from android.provider import Settings
            ctx = self._context()
            intent = Intent(Settings.ACTION_APPLICATION_DETAILS_SETTINGS)
            intent.setData(Uri.fromParts('package', ctx.getPackageName(), None))
            intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
            ctx.startActivity(intent)
        run_on_ui_thread(_do)

    def get_all_granted(self) -> List[str]:
        return [p for p in self.ALL_PERMISSIONS if self.is_granted(p)]

_register_module('Permissions', SDK_VERSION, 'Android разрешения: проверка/запрос/настройки')

# ===========================================================================
# MODULE: _animation
# ===========================================================================

class AnimationAPI:

    def fade_in(self, view, duration_ms=250, on_end=None):
        def _run():
            anim = view.animate().alpha(1.0).setDuration(duration_ms)
            if on_end:
                anim.withEndAction(on_end)
            anim.start()
        run_on_ui_thread(_run)

    def fade_out(self, view, duration_ms=250, on_end=None):
        def _run():
            anim = view.animate().alpha(0.0).setDuration(duration_ms)
            if on_end:
                anim.withEndAction(on_end)
            anim.start()
        run_on_ui_thread(_run)

    def scale_in(self, view, from_scale=0.8, duration_ms=200, on_end=None):
        def _run():
            view.setScaleX(from_scale)
            view.setScaleY(from_scale)
            anim = view.animate().scaleX(1.0).scaleY(1.0).setDuration(duration_ms)
            if on_end:
                anim.withEndAction(on_end)
            anim.start()
        run_on_ui_thread(_run)

    def scale_out(self, view, to_scale=0.8, duration_ms=200, on_end=None):
        def _run():
            anim = view.animate().scaleX(to_scale).scaleY(to_scale).setDuration(duration_ms)
            if on_end:
                anim.withEndAction(on_end)
            anim.start()
        run_on_ui_thread(_run)

    def slide_in_from_bottom(self, view, duration_ms=300, on_end=None):
        def _run():
            view.setTranslationY(view.getHeight())
            anim = view.animate().translationY(0).setDuration(duration_ms)
            if on_end:
                anim.withEndAction(on_end)
            anim.start()
        run_on_ui_thread(_run)

    def slide_out_to_bottom(self, view, duration_ms=300, on_end=None):
        def _run():
            anim = view.animate().translationY(view.getHeight()).setDuration(duration_ms)
            if on_end:
                anim.withEndAction(on_end)
            anim.start()
        run_on_ui_thread(_run)

    def slide_in_from_right(self, view, duration_ms=300, on_end=None):
        def _run():
            view.setTranslationX(view.getWidth())
            anim = view.animate().translationX(0).setDuration(duration_ms)
            if on_end:
                anim.withEndAction(on_end)
            anim.start()
        run_on_ui_thread(_run)

    def slide_out_to_right(self, view, duration_ms=300, on_end=None):
        def _run():
            anim = view.animate().translationX(view.getWidth()).setDuration(duration_ms)
            if on_end:
                anim.withEndAction(on_end)
            anim.start()
        run_on_ui_thread(_run)

    def shake(self, view, intensity_dp=5, duration_ms=500):
        from android.animation import ObjectAnimator, Keyframe, PropertyValuesHolder
        def _run():
            kf0 = Keyframe.ofFloat(0.0, 0.0)
            kf1 = Keyframe.ofFloat(0.25, float(intensity_dp))
            kf2 = Keyframe.ofFloat(0.5, 0.0)
            kf3 = Keyframe.ofFloat(0.75, float(-intensity_dp))
            kf4 = Keyframe.ofFloat(1.0, 0.0)
            pvh = PropertyValuesHolder.ofKeyframe('translationX', kf0, kf1, kf2, kf3, kf4)
            anim = ObjectAnimator.ofPropertyValuesHolder(view, pvh)
            anim.setDuration(duration_ms)
            anim.start()
        run_on_ui_thread(_run)

    def pulse(self, view, scale=1.1, duration_ms=300, on_end=None):
        def _run():
            half = duration_ms // 2
            def _scale_down():
                anim2 = view.animate().scaleX(1.0).scaleY(1.0).setDuration(half)
                if on_end:
                    anim2.withEndAction(on_end)
                anim2.start()
            view.animate().scaleX(scale).scaleY(scale).setDuration(half).withEndAction(_scale_down).start()
        run_on_ui_thread(_run)

    def spring_scale(self, view, from_scale=0.5, stiffness=400, damping=0.7):
        def _run():
            try:
                from androidx.dynamicanimation.animation import SpringAnimation, SpringForce
                view.setScaleX(from_scale)
                view.setScaleY(from_scale)
                force = SpringForce(1.0)
                force.setStiffness(float(stiffness))
                force.setDampingRatio(float(damping))
                sx = SpringAnimation(view, SpringAnimation.SCALE_X)
                sx.setSpring(force)
                sy = SpringAnimation(view, SpringAnimation.SCALE_Y)
                sy.setSpring(force)
                sx.start()
                sy.start()
            except Exception:
                self.scale_in(view, from_scale=from_scale)
        run_on_ui_thread(_run)

    def cross_fade(self, from_view, to_view, duration_ms=200):
        def _run():
            to_view.setAlpha(0.0)
            to_view.setVisibility(0)  # VISIBLE
            from_view.animate().alpha(0.0).setDuration(duration_ms).start()
            to_view.animate().alpha(1.0).setDuration(duration_ms).start()
        run_on_ui_thread(_run)

    def rotate(self, view, degrees=360, duration_ms=600, on_end=None):
        def _run():
            anim = view.animate().rotation(float(degrees)).setDuration(duration_ms)
            if on_end:
                anim.withEndAction(on_end)
            anim.start()
        run_on_ui_thread(_run)

    def bounce(self, view, height_dp=20, duration_ms=400):
        from android.animation import ObjectAnimator, Keyframe, PropertyValuesHolder
        def _run():
            kf0 = Keyframe.ofFloat(0.0, 0.0)
            kf1 = Keyframe.ofFloat(0.4, float(-height_dp))
            kf2 = Keyframe.ofFloat(0.7, float(-height_dp * 0.5))
            kf3 = Keyframe.ofFloat(1.0, 0.0)
            pvh = PropertyValuesHolder.ofKeyframe('translationY', kf0, kf1, kf2, kf3)
            anim = ObjectAnimator.ofPropertyValuesHolder(view, pvh)
            anim.setDuration(duration_ms)
            anim.start()
        run_on_ui_thread(_run)

    def get_interpolator(self, name: str):
        from android.view.animation import (
            LinearInterpolator, AccelerateInterpolator, DecelerateInterpolator,
            OvershootInterpolator, AnticipateInterpolator, BounceInterpolator,
            AccelerateDecelerateInterpolator
        )
        _map = {
            'linear': LinearInterpolator,
            'accelerate': AccelerateInterpolator,
            'decelerate': DecelerateInterpolator,
            'overshoot': OvershootInterpolator,
            'anticipate': AnticipateInterpolator,
            'bounce': BounceInterpolator,
            'spring': AccelerateDecelerateInterpolator,
        }
        cls = _map.get(name, LinearInterpolator)
        return cls()

    def cancel_all(self, view):
        def _run():
            view.animate().cancel()
        run_on_ui_thread(_run)

_register_module('Animation', SDK_VERSION, 'Анимации: fade/scale/slide/spring/shake/bounce')

