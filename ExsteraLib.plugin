from dataclasses import dataclass, field

@dataclass
class StoryInfo:
    story_id: int
    user_id: int
    date: int = 0
    expire_date: int = 0
    has_media: bool = False
    views_count: int = 0
    forwards_count: int = 0
    reactions_count: int = 0
    caption: str = ''

class StoriesAPI:
    _auto_view: bool = False

    def get_user_stories(self, user_id: int, on_result: Callable[[List[StoryInfo]], None]):
        req = TLRPC.TL_stories_getUserStories()
        req.user_id = self._input_user(user_id)

        def _on_response(res, err):
            if err or res is None:
                _log('get_user_stories error: ' + str(err))
                run_on_ui_thread(lambda: on_result([]))
                return
            stories = []
            try:
                for tl in res.stories:
                    stories.append(self._parse_story(tl))
            except Exception as e:
                _log('get_user_stories parse error: ' + str(e))
            run_on_ui_thread(lambda: on_result(stories))

        send_request(req, _on_response)

    def get_story(self, user_id: int, story_id: int, on_result: Callable[[Optional[StoryInfo]], None]):
        req = TLRPC.TL_stories_getStoriesByID()
        req.user_id = self._input_user(user_id)
        req.id = [story_id]

        def _on_response(res, err):
            if err or res is None or not res.stories:
                run_on_ui_thread(lambda: on_result(None))
                return
            try:
                info = self._parse_story(res.stories[0])
            except Exception as e:
                _log('get_story parse error: ' + str(e))
                info = None
            run_on_ui_thread(lambda: on_result(info))

        send_request(req, _on_response)

    def delete_story(self, story_id: int, on_done: Callable[[bool], None]):
        req = TLRPC.TL_stories_deleteStories()
        req.id = [story_id]

        def _on_response(res, err):
            ok = err is None and res is not None
            run_on_ui_thread(lambda: on_done(ok))

        send_request(req, _on_response)

    def download_story(self, user_id: int, story_id: int,
                       on_progress: Callable[[float], None],
                       on_done: Callable[[Optional[str]], None]):
        def _fetch():
            result_holder = [None]
            event = threading.Event()

            def _got_story(info):
                result_holder[0] = info
                event.set()

            self.get_story(user_id, story_id, _got_story)
            event.wait(timeout=15)
            info = result_holder[0]
            if info is None or not info.has_media:
                run_on_ui_thread(lambda: on_done(None))
                return
            try:
                from org.telegram.messenger import FileLoader, ImageLocation
                on_progress(0.0)
                path = FileLoader.getInstance(0).getPathToAttach(None, True)
                on_progress(1.0)
                run_on_ui_thread(lambda: on_done(str(path) if path else None))
            except Exception as e:
                _log('download_story error: ' + str(e))
                run_on_ui_thread(lambda: on_done(None))

        t = threading.Thread(target=_fetch)
        t.daemon = True
        t.start()

    def view_story(self, user_id: int, story_id: int, on_done: Callable[[bool], None]):
        req = TLRPC.TL_stories_incrementStoryViews()
        req.user_id = self._input_user(user_id)
        req.id = [story_id]

        def _on_response(res, err):
            ok = err is None and res is not None
            run_on_ui_thread(lambda: on_done(ok))

        send_request(req, _on_response)

    def send_reaction(self, user_id: int, story_id: int, emoji: str, on_done: Callable[[bool], None]):
        req = TLRPC.TL_stories_sendReaction()
        req.user_id = self._input_user(user_id)
        req.story_id = story_id
        reaction = TLRPC.TL_reactionEmoji()
        reaction.emoticon = emoji
        req.reaction = reaction

        def _on_response(res, err):
            ok = err is None and res is not None
            run_on_ui_thread(lambda: on_done(ok))

        send_request(req, _on_response)

    def get_viewers(self, story_id: int, limit: int = 50, on_result: Callable[[List[Any]], None] = None):
        req = TLRPC.TL_stories_getStoryViewsList()
        req.id = story_id
        req.limit = limit
        req.offset = ''

        def _on_response(res, err):
            viewers = []
            if err is None and res is not None:
                try:
                    viewers = list(res.views)
                except Exception as e:
                    _log('get_viewers parse error: ' + str(e))
            if on_result is not None:
                run_on_ui_thread(lambda: on_result(viewers))

        send_request(req, _on_response)

    @property
    def auto_view_mode(self) -> bool:
        return self._auto_view

    @auto_view_mode.setter
    def auto_view_mode(self, value: bool):
        self._auto_view = value

    def on_story_received(self, plugin_id: str, cb: Callable[[StoryInfo], None]):
        _events.on('story_received', plugin_id, cb)

    def _parse_story(self, tl: Any) -> StoryInfo:
        info = StoryInfo(story_id=tl.id, user_id=getattr(tl, 'user_id', 0))
        info.date = getattr(tl, 'date', 0)
        info.expire_date = getattr(tl, 'expire_date', 0)
        info.has_media = getattr(tl, 'media', None) is not None
        views = getattr(tl, 'views', None)
        if views is not None:
            info.views_count = getattr(views, 'views_count', 0)
            info.forwards_count = getattr(views, 'forwards_count', 0)
            info.reactions_count = getattr(views, 'reactions_count', 0)
        cap = getattr(tl, 'caption', None)
        info.caption = str(cap) if cap else ''
        return info

    def _input_user(self, user_id: int) -> Any:
        from org.telegram.messenger import MessagesController, UserConfig
        account = UserConfig.selectedAccount
        ctrl = MessagesController.getInstance(account)
        user = ctrl.getUser(user_id)
        inp = TLRPC.TL_inputUser()
        if user is not None:
            inp.user_id = user.id
            inp.access_hash = user.access_hash
        else:
            inp.user_id = user_id
            inp.access_hash = 0
        return inp

_register_module('Stories', SDK_VERSION, 'Stories: get/delete/download/view/react')

